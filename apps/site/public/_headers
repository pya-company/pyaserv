/*
  # Security / privacy headers applied to every Cloudflare Pages response.
  #
  # CSP locked down to:
  #   - script-src: 'self' + 'unsafe-inline' for the inline FOUC/locale init
  #     scripts in Base.astro. We use Trusted Types so DOM XSS is blocked at
  #     the sink level even if a string gets injected somewhere.
  #   - connect-src: 'self' + api.pyaserv.com (our worker)
  #   - frame-ancestors 'none' replaces X-Frame-Options
  #   - upgrade-insecure-requests for any stray http://
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://api.pyaserv.com https://images.unsplash.com; font-src 'self' data:; connect-src 'self' https://api.pyaserv.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests; require-trusted-types-for 'script'; trusted-types default ps-html lit-html
  Content-Security-Policy-Report-Only: require-trusted-types-for 'script'
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=()
  X-Frame-Options: DENY

# Never let CF Pages cache the service worker — its update logic depends on
# fresh byte-checks against /sw.js on every load.
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

# Explicit content-type for PWA manifest (CF Pages may not auto-detect .webmanifest).
/manifest.webmanifest
  Content-Type: application/manifest+json; charset=utf-8

/sitemap.xml
  Content-Type: application/xml; charset=utf-8

# Hashed Astro assets — content hash changes when bytes change, so we can
# cache aggressively (1 year, immutable). Saves a 304 round-trip every 4 h
# for returning visitors on slow PY 3G.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static prerendered HTML — let CF edge cache for an hour with SWR so the
# CDN can serve from cache, instead of returning Cf-Cache-Status: DYNAMIC.
/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
  Cdn-Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/specialists/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
  Cdn-Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/clients/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
  Cdn-Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/docs/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
  Cdn-Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/docs/*
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
  Cdn-Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/releases/
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
  Cdn-Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/releases/*
  Cache-Control: public, max-age=0, s-maxage=3600, stale-while-revalidate=86400, must-revalidate
  Cdn-Cache-Control: public, max-age=3600, stale-while-revalidate=86400
