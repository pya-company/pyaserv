    "jspdf": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.61.0",
    "chrome-launcher": "^1.1.2",
    "esbuild": "^0.28.1",
    "lighthouse": "^12.3.0",
    "puppeteer-core": "^23.0.0",
    "typescript": "^5.7.2"
  }
