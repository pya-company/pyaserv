---
import '~/styles/global.css'
import T from '~/components/T.astro'
import LoginDialog from '~/components/LoginDialog.astro'
import EnrollToast from '~/components/EnrollToast.astro'
import { ClientRouter } from 'astro:transitions'

interface Props {
  readonly title: string
  readonly description?: string
  readonly active?: 'home' | 'specialists' | 'clients' | 'me' | 'login'
  // Title in Spanish (default UI language used by static frontmatter rendering).
  // For locale-aware <title>, supply a translation key via `titleKey`.
  readonly titleKey?: string
  readonly descriptionKey?: string
}

const { title, description, active = 'home', titleKey, descriptionKey } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const href = (path: string): string => `${base}${path}`
const fallbackDesc = 'PyaServ — marketplace de servicios en Paraguay sin comisiones. Conectá con plomeros, electricistas, peluqueras, profes y más, directo y sin intermediarios.'
const canonical = `https://pyaserv.com${Astro.url.pathname}`
---
<html lang="es" data-title-key={titleKey} data-desc-key={descriptionKey}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title} · PyaServ</title>
    <meta name="description" content={description ?? fallbackDesc} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#4f46e5" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#111827" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} · PyaServ`} />
    <meta property="og:description" content={description ?? fallbackDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="PyaServ" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" type="image/svg+xml" href={href('/favicon.svg')} />
    <link rel="preconnect" href="https://api.pyaserv.com" crossorigin />
    <link rel="dns-prefetch" href="https://api.pyaserv.com" />
    <!-- Synchronous bootstrap: Trusted Types default policy + locale/theme/auth
         pre-paint. External file so CSP can drop 'unsafe-inline' from script-src.
         Parser-blocking position in <head> guarantees pre-body execution. -->
    <script src={href('/bootstrap.js')}></script>
    <!-- Astro's MPA-style view transitions — fade between pages, persist scroll
         position, keep our pre-paint <html data-…> attrs across navigations. -->
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="ps-skip"><T k="nav.skip" /></a>
    <header class="ps-topbar" id="topbar">
      <a href={href('/')} class="ps-topbar__brand">
        <span class="ps-topbar__brand-em">Pya</span>Serv
      </a>
      <nav class="ps-topbar__nav" id="topnav" data-i18n-aria="nav.primary_aria" aria-label="Principal">
        <a href={href('/specialists/')} aria-current={active === 'specialists' ? 'page' : undefined}><T k="nav.specialists" /></a>
        <a href={href('/clients/')} aria-current={active === 'clients' ? 'page' : undefined}><T k="nav.clients" /></a>
        <a href={href('/me/')} aria-current={active === 'me' ? 'page' : undefined} data-nav-me><T k="nav.me" /></a>
        <!-- Sign in is a dialog trigger, not a page link. data-nav-login hides
             it for authed users via the existing html[data-auth=user] CSS. -->
        <button type="button" class="ps-topbar__nav-btn" data-open-login data-nav-login><T k="nav.login" /></button>
        <!-- Sign out: visible only to authed users via html[data-auth=guest]
             [data-nav-logout]{display:none}. Wired via document delegation. -->
        <button type="button" class="ps-topbar__nav-btn" data-nav-logout id="nav-logout">
          <span lang="es">Cerrar sesión</span>
          <span lang="en">Sign out</span>
        </button>
        <div class="ps-lang-switch" role="group" data-i18n-aria="nav.lang_label" aria-label="Idioma">
          <button type="button" class="ps-lang-btn" data-lang="es" data-i18n-aria="nav.lang_es_aria" aria-label="Cambiar a español">ES</button>
          <button type="button" class="ps-lang-btn" data-lang="en" data-i18n-aria="nav.lang_en_aria" aria-label="Cambiar a inglés">EN</button>
        </div>
        <button type="button" class="ps-theme-btn" id="theme-btn" data-i18n-aria="nav.theme_label" aria-label="Cambiar tema">
          <span class="ps-theme-icon" aria-hidden="true"></span>
        </button>
      </nav>
    </header>
    <!--
      Mobile floating menu. Uses @igor-ganov/flying-menu (Lit web component):
      draggable, snaps to corners, persists position via localStorage. Replaces
      the old hamburger drawer on mobile. Hidden on desktop via CSS.
      Slots: trigger (the icon) and menu (the nav links).
    -->
    <flying-menu class="ps-fly" corner="bottom-right" storage-key="pyaserv.fly-corner">
      <button slot="trigger" type="button" class="ps-fly__trigger" id="menu-btn" data-i18n-aria="nav.menu_open" aria-label="Abrir menú">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
      </button>
      <div slot="menu" class="ps-fly__menu" role="menu">
        <a href={href('/specialists/')} role="menuitem"><T k="nav.specialists" /></a>
        <a href={href('/clients/')} role="menuitem"><T k="nav.clients" /></a>
        <a href={href('/me/')} role="menuitem" data-nav-me><T k="nav.me" /></a>
        <button type="button" role="menuitem" data-open-login data-nav-login class="ps-fly__menuitem"><T k="nav.login" /></button>
        <button type="button" role="menuitem" data-nav-logout class="ps-fly__menuitem">
          <span lang="es">Cerrar sesión</span>
          <span lang="en">Sign out</span>
        </button>
        <div class="ps-fly__row">
          <div class="ps-lang-switch" role="group" data-i18n-aria="nav.lang_label" aria-label="Idioma">
            <button type="button" class="ps-lang-btn" data-lang="es" data-i18n-aria="nav.lang_es_aria" aria-label="Cambiar a español">ES</button>
            <button type="button" class="ps-lang-btn" data-lang="en" data-i18n-aria="nav.lang_en_aria" aria-label="Cambiar a inglés">EN</button>
          </div>
          <button type="button" class="ps-theme-btn" data-i18n-aria="nav.theme_label" aria-label="Cambiar tema">
            <span class="ps-theme-icon" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </flying-menu>
    <main id="main-content" class="ps-shell">
      <slot />
    </main>
    <LoginDialog />
    <EnrollToast />
    <footer class="ps-foot">
      © PyaServ · <a href={href('/')}><T k="foot.brother" /></a> · <T k="foot.built_on" />
    </footer>
    <script>
      // @ts-nocheck
      // Register the <flying-menu> custom element (mobile nav). Lit-based,
      // side-effect import — defines the element on first execution.
      import '@igor-ganov/flying-menu'
      import { applyI18n, getLocale, setLocale, t } from '../lib/i18n.ts'
      import { apiFetch, clearToken, setToken } from '../lib/api.ts'
      import { assertPasskey, enrollPasskey, startConditionalLogin } from '../features/passkey/client.ts'
      import {
        authenticatorLabel,
        conditionalUiAvailable,
        guessPlatform,
        passkeySupported,
        platformAuthenticatorAvailable,
      } from '../features/passkey/platform.ts'
      import {
        dismissPromptForCooldown,
        isPromptOnCooldown,
        muteForeverAfterEnroll,
      } from '../features/passkey/prompt-cooldown.ts'

      // ClientRouter swaps the body but does NOT re-run inline scripts.
      // Everything that touches DOM-state per-page must run on every
      // astro:page-load (which Astro also fires on the very first load).
      // Document-level handlers below are attached ONCE (delegated) so they
      // survive every swap automatically.

      const isTheme = (v) => v === 'light' || v === 'dark' || v === 'auto'
      const isLoc = (v) => v === 'es' || v === 'en'

      // --- per-page wireup ---------------------------------------------------
      const initPage = () => {
        // 1. Re-apply locale + theme + auth from storage to <html>. ClientRouter
        //    swaps in the SSR'd <html lang="es"> for every new page; without
        //    this the EN-locale user sees ES UI from /specialists/ onward.
        try {
          const stored = localStorage.getItem('pyaserv.locale')
          const loc = isLoc(stored) ? stored : (navigator.language || '').toLowerCase().startsWith('en') ? 'en' : 'es'
          document.documentElement.lang = loc
          document.documentElement.dataset.loc = loc
        } catch {}
        try {
          const stTheme = localStorage.getItem('pyaserv.theme')
          document.documentElement.dataset.theme = isTheme(stTheme) ? stTheme : 'auto'
        } catch {}
        try {
          const token = sessionStorage.getItem('pyaserv.token')
          document.documentElement.dataset.auth = token ? 'user' : 'guest'
        } catch {}

        // 2. Apply i18n to data-i18n* attributes (placeholder/aria, not visible
        //    text — visible text is dual-rendered SSR'd).
        applyI18n(document)
        document.documentElement.dataset.i18nReady = '1'

        // 3. Localized <title>/<meta description>
        const titleKey = document.documentElement.dataset.titleKey
        const descKey = document.documentElement.dataset.descKey
        if (titleKey) document.title = `${t(titleKey)} · PyaServ`
        if (descKey) {
          const meta = document.querySelector('meta[name="description"]')
          if (meta) meta.setAttribute('content', t(descKey))
        }

        // 4. Mark active language button (aria-pressed only — click is delegated)
        const loc = getLocale()
        for (const b of document.querySelectorAll('.ps-lang-btn')) {
          b.setAttribute('aria-pressed', b.dataset.lang === loc ? 'true' : 'false')
        }

        // 5. Defensively close any flying-menu that may be left open across nav
        const fly = document.querySelector('flying-menu')
        if (fly && typeof fly.closeMenu === 'function') fly.closeMenu()

        // 5b. Defensive: authed users must never see the login dialog. If a
        //     prior page-life cycle left it open, close it now.
        if (document.documentElement.dataset.auth === 'user') {
          const d = document.getElementById('login-dlg')
          if (d && d.open && typeof d.close === 'function') d.close()
        }

        // 6a. #email=...&code=... — magic-link arrival. Pulls the email +
        //     6-digit code out of the URL fragment, posts /otp/verify, signs
        //     the user in, strips the fragment. Fragments aren't sent to the
        //     server so the code can't be pre-fetched by mail scanners.
        //     Skipped on /login/ which is itself a redirect — its hash gets
        //     forwarded to / and handled there to avoid racing the fetch
        //     against the redirect's navigation.
        try {
          if (location.hash &&
              !location.pathname.endsWith('/login/') &&
              document.documentElement.dataset.auth !== 'user') {
            const params = new URLSearchParams(location.hash.replace(/^#/, ''))
            const email = params.get('email') ?? ''
            const code = params.get('code') ?? ''
            if (email && /^\d{6}$/.test(code)) {
              // Clear hash immediately so a reload doesn't re-attempt with a spent code
              history.replaceState({}, '', location.pathname + location.search)
              void handleMagicLink(email, code)
              return
            }
          }
        } catch {}

        // 6b. ?login=1 → auto-open the dialog (entry point from the redirect
        //    that the legacy /login/ page emits, and from anything that wants
        //    to deep-link to "show me the sign-in").
        try {
          const url = new URL(location.href)
          if (url.searchParams.get('login') === '1' &&
              document.documentElement.dataset.auth !== 'user') {
            const next = url.searchParams.get('next') ?? ''
            url.searchParams.delete('login')
            url.searchParams.delete('next')
            history.replaceState({}, '', url.toString())
            openLoginDialog(next)
          }
        } catch {}
      }

      // Magic-link arrival: verify the code without showing the dialog.
      // If it succeeds, we're signed in. If it fails, fall back to opening
      // the dialog at the verify step with the email pre-filled so the user
      // can re-enter / paste a fresh code.
      const handleMagicLink = async (email, code) => {
        let data
        try {
          data = await apiFetch('/api/auth/otp/verify', {
            method: 'POST',
            body: JSON.stringify({ email, code }),
          })
        } catch {
          // Open dialog with email pre-filled so the user can retry manually
          openLoginDialog()
          const inp = document.querySelector('#dlg-start input[name="email"]')
          if (inp) inp.value = email
          return
        }
        if (data?.sid) {
          setToken(data.sid)
          document.documentElement.dataset.auth = 'user'
          if (data.hasPasskey === false) void maybeShowEnrollToast()
          if (data.redirect) location.href = data.redirect
          // Otherwise stay on the current page — user is now signed in.
        }
      }

      // ====== Login dialog =========================================================

      const dlgState = {
        email: '',
        next: '',
      }
      const dlg = () => document.getElementById('login-dlg')
      const dlgEl = (id) => document.getElementById(id)
      const dlgShow = (id) => { const el = dlgEl(id); if (el) el.hidden = false }
      const dlgHide = (id) => { const el = dlgEl(id); if (el) el.hidden = true }
      const dlgMsg = (html) => { const el = dlgEl('dlg-msg'); if (el) el.innerHTML = html }
      const dlgReset = () => {
        const start = dlgEl('dlg-start'); if (start) start.reset()
        const verify = dlgEl('dlg-verify'); if (verify) verify.reset()
        dlgHide('dlg-verify')
        dlgHide('dlg-enroll')
        dlgShow('dlg-start')
        dlgMsg('')
        dlgState.email = ''
      }
      const closeDialog = (next) => {
        const d = dlg()
        if (d && typeof d.close === 'function' && d.open) d.close()
        if (next) location.href = next
      }
      const afterAuthed = (sid, next) => {
        setToken(sid)
        document.documentElement.dataset.auth = 'user'
        closeDialog(next || dlgState.next || '')
      }

      // S26: try the discoverable passkey first. If the OS resolves quickly,
      // we go signed-in without ever showing the email form. On cancel/error
      // the email form is already visible — the user just types their email.
      const tryPasskeyFirst = async () => {
        if (!passkeySupported()) return
        if (!(await platformAuthenticatorAvailable())) return
        const ctl = new AbortController()
        // Aborted by start-form submit, by closing the dialog, or by another
        // tryPasskeyFirst run (we want at most one in flight).
        const onCancel = () => ctl.abort()
        const d = dlg()
        d?.addEventListener('close', onCancel, { once: true })
        const r = await startConditionalLogin(apiFetch, ctl.signal)
        if (r.status === 'ok' && r.response?.sid) {
          afterAuthed(r.response.sid)
        }
        // any other status: silently fall through to the email form
      }

      const openLoginDialog = (next) => {
        const d = dlg()
        if (!d) return
        if (document.documentElement.dataset.auth === 'user') return // never show to authed users
        if (d.open) return
        dlgState.next = typeof next === 'string' ? next : ''
        dlgReset()
        if (typeof d.showModal === 'function') d.showModal()
        else d.setAttribute('open', '')
        // Auto-attempt passkey-first. Promise resolves silently when OS prompt
        // is denied; user then sees the email form already visible behind it.
        void tryPasskeyFirst()
      }

      // --- document-level delegation (attached ONCE) -------------------------
      // Survives every ClientRouter body swap because document is the host.
      const readTheme = () => {
        try {
          const v = localStorage.getItem('pyaserv.theme')
          return isTheme(v) ? v : 'auto'
        } catch { return 'auto' }
      }
      const writeTheme = (v) => {
        try { localStorage.setItem('pyaserv.theme', v) } catch {}
        document.documentElement.dataset.theme = v
      }

      document.addEventListener('click', async (e) => {
        const tEl = e.target instanceof Element ? e.target : null
        if (!tEl) return
        // Theme cycle (matches both topbar button and flying-menu duplicate)
        const themeBtn = tEl.closest('.ps-theme-btn, #theme-btn')
        if (themeBtn) {
          const cur = readTheme()
          writeTheme(cur === 'light' ? 'dark' : cur === 'dark' ? 'auto' : 'light')
          return
        }
        // Language switch
        const langBtn = tEl.closest('.ps-lang-btn')
        if (langBtn) {
          const want = langBtn.dataset.lang
          if (isLoc(want) && want !== getLocale()) setLocale(want)
          return
        }
        // Open login dialog (Sign in button)
        const openLogin = tEl.closest('[data-open-login]')
        if (openLogin) {
          e.preventDefault()
          const fly = document.querySelector('flying-menu')
          if (fly && typeof fly.closeMenu === 'function') fly.closeMenu()
          openLoginDialog()
          return
        }
        // Sign out
        const logoutBtn = tEl.closest('[data-nav-logout]')
        if (logoutBtn) {
          e.preventDefault()
          clearToken()
          document.documentElement.dataset.auth = 'guest'
          location.href = '/'
          return
        }
        // Enroll toast accept / skip / close (S32)
        if (tEl.closest('#enroll-toast-accept')) {
          e.preventDefault()
          const clk = { now: () => Date.now() }
          hideEnrollToast()
          const r = await enrollPasskey(apiFetch)
          if (r === 'ok') muteForeverAfterEnroll(localStorage, clk)
          else dismissPromptForCooldown(localStorage, clk)
          return
        }
        if (tEl.closest('#enroll-toast-skip') || tEl.closest('#enroll-toast-close')) {
          e.preventDefault()
          dismissPromptForCooldown(localStorage, { now: () => Date.now() })
          hideEnrollToast()
          return
        }
        if (tEl.closest('#dlg-back')) {
          e.preventDefault()
          dlgHide('dlg-verify')
          dlgShow('dlg-start')
          dlgMsg('')
          return
        }
        // Tapping a flying-menu nav link → close the menu (Astro then navigates)
        const flyLink = tEl.closest('.ps-fly__menu a')
        if (flyLink) {
          const fly = document.querySelector('flying-menu')
          if (fly && typeof fly.closeMenu === 'function') fly.closeMenu()
        }
      })

      // ====== Dialog form submits ===================================================
      // Delegated to document so a single bind survives dialog re-creation.
      // Capture phase so we beat Astro ClientRouter's form-navigation intercept
      // (which otherwise navigates the page and closes the dialog mid-submit).
      document.addEventListener('submit', async (e) => {
        const f = e.target instanceof HTMLFormElement ? e.target : null
        if (!f) return
        if (f.id !== 'dlg-start' && f.id !== 'dlg-verify') return

        // Sign-in email step
        if (f.id === 'dlg-start') {
          e.preventDefault()
          e.stopImmediatePropagation()
          dlgMsg(t('common.sending'))
          dlgState.email = new FormData(f).get('email')
          let data
          try {
            data = await apiFetch('/api/auth/start', {
              method: 'POST',
              body: JSON.stringify({ email: dlgState.email, channel: 'otp', locale: getLocale() }),
            })
          } catch (err) {
            dlgMsg(`<span class="ps-error">${err.message || t('error.network')}</span>`)
            return
          }
          // Passkey-first: if the email has a registered key, fire the OS picker.
          if (data?.method === 'passkey' && data.options) {
            const r = await assertPasskey(apiFetch, dlgState.email, data.options)
            if (r.status === 'ok' && r.response?.sid) {
              afterAuthed(r.response.sid, r.response.redirect)
              return
            }
            // User cancelled → re-call /start with force:'otp' to get a code.
            try {
              await apiFetch('/api/auth/start', {
                method: 'POST',
                body: JSON.stringify({ email: dlgState.email, channel: 'otp', locale: getLocale(), force: 'otp' }),
              })
            } catch (err) {
              dlgMsg(`<span class="ps-error">${err.message || t('error.network')}</span>`)
              return
            }
          }
          dlgHide('dlg-start')
          dlgShow('dlg-verify')
          dlgMsg(`<span class="ps-msg--ok">${t('login.sent_ok')}</span>`)
          return
        }

        // Sign-in OTP step
        if (f.id === 'dlg-verify') {
          e.preventDefault()
          e.stopImmediatePropagation()
          dlgMsg(t('common.verifying'))
          const code = new FormData(f).get('code')
          let data
          try {
            data = await apiFetch('/api/auth/otp/verify', {
              method: 'POST',
              body: JSON.stringify({ email: dlgState.email, code }),
            })
          } catch (err) {
            dlgMsg(`<span class="ps-error">${err.message || t('error.network')}</span>`)
            return
          }
          if (!data?.sid) {
            dlgMsg(`<span class="ps-error">${t('error.network')}</span>`)
            return
          }
          setToken(data.sid)
          document.documentElement.dataset.auth = 'user'
          // S32: close the dialog IMMEDIATELY on success. The enroll prompt
          // (if eligible) surfaces as a non-modal toast — authed users must
          // never see the login dialog.
          closeDialog(data.redirect || dlgState.next || '')
          if (data.hasPasskey === false) void maybeShowEnrollToast()
        }
      }, true) // capture phase — runs before ClientRouter's bubble-phase intercept

      // ====== Enroll toast (S32) ====================================================
      const maybeShowEnrollToast = async () => {
        if (!passkeySupported()) return
        const clk = { now: () => Date.now() }
        if (isPromptOnCooldown(localStorage, clk)) return
        if (!(await platformAuthenticatorAvailable())) return
        const toast = document.getElementById('enroll-toast')
        if (!toast) return
        const platform = guessPlatform(navigator.userAgent)
        const es = document.getElementById('enroll-toast-method-es')
        const en = document.getElementById('enroll-toast-method-en')
        if (es) es.textContent = authenticatorLabel(platform, 'es')
        if (en) en.textContent = authenticatorLabel(platform, 'en')
        toast.hidden = false
        // Auto-dismiss after 15s as a soft cooldown (no penalty, just clear UI).
        setTimeout(() => { if (!toast.hidden) toast.hidden = true }, 15000)
      }
      const hideEnrollToast = () => {
        const toast = document.getElementById('enroll-toast')
        if (toast) toast.hidden = true
      }

      // --- run on first load AND every ClientRouter swap --------------------
      initPage()
      document.addEventListener('astro:after-swap', initPage)
    </script>
    <script>
      // @ts-nocheck
      // Service-worker registration with forced rollover on new deploys.
      // Logic in features/sw-update/register-sw.ts (testable, IO injected).
      // Skipped on localhost so dev iterates without cache surprises.
      import { setupSwUpdate } from '../features/sw-update/register-sw.ts'
      if ('serviceWorker' in navigator && location.hostname !== 'localhost' && location.hostname !== '127.0.0.1') {
        setupSwUpdate(
          {
            hasController: () => !!navigator.serviceWorker.controller,
            register: () => navigator.serviceWorker.register('/sw.js'),
            onControllerChange: (h) =>
              navigator.serviceWorker.addEventListener('controllerchange', h),
          },
          { reload: () => location.reload() },
        )
      }
    </script>
  </body>
</html>
