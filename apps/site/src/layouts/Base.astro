---
import '~/styles/global.css'

interface Props {
  readonly title: string
  readonly description?: string
  readonly active?: 'home' | 'specialists' | 'clients' | 'me' | 'login'
}

const { title, description, active = 'home' } = Astro.props
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const href = (path: string): string => `${base}${path}`
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · PyaServ</title>
    {description !== undefined && <meta name="description" content={description} />}
    <meta name="theme-color" content="#0e7490" />
    <link rel="icon" type="image/svg+xml" href={href('/favicon.svg')} />
  </head>
  <body>
    <header class="ps-topbar">
      <a href={href('/')} class="ps-topbar__brand">
        <span class="ps-topbar__brand-em">Pya</span>Serv
      </a>
      <nav class="ps-topbar__nav" aria-label="Principal">
        <a href={href('/specialists/')} aria-current={active === 'specialists' ? 'page' : undefined}>Profesionales</a>
        <a href={href('/clients/')} aria-current={active === 'clients' ? 'page' : undefined}>Pedidos</a>
        <a href={href('/me/')} aria-current={active === 'me' ? 'page' : undefined} data-nav-me>Mi panel</a>
        <a href={href('/login/')} aria-current={active === 'login' ? 'page' : undefined} data-nav-login>Ingresar</a>
      </nav>
    </header>
    <main class="ps-shell">
      <slot />
    </main>
    <footer class="ps-foot">
      © PyaServ · <a href={href('/')}>hermano de PyaEats</a> · construido sobre pya-platform
    </footer>
    <script>
      // Hide "Ingresar" if token is present; otherwise hide "Mi panel".
      ;(() => {
        const token = sessionStorage.getItem('pyaserv.token')
        const me = document.querySelector('[data-nav-me]')
        const login = document.querySelector('[data-nav-login]')
        if (token) { login?.classList.add('ps-hidden') }
        else { me?.classList.add('ps-hidden') }
      })()
    </script>
  </body>
</html>
