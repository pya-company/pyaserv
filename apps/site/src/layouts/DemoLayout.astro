---
/*
 * Demo Mode wrapper. Adds the Safety Charter:
 *   • orange sticky banner with "Salir" button
 *   • html[data-demo-mode="1"] for CSS-driven tint/border/watermark
 *   • exit confirmation modal
 *   • idle-watcher (10 min → auto-exit)
 *
 * Every /demo/* page should use this layout (NOT Base). Real auth chrome
 * is hidden — the page renders as if logged-out, matching mech 6.
 */
import '~/styles/global.css'
import '~/styles/demo-and-docs.css'
import { ClientRouter } from 'astro:transitions'

interface Props {
  readonly title: string
  readonly feature: string  // 'profile' | 'tour' | 'badges' | 'quote' | 'analytics' | 'cards'
}

const { title, feature } = Astro.props
---
<html lang="es" data-demo-mode="1" data-demo-feature={feature}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Demo: {title} · PyaServ</title>
    <meta name="robots" content="noindex,nofollow" />
    <meta name="theme-color" content="#f59e0b" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
  </head>
  <body>
    <div class="ps-demo-banner" role="banner" aria-live="polite">
      <div class="ps-demo-banner__msg">
        <span class="ps-demo-banner__icon" aria-hidden="true">⚠</span>
        <span class="ps-demo-banner__text">
          MODO DEMO — los cambios no se guardan · estás probando la feature <strong>{title}</strong>
        </span>
      </div>
      <button type="button" class="ps-demo-banner__exit" data-demo-exit>Salir</button>
    </div>

    <main id="main-content" class="ps-shell" style="padding-top: 16px;">
      <slot />
    </main>

    <div class="ps-demo-modal" id="demo-exit-modal" hidden role="dialog" aria-modal="true" aria-labelledby="demo-exit-title">
      <div class="ps-demo-modal__panel">
        <h2 id="demo-exit-title" class="ps-demo-modal__title">Volver al sitio</h2>
        <p class="ps-demo-modal__body">
          Nada de lo que probaste en el modo demo se guarda. Tu perfil real (si tenés uno) sigue exactamente como lo dejaste.
        </p>
        <div class="ps-demo-modal__actions">
          <button type="button" class="ps-demo-modal__btn ps-demo-modal__btn--primary" data-demo-exit-confirm>Sí, salir del demo</button>
          <button type="button" class="ps-demo-modal__btn ps-demo-modal__btn--ghost" data-demo-exit-cancel>Seguir en demo</button>
        </div>
      </div>
    </div>

    <script define:vars={{ feature }}>
      // Demo Mode runtime: idle watcher + exit modal wiring.
      // Pure DOM script, no module import needed beyond what the layout pulls.

      const showModal = () => {
        const m = document.getElementById('demo-exit-modal')
        if (m) m.hidden = false
      }
      const hideModal = () => {
        const m = document.getElementById('demo-exit-modal')
        if (m) m.hidden = true
      }
      const goHome = () => {
        sessionStorage.removeItem('pyaserv.demo.' + feature)
        location.href = '/docs/'
      }

      // Banner exit → modal
      document.addEventListener('click', (e) => {
        const t = e.target instanceof Element ? e.target : null
        if (!t) return
        if (t.closest('[data-demo-exit]')) {
          e.preventDefault()
          showModal()
          return
        }
        if (t.closest('[data-demo-exit-confirm]')) {
          e.preventDefault()
          goHome()
          return
        }
        if (t.closest('[data-demo-exit-cancel]')) {
          e.preventDefault()
          hideModal()
          return
        }
      })

      // Idle watcher: 10 min of no input → trigger exit modal (auto-clears at 30s)
      const IDLE = 10 * 60 * 1000
      let timer = null
      const reset = () => {
        if (timer) clearTimeout(timer)
        timer = setTimeout(() => {
          showModal()
          // Auto-exit 30s after the modal appears
          setTimeout(goHome, 30 * 1000)
        }, IDLE)
      }
      ;['click', 'keydown', 'pointermove', 'touchstart', 'scroll'].forEach((ev) =>
        document.addEventListener(ev, reset, { passive: true })
      )
      reset()

      // Audit beacon — fire-and-forget
      try {
        const blob = new Blob([JSON.stringify({ event: 'demo.started', feature, at: Date.now() })], { type: 'application/json' })
        navigator.sendBeacon?.('/api/demo-audit', blob)
      } catch {}
    </script>
  </body>
</html>
