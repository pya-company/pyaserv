---
import { TOC } from '~/data/docs-toc.ts'
import { getDocContent } from '~/lib/content.ts'
import { tFor, LOCALES, type Locale } from '~/lib/i18n.ts'
import { getAllLocales } from '~/lib/l10n-emit.ts'

interface Props { currentSlug?: string }
const { currentSlug } = Astro.props
const loc: Locale = 'es'
const VISIBLE_LOCS = LOCALES.filter((l) => l !== 'gn')

const statusLabelMap = (status: string): Record<string, string> => {
  const out: Record<string, string> = {}
  for (const l of VISIBLE_LOCS) out[l] = tFor(l, `docs.status_${status === 'live' ? 'live' : status === 'demo' ? 'demo' : 'soon'}`)
  return out
}
const groupLabelMap = (key: string): Record<string, string> => {
  const out: Record<string, string> = {}
  for (const l of VISIBLE_LOCS) out[l] = tFor(l, key)
  return out
}
const escapeAttr = (s: string): string =>
  s.replace(/&/g, '&amp;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
const l10n = (m: Record<string, string>): string => `data-l10n-text='${escapeAttr(JSON.stringify(m))}'`
---
<details class="docs-sidebar" aria-label={tFor(loc, 'docs.sidebar_aria')}>
  <summary>{tFor(loc, 'docs.sidebar_aria')}</summary>
  {TOC.map((entry) => (
    <div class="docs-sidebar__group">
      <Fragment set:html={`<h3 class="docs-sidebar__group-title" ${l10n(groupLabelMap(entry.group.i18nKey))}>${tFor(loc, entry.group.i18nKey)}</h3>`} />
      <ul class="docs-sidebar__list">
        {entry.pages.map((page) => {
          const content = getDocContent(loc, page.slug)
          const title = content?.title ?? page.slug
          const isActive = currentSlug === page.slug
          const titleMap = getAllLocales('docs', page.slug, ['title'])
          const statusLabel = tFor(loc, `docs.status_${page.status}`)
          return (
            <li class="docs-sidebar__item">
              <a href={`/docs/${page.slug}/`} aria-current={isActive ? 'page' : undefined}>
                <Fragment set:html={`<span ${l10n(titleMap)}>${title}</span>`} />
                <span class="docs-sidebar__code">{page.code}</span>
                <Fragment set:html={`<span class="docs-sidebar__status" data-status="${page.status}" ${l10n(statusLabelMap(page.status))}>${statusLabel}</span>`} />
              </a>
            </li>
          )
        })}
      </ul>
    </div>
  ))}
</details>
<script is:inline>
  // Force the <details class="docs-sidebar"> open on desktop (≥821px) so the
  // mobile drawer affordance does not hide nav on wider viewports. Re-check
  // on resize so dragging the window across the breakpoint stays correct.
  (function () {
    const apply = function () {
      const s = document.querySelector('details.docs-sidebar')
      if (!s) return
      if (window.matchMedia('(min-width: 821px)').matches) s.setAttribute('open', '')
    }
    apply()
    window.addEventListener('resize', apply)
    document.addEventListener('astro:page-load', apply)
  })()
</script>
