---
import DemoLayout from '~/layouts/DemoLayout.astro'
---
<DemoLayout title="Onboarding Tour" feature="tour">
  <div style="max-width:600px;margin:0 auto;padding:0 16px;">
    <h1 style="font-size:24px;margin:0 0 12px 0;">Demo del Onboarding Tour</h1>
    <p style="color:#6b7280;margin:0 0 24px 0;">
      Cuando un profesional se registra por primera vez, este tour de 7 pasos lo lleva por el armado del perfil. Tocá <strong>"Lanzar tour"</strong> para verlo en acción.
    </p>

    <button type="button" id="launch-tour" style="background:#4f46e5;color:white;padding:12px 24px;border-radius:8px;border:none;font-weight:600;cursor:pointer;font-size:15px;">
      Lanzar tour
    </button>

    <div style="margin-top:32px;background:white;border:1px solid #e5e7eb;border-radius:12px;padding:20px;">
      <h2 style="font-size:14px;text-transform:uppercase;color:#6b7280;margin:0 0 12px 0;letter-spacing:0.05em;">Formulario de perfil (anclado)</h2>

      <label style="display:block;margin-bottom:12px;">
        <span style="display:block;font-weight:600;margin-bottom:4px;">Foto de perfil</span>
        <div id="avatar-upload" style="width:80px;height:80px;background:#fbbf24;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#92400e;font-weight:700;font-size:24px;">JP</div>
      </label>

      <label style="display:block;margin-bottom:12px;">
        <span style="display:block;font-weight:600;margin-bottom:4px;">Imagen de portada</span>
        <div id="cover-image" style="height:80px;background:linear-gradient(135deg,#4f46e5,#818cf8);border-radius:8px;"></div>
      </label>

      <label style="display:block;margin-bottom:12px;">
        <span style="display:block;font-weight:600;margin-bottom:4px;">Bio</span>
        <textarea id="bio-textarea" rows="3" placeholder="Plomero matriculado…" style="width:100%;padding:8px;border:1px solid #e5e7eb;border-radius:6px;font-family:inherit;"></textarea>
      </label>

      <div style="display:flex;gap:8px;margin-bottom:12px;">
        <button type="button" id="services-add" style="background:#4f46e5;color:white;padding:6px 12px;border-radius:6px;border:none;font-size:14px;">+ Servicio</button>
      </div>

      <label style="display:block;margin-bottom:12px;">
        <span style="display:block;font-weight:600;margin-bottom:4px;">Zona</span>
        <div id="service-area-selector" style="border:1px solid #e5e7eb;padding:8px;border-radius:6px;color:#9ca3af;">Tocá para elegir hasta 8 barrios</div>
      </label>

      <label style="display:block;margin-bottom:12px;">
        <span style="display:block;font-weight:600;margin-bottom:4px;">Horario</span>
        <div id="schedule-editor" style="border:1px solid #e5e7eb;padding:8px;border-radius:6px;color:#9ca3af;">Configurar horario</div>
      </label>

      <div id="completeness-bar" style="margin-top:16px;background:#f9fafb;padding:12px;border-radius:8px;">
        <div style="display:flex;justify-content:space-between;margin-bottom:6px;font-size:13px;">
          <span style="font-weight:600;">Perfil completo</span>
          <span style="color:#4f46e5;font-weight:700;">20%</span>
        </div>
        <div style="background:#e5e7eb;border-radius:999px;height:6px;overflow:hidden;">
          <div style="width:20%;height:100%;background:linear-gradient(90deg,#4f46e5,#818cf8);"></div>
        </div>
      </div>
    </div>

    <section style="margin-top:32px;text-align:center;">
      <a href="/docs/" style="color:#6b7280;font-size:14px;">← Volver a la lista de features</a>
    </section>
  </div>

  <script>
    // Dynamically import driver.js on click to keep initial load lean.
    const btn = document.getElementById('launch-tour')
    if (btn) {
      btn.addEventListener('click', async () => {
        const mod = await import('driver.js')
        await import('driver.js/dist/driver.css')
        const driver = mod.driver({
          showProgress: true,
          progressText: 'Paso {{current}} de {{total}}',
          nextBtnText: 'Siguiente',
          prevBtnText: 'Atrás',
          doneBtnText: '¡Listo!',
          steps: [
            {
              element: '#avatar-upload',
              popover: {
                title: 'Empezamos por tu cara',
                description: 'Una buena foto duplica las consultas. Sacate una con luz natural.',
              },
            },
            {
              element: '#cover-image',
              popover: {
                title: 'Imagen de portada',
                description: 'Lo primero que ven los clientes. Una foto de tu trabajo o algo del rubro.',
              },
            },
            {
              element: '#bio-textarea',
              popover: {
                title: 'Contales quién sos',
                description: '2-3 frases. Tu experiencia, herramientas, qué zonas cubrís.',
              },
            },
            {
              element: '#services-add',
              popover: {
                title: '¿Qué servicios ofrecés?',
                description: 'Al menos dos, con precio aproximado. Los clientes odian "consultar por privado".',
              },
            },
            {
              element: '#service-area-selector',
              popover: {
                title: 'Tu zona de trabajo',
                description: 'Elegí hasta 8 barrios. Los más cercanos primero.',
              },
            },
            {
              element: '#schedule-editor',
              popover: {
                title: 'Tu horario',
                description: 'Cuándo respondés. Fuera de eso los clientes ven que estás cerrado y no se enojan.',
              },
            },
            {
              element: '#completeness-bar',
              popover: {
                title: '¡Listo!',
                description: 'Tu perfil sube cada vez que completás un paso. ¡A 100% desbloqueás 7 días de Boost gratis y la insignia Perfil Maestro!',
              },
            },
          ],
        })
        driver.drive()
      })
    }
  </script>
</DemoLayout>
