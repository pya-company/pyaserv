---
import Base from '~/layouts/Base.astro'
import BarriosDatalist from '~/components/BarriosDatalist.astro'
import T from '~/components/T.astro'
import { tFor, formatGs as formatGsFor } from '~/lib/i18n.ts'
import { CATEGORIES } from '~/lib/api.ts'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

// Build-time fetch of the initial (unfiltered) requests list. Same approach
// as specialists.astro — SSR the cards into the HTML so users see real
// requests at FCP. Filter input still triggers client-side re-fetch.
const API = (typeof import.meta.env.PUBLIC_API_URL === 'string' && import.meta.env.PUBLIC_API_URL) ||
  'https://api.pyaserv.com'

interface ClientRequest {
  readonly id: string
  readonly category: string
  readonly title: string
  readonly description: string
  readonly titleEs: string
  readonly titleEn: string
  readonly descriptionEs: string
  readonly descriptionEn: string
  readonly budgetGs: number
  readonly barrio: string
  readonly createdAt: number
}

const fetchRequests = async (): Promise<ReadonlyArray<ClientRequest>> => {
  try {
    const r = await fetch(`${API}/v1/requests`)
    if (!r.ok) return []
    const body = await r.json() as { data?: ReadonlyArray<ClientRequest> }
    return body.data ?? []
  } catch { return [] }
}

const items = await fetchRequests()
const categoryEmoji = (value: string): string =>
  CATEGORIES.find((c) => c.value === value)?.emoji ?? '•'

const countOneEs = tFor('es', 'clients.count.one')
const countManyEs = tFor('es', 'clients.count.many')
const countOneEn = tFor('en', 'clients.count.one')
const countManyEn = tFor('en', 'clients.count.many')
const ctaEs = tFor('es', 'clients.card.cta')
const ctaEn = tFor('en', 'clients.card.cta')

// Relative time — render BOTH locales server-side. Reuses i18n locale-aware formatter.
const relativeFor = (ts: number, loc: 'es' | 'en'): string => {
  const seconds = Math.floor(Date.now() / 1000) - ts
  const minutes = Math.floor(seconds / 60)
  const hours = Math.floor(minutes / 60)
  const days = Math.floor(hours / 24)
  if (loc === 'es') {
    if (seconds < 60) return 'hace un momento'
    if (minutes < 60) return `hace ${minutes} min`
    if (hours < 24) return `hace ${hours} h`
    if (days < 30) return `hace ${days} d`
    return `hace ${Math.floor(days / 30)} m`
  }
  if (seconds < 60) return 'just now'
  if (minutes < 60) return `${minutes} min ago`
  if (hours < 24) return `${hours} h ago`
  if (days < 30) return `${days} d ago`
  return `${Math.floor(days / 30)} mo ago`
}

const formatGs = (n: number): string => `Gs ${n.toLocaleString('es-PY')}`
const truncate = (s: string, n = 220): string => s.length > n ? `${s.slice(0, n)}…` : s
---
<Base
  title="Pedidos"
  description="Pedidos de clientes en Asunción. Si ofrecés el servicio que buscan, escribiles directo."
  titleKey="clients.title"
  descriptionKey="clients.description"
  active="clients"
>
  <section class="ps-section" data-base={base}>
    <div class="ps-page-head">
      <T k="clients.heading" as="h1" />
      <T k="clients.intro" as="p" />
    </div>

    <form id="filters" class="ps-filters" autocomplete="off">
      <label>
        <T k="specialists.filter.category" as="span" />
        <select name="category" id="f-category" aria-label="Categoría">
          <option value="" data-i18n="specialists.filter.category.all">Todas</option>
        </select>
      </label>
      <label>
        <T k="specialists.filter.barrio" as="span" />
        <input type="text" name="barrio" id="f-barrio" list="ps-barrios" data-i18n-placeholder="specialists.filter.barrio.placeholder" placeholder="Villa Morra, Carmelitas…" />
      </label>
    </form>

    <p id="status" class="ps-msg" aria-live="polite">
      <span lang="es">{items.length} {items.length === 1 ? countOneEs : countManyEs}</span>
      <span lang="en">{items.length} {items.length === 1 ? countOneEn : countManyEn}</span>
    </p>
    <div id="results" class="ps-cards">
      {items.map((r) => {
        const catLabelEs = tFor('es', `category.${r.category}`)
        const catLabelEn = tFor('en', `category.${r.category}`)
        return (
          <a class="ps-card ps-card--request" href={`${base}/clients/${r.id}/`}>
            <div class="ps-row">
              <span class="ps-chip">
                {categoryEmoji(r.category)}
                {' '}
                <span lang="es">{catLabelEs}</span>
                <span lang="en">{catLabelEn}</span>
              </span>
              <span class="ps-card__sub">
                <span lang="es">{relativeFor(r.createdAt, 'es')}</span>
                <span lang="en">{relativeFor(r.createdAt, 'en')}</span>
              </span>
            </div>
            <h2>
              <span lang="es">{r.titleEs}</span>
              <span lang="en">{r.titleEn}</span>
            </h2>
            <p class="ps-card__sub">📍 {r.barrio} · 💰 {formatGs(r.budgetGs)}</p>
            <p class="ps-card__body">
              <span lang="es">{truncate(r.descriptionEs)}</span>
              <span lang="en">{truncate(r.descriptionEn)}</span>
            </p>
            <div class="ps-card__cta">
              <span lang="es">{ctaEs}</span>
              <span lang="en">{ctaEn}</span>
            </div>
          </a>
        )
      })}
    </div>
  </section>

  <BarriosDatalist />

  <script>
    // @ts-nocheck
    import { apiFetch, CATEGORIES, categoryLabel, categoryEmoji, formatGs, formatRelativeTime } from '../lib/api.ts'
    import { t } from '../lib/i18n.ts'

    const sec = document.querySelector('.ps-section')
    const base = sec.dataset.base ?? ''
    const catSel = document.getElementById('f-category')
    for (const c of CATEGORIES) {
      const opt = document.createElement('option')
      opt.value = c.value
      opt.textContent = `${c.emoji} ${categoryLabel(c.value)}`
      catSel.append(opt)
    }

    const results = document.getElementById('results')
    const status = document.getElementById('status')
    const form = document.getElementById('filters')

    const escape = (s) => String(s).replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]))

    const render = (items) => {
      results.removeAttribute('aria-busy')
      if (items.length === 0) {
        results.innerHTML = ''
        status.innerHTML = `<span class="ps-empty"><span class="ps-empty__icon">📭</span><strong class="ps-empty__title">${t('clients.empty.title')}</strong><span class="ps-empty__hint">${t('clients.empty.hint')}</span></span>`
        return
      }
      status.textContent = `${items.length} ${items.length === 1 ? t('clients.count.one') : t('clients.count.many')}`
      const cta = t('clients.card.cta')
      results.innerHTML = items.map((r) => `
        <a class="ps-card ps-card--request" href="${base}/clients/${escape(r.id)}/">
          <div class="ps-row">
            <span class="ps-chip">${categoryEmoji(r.category)} ${categoryLabel(r.category)}</span>
            <span class="ps-card__sub">${formatRelativeTime(r.createdAt)}</span>
          </div>
          <h2>${escape(r.title)}</h2>
          <p class="ps-card__sub">📍 ${escape(r.barrio)} · 💰 ${escape(formatGs(r.budgetGs))}</p>
          <p class="ps-card__body">${escape(r.description.slice(0, 220))}${r.description.length > 220 ? '…' : ''}</p>
          <div class="ps-card__cta"><span>${cta}</span></div>
        </a>`).join('')
    }

    const load = async () => {
      const fd = new FormData(form)
      const params = new URLSearchParams()
      if (fd.get('category')) params.set('category', fd.get('category'))
      if (fd.get('barrio')) params.set('barrio', fd.get('barrio'))
      status.textContent = t('common.loading')
      results.setAttribute('aria-busy', 'true')
      results.innerHTML = ''
      try {
        const data = await apiFetch(`/v1/requests?${params.toString()}`)
        render(data)
      } catch (err) {
        results.removeAttribute('aria-busy')
        status.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>`
      }
    }

    form.addEventListener('input', load)
    form.addEventListener('submit', (e) => { e.preventDefault(); load() })
    // NOTE: no initial load() — cards are SSR'd inline. Filter input still triggers it.
  </script>
</Base>
