---
import Base from '~/layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base
  title="Pedidos"
  description="Pedidos de clientes en Asunción. Si ofrecés el servicio que buscan, escribiles directo."
  active="clients"
>
  <section class="ps-section">
    <h1>Pedidos abiertos</h1>
    <p>Lista de clientes que están buscando un profesional. Para responder, iniciá sesión y abrí una conversación.</p>

    <form id="filters" class="ps-filters" autocomplete="off">
      <label>
        Categoría
        <select name="category" id="f-category">
          <option value="">Todas</option>
        </select>
      </label>
      <label>
        Barrio
        <input type="text" name="barrio" id="f-barrio" placeholder="Villa Morra, Carmelitas…" />
      </label>
    </form>

    <div id="results" class="ps-cards" aria-busy="true" data-base={base}>Cargando…</div>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, CATEGORIES, categoryLabel } from '../lib/api.ts'

    const cats = document.getElementById('f-category')
    for (const c of CATEGORIES) {
      const opt = document.createElement('option')
      opt.value = c.value
      opt.textContent = c.label
      cats.append(opt)
    }

    const results = document.getElementById('results')
    const base = results.dataset.base ?? ''
    const form = document.getElementById('filters')

    const formatBudget = (gs) => {
      if (gs === null || gs === undefined) return 'A coordinar'
      return new Intl.NumberFormat('es-PY', { maximumFractionDigits: 0 }).format(gs) + ' Gs'
    }

    const render = (items) => {
      results.removeAttribute('aria-busy')
      if (items.length === 0) {
        results.innerHTML = '<p class="ps-empty">No hay pedidos abiertos con ese filtro.</p>'
        return
      }
      results.innerHTML = items
        .map(
          (r) => `
          <article class="ps-card">
            <header>
              <h2>${r.title}</h2>
              <p class="ps-card__sub">${categoryLabel(r.category)} · ${r.barrio} · ${formatBudget(r.budgetGs)}</p>
            </header>
            <p>${r.description.length > 240 ? r.description.slice(0, 240) + '…' : r.description}</p>
            <p class="ps-card__cta"><a href="${base}/me/?reply=${r.id}&type=request">Responder →</a></p>
          </article>`,
        )
        .join('')
    }

    const load = async () => {
      const fd = new FormData(form)
      const params = new URLSearchParams()
      if (fd.get('category')) params.set('category', fd.get('category'))
      if (fd.get('barrio')) params.set('barrio', fd.get('barrio'))
      results.setAttribute('aria-busy', 'true')
      results.textContent = 'Cargando…'
      try {
        const data = await apiFetch(`/v1/requests?${params.toString()}`)
        render(data)
      } catch (err) {
        results.removeAttribute('aria-busy')
        results.innerHTML = `<p class="ps-error">${err.message}</p>`
      }
    }

    form.addEventListener('input', load)
    form.addEventListener('submit', (e) => {
      e.preventDefault()
      load()
    })
    load()
  </script>
</Base>
