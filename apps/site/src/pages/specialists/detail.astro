---
import Base from '../../layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Perfil" titleKey="specialist.detail.title" active="specialists">
  <section class="ps-section" data-base={base}>
    <p id="status" class="ps-msg" aria-live="polite" data-i18n="common.loading">Cargando…</p>
    <div id="profile" class="ps-detail ps-hidden">
      <aside class="ps-detail__side">
        <div class="ps-detail__avatar" id="avatar">🛠️</div>
        <h1 class="ps-detail__name" id="name">—</h1>
        <p class="ps-detail__meta" id="meta">—</p>
        <div id="badge-row" class="ps-row" style="justify-content:center"></div>
        <div id="contact" class="ps-detail__contact ps-stack ps-hidden">
          <a id="phone-link" href="#">📞 <span id="phone-text">—</span></a>
          <a id="whatsapp-link" href="#" target="_blank" rel="noopener" class="ps-hidden">💬 WhatsApp</a>
        </div>
        <p id="contact-locked" class="ps-banner ps-banner--warn">
          <span data-i18n="specialist.detail.locked">Para ver el contacto,</span>
          <a id="login-link" data-i18n="specialist.detail.locked.cta">iniciá sesión</a>.
        </p>
        <button id="contact-btn" class="ps-btn ps-hidden" data-i18n="specialist.detail.contact_btn">Enviar mensaje</button>
      </aside>

      <div class="ps-detail__body">
        <article class="ps-detail__bio" id="bio">—</article>

        <section id="reviews-block" class="ps-stack ps-stack--gap-4" aria-labelledby="reviews-h">
          <h2 id="reviews-h" data-i18n="reviews.h">Reseñas</h2>
          <p id="reviews-summary" class="ps-card__sub" aria-live="polite"></p>
          <div id="reviews-list" class="ps-stack"></div>
        </section>

        <h2 data-i18n="specialist.detail.services_h">Servicios que ofrece</h2>
        <div id="listings" class="ps-cards"></div>
      </div>
    </div>

    <div id="composer" class="ps-banner ps-hidden">
      <h2 data-i18n="specialist.detail.compose_h">Escribirle</h2>
      <form id="composer-form" class="ps-form">
        <label>
          <span data-i18n="specialist.detail.compose.label">Mensaje</span>
          <textarea name="body" required minlength="1" maxlength="2000" data-i18n-placeholder="specialist.detail.compose.placeholder" placeholder="Hola, me interesa…"></textarea>
        </label>
        <div class="ps-row">
          <button type="submit" class="ps-btn" data-i18n="common.send">Enviar</button>
          <button type="button" id="composer-cancel" class="ps-btn ps-btn--ghost" data-i18n="common.cancel">Cancelar</button>
        </div>
        <p id="composer-msg" class="ps-msg" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, categoryLabel, categoryEmoji, formatGs, formatRelativeTime } from '../../lib/api.ts'
    import { t } from '../../lib/i18n.ts'

    ;(async () => {
      const base = document.querySelector('.ps-section').dataset.base ?? ''
      const id = new URLSearchParams(location.search).get('id')
      const status = document.getElementById('status')
      const profile = document.getElementById('profile')

      document.getElementById('login-link').href = `${base}/login/?next=${encodeURIComponent(location.pathname + location.search)}`

      if (!id) { status.innerHTML = `<span class="ps-error">${t('common.missing_id')}</span>`; return }

      const escape = (s) => String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]))

      let spec, listings, reviews
      try {
        spec = await apiFetch(`/v1/specialists/${id}`)
        listings = await apiFetch(`/v1/listings?specialist_id=${id}`)
        try { reviews = await apiFetch(`/v1/specialists/${id}/reviews`) }
        catch { reviews = { average: 0, count: 0, items: [] } }
      } catch (err) {
        status.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>`
        return
      }

      status.classList.add('ps-hidden')
      profile.classList.remove('ps-hidden')

      // Fire-and-forget profile_view event — backend dedupes self-views.
      try { apiFetch('/v1/analytics', { method: 'POST', body: JSON.stringify({ event: 'profile_view', subjectId: id }) }) } catch {}

      document.getElementById('name').textContent = spec.displayName
      document.getElementById('meta').textContent = `${spec.headline} · 📍 ${spec.barrio}`
      document.getElementById('bio').textContent = spec.bio || spec.headline
      const apiBase = (typeof import.meta.env.PUBLIC_API_URL === 'string' && import.meta.env.PUBLIC_API_URL) || 'https://api.pyaserv.com'
      if (spec.photo) {
        const av = document.getElementById('avatar')
        av.classList.add('ps-avatar--photo')
        av.innerHTML = `<img class="ps-avatar__img" src="${apiBase}/v1/media/${escape(spec.photo)}" alt="${escape(spec.displayName)}"/>`
      }

      if (spec.verified) {
        document.getElementById('badge-row').innerHTML = `<span class="ps-badge">${t('specialist.detail.verified')}</span>`
      }

      // Reviews
      const rSummary = document.getElementById('reviews-summary')
      const rList = document.getElementById('reviews-list')
      const renderStars = (n) => '★★★★★'.slice(0, Math.round(n)) + '☆☆☆☆☆'.slice(0, 5 - Math.round(n))
      if (reviews.count > 0) {
        const word = reviews.count === 1 ? t('reviews.avg_one') : t('reviews.avg_many')
        rSummary.innerHTML = `<span class="ps-stars-inline" aria-hidden="true">${renderStars(reviews.average)}</span> <strong>${reviews.average.toFixed(1)}</strong> · ${reviews.count} ${word}`
        rList.innerHTML = (reviews.items || []).map((r) => `
          <article class="ps-card">
            <div class="ps-row">
              <span class="ps-stars-inline" aria-label="${r.stars} ★">${renderStars(r.stars)}</span>
              <span class="ps-card__sub">${formatRelativeTime(r.createdAt)}</span>
            </div>
            ${r.body ? `<p class="ps-card__body">${escape(r.body)}</p>` : ''}
          </article>`).join('')
      } else {
        rSummary.textContent = t('reviews.empty')
      }

      const token = getToken()
      if (token) {
        document.getElementById('contact-locked').classList.add('ps-hidden')
        const contact = document.getElementById('contact')
        contact.classList.remove('ps-hidden')
        const phoneText = document.getElementById('phone-text')
        const phoneLink = document.getElementById('phone-link')
        phoneText.textContent = spec.phone
        phoneLink.href = `tel:${spec.phone.replace(/[^+0-9]/g, '')}`
        phoneLink.addEventListener('click', () => {
          try { apiFetch('/v1/analytics', { method: 'POST', body: JSON.stringify({ event: 'phone_click', subjectId: id }) }) } catch {}
        })
        if (spec.whatsapp) {
          const wa = document.getElementById('whatsapp-link')
          wa.href = `https://wa.me/${spec.whatsapp.replace(/[^0-9]/g, '')}`
          wa.classList.remove('ps-hidden')
          wa.addEventListener('click', () => {
            try { apiFetch('/v1/analytics', { method: 'POST', body: JSON.stringify({ event: 'whatsapp_click', subjectId: id }) }) } catch {}
          })
        }
        document.getElementById('contact-btn').classList.remove('ps-hidden')
      }

      const lEl = document.getElementById('listings')
      const noServicesTitle = t('specialist.detail.no_services.title')
      const priceFrom = t('specialist.detail.price_from')
      const perHour = t('specialist.detail.per_hour')
      const perJob = t('specialist.detail.per_job')
      const priceTbd = t('specialist.detail.price_tbd')
      lEl.innerHTML = listings.length === 0
        ? `<p class="ps-empty"><span class="ps-empty__icon">📦</span><strong class="ps-empty__title">${noServicesTitle}</strong></p>`
        : listings.map((l) => `
          <article class="ps-card" data-listing-id="${escape(l.id)}">
            <div class="ps-row">
              <span class="ps-chip">${categoryEmoji(l.category)} ${categoryLabel(l.category)}</span>
            </div>
            <h3>${escape(l.title)}</h3>
            <p class="ps-card__body">${escape(l.description)}</p>
            <p class="ps-card__sub">${l.priceFromGs ? `${priceFrom} ${escape(formatGs(l.priceFromGs))}${l.priceUnit ? ` / ${l.priceUnit === 'hour' ? perHour : perJob}` : ''}` : priceTbd}</p>
            ${token ? `<div class="ps-card__cta"><button type="button" class="ps-btn ps-btn--sm js-pick-listing" data-id="${escape(l.id)}" data-i18n="specialist.detail.ask_about">Consultar sobre este servicio</button></div>` : ''}
          </article>`).join('')

      // Remember which listing the user clicked so the composer creates the inquiry
      // against THAT listing, not always listings[0].
      let pickedListingId = listings[0]?.id ?? null
      for (const btn of lEl.querySelectorAll('.js-pick-listing')) {
        btn.addEventListener('click', () => {
          pickedListingId = btn.dataset.id
          composer.classList.remove('ps-hidden')
          composer.scrollIntoView({ behavior: 'smooth' })
        })
      }

      const composer = document.getElementById('composer')
      const composerForm = document.getElementById('composer-form')
      const composerMsg = document.getElementById('composer-msg')

      document.getElementById('contact-btn').addEventListener('click', () => {
        composer.classList.remove('ps-hidden')
        composer.scrollIntoView({ behavior: 'smooth' })
      })
      document.getElementById('composer-cancel').addEventListener('click', () => composer.classList.add('ps-hidden'))

      composerForm.addEventListener('submit', async (e) => {
        e.preventDefault()
        composerMsg.textContent = t('common.sending')
        const body = new FormData(composerForm).get('body')
        const subjectId = pickedListingId ?? listings[0]?.id
        if (!subjectId) {
          composerMsg.innerHTML = `<span class="ps-error">${t('specialist.detail.no_listings_err')}</span>`
          return
        }
        try {
          const inq = await apiFetch('/v1/inquiries', {
            method: 'POST',
            body: JSON.stringify({ subjectType: 'listing', subjectId, body }),
          })
          location.href = `${base}/me/inquiries/detail/?id=${inq.id}`
        } catch (err) {
          composerMsg.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>`
        }
      })
    })()
  </script>
</Base>
