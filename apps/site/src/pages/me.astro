---
import Base from '~/layouts/Base.astro'
import BarriosDatalist from '~/components/BarriosDatalist.astro'
import T from '~/components/T.astro'
import '~/styles/demo-and-docs.css'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Mi panel" titleKey="me.title" active="me">
  <section class="ps-section" data-base={base}>
    <div class="ps-row" style="justify-content:space-between">
      <T k="me.heading" as="h1" />
      <button id="logout" class="ps-btn ps-btn--ghost ps-btn--sm"><T k="me.logout" /></button>
    </div>
    <!-- Reserve one-line height so the tabs strip + form below don't jump
         down when JS later writes "Sesión: <userId>…" into this paragraph. -->
    <p id="me-info" class="ps-card__sub" style="min-height:1.25rem"></p>

    <!-- Gamification HUD: XP / streak / tier. Always reserved so /v1/me/game-state
         resolving doesn't shift the form below it (was a 0.13 CLS source). Cells
         start at placeholder values; JS only updates text content, no height swap. -->
    <div id="game-hud" class="ps-game-hud">
      <div class="ps-game-hud__cell">
        <div class="ps-game-hud__value" id="hud-xp">—</div>
        <div class="ps-game-hud__label">XP</div>
      </div>
      <div class="ps-game-hud__cell" id="hud-streak-cell">
        <div class="ps-game-hud__value" id="hud-streak">🔥 0 d</div>
        <div class="ps-game-hud__label">Racha</div>
      </div>
      <div class="ps-game-hud__cell">
        <div class="ps-game-hud__value" id="hud-tier">⚡ T0</div>
        <div class="ps-game-hud__label" id="hud-tier-name">Aprendiz</div>
      </div>
    </div>

    <div class="ps-tabs" role="tablist" data-i18n-aria="me.tabs.aria" aria-label="Secciones">
      <button class="ps-tab" role="tab" id="tab-profile" aria-controls="panel-profile" data-tab="profile"><T k="me.tabs.profile" /></button>
      <button class="ps-tab" role="tab" id="tab-listings" aria-controls="panel-listings" data-tab="listings"><T k="me.tabs.listings" /></button>
      <button class="ps-tab" role="tab" id="tab-quotes" aria-controls="panel-quotes" data-tab="quotes"><T k="me.tabs.quotes" /></button>
      <button class="ps-tab" role="tab" id="tab-clients" aria-controls="panel-clients" data-tab="clients"><T k="me.tabs.clients" /></button>
      <button class="ps-tab" role="tab" id="tab-game" aria-controls="panel-game" data-tab="game"><T k="me.tabs.game" /></button>
      <button class="ps-tab" role="tab" id="tab-requests" aria-controls="panel-requests" data-tab="requests"><T k="me.tabs.requests" /></button>
      <button class="ps-tab" role="tab" id="tab-inquiries" aria-controls="panel-inquiries" data-tab="inquiries"><T k="me.tabs.inquiries" /></button>
      <button class="ps-tab" role="tab" id="tab-stats" aria-controls="panel-stats" data-tab="stats"><T k="me.tabs.stats" /></button>
    </div>

    <!-- Visibility is driven by html[data-me-tab=<name>] from bootstrap.js
         (set pre-paint from ?tab=X). Each panel is rendered in SSR; CSS
         hides the non-active ones on the first frame — no JS-driven swap,
         no footer jump on deep-link reload. JS tab clicks update the
         attribute too; no need for the per-panel `hidden` attribute. -->
    <div class="ps-tabpanel" id="panel-profile" role="tabpanel" aria-labelledby="tab-profile">
      <T k="me.profile.h" as="h2" />
      <T k="me.profile.intro" as="p" />
      <!-- Always rendered at 0% so the bar's height + label line are reserved.
           JS just updates the % once /v1/me returns. -->
      <div id="completeness" class="ps-completeness" aria-live="polite">
        <div class="ps-completeness__bar"><div class="ps-completeness__fill" id="completeness-fill" style="width:0%"></div></div>
        <p class="ps-card__sub"><span id="completeness-label" data-i18n="me.profile.completeness.empty">Perfil completo: 0%</span></p>
      </div>
      <form id="profile-form" class="ps-form">
        <div class="ps-row ps-photo-widget">
          <div id="photo-preview" class="ps-detail__avatar ps-avatar--thumb">👤</div>
          <div class="ps-stack ps-photo-widget__ctrl">
            <label class="ps-btn ps-btn--ghost ps-btn--sm ps-photo-widget__btn" for="photo-input">
              <span id="photo-btn-label" data-i18n="media.upload">Subir foto</span>
            </label>
            <input id="photo-input" type="file" accept="image/jpeg,image/png,image/webp" hidden />
            <button type="button" id="photo-remove" class="ps-btn ps-btn--ghost ps-btn--sm ps-hidden" data-i18n="media.remove">Quitar</button>
            <p id="photo-msg" class="ps-msg" aria-live="polite"></p>
          </div>
        </div>
        <input type="hidden" name="photo" id="photo-key" />
        <label>
          <span data-i18n="me.profile.display_name">Nombre que mostramos</span>
          <input name="displayName" required maxlength="80" autocomplete="name" />
        </label>
        <label>
          <span data-i18n="me.profile.headline">Frase corta (headline)</span>
          <input name="headline" required maxlength="120" data-i18n-placeholder="me.profile.headline_placeholder" placeholder="Plomero 24h en Asunción" />
        </label>
        <label>
          <span data-i18n="me.profile.phone">Teléfono</span>
          <input name="phone" required type="tel" autocomplete="tel" data-i18n-placeholder="me.profile.phone_placeholder" placeholder="+595 981 234567" />
        </label>
        <label>
          <span data-i18n="me.profile.whatsapp">WhatsApp (opcional)</span>
          <input name="whatsapp" type="tel" autocomplete="tel" data-i18n-placeholder="me.profile.whatsapp_placeholder" placeholder="+595 981 234567" />
        </label>
        <label>
          <span data-i18n="me.profile.barrio">Barrio</span>
          <input name="barrio" required list="ps-barrios" data-i18n-placeholder="me.profile.barrio_placeholder" placeholder="Villa Morra" />
        </label>

        <div class="ps-row" style="align-items:center">
          <button type="button" id="geoloc-btn" class="ps-btn ps-btn--ghost ps-btn--sm" data-i18n="me.profile.geoloc_button">Usar mi ubicación</button>
          <span id="geoloc-status" class="ps-card__sub" aria-live="polite"></span>
        </div>
        <input type="hidden" name="lat" id="profile-lat" />
        <input type="hidden" name="lng" id="profile-lng" />

        <label>
          <span data-i18n="me.profile.bio">Bio</span>
          <textarea name="bio" rows="4" maxlength="2000" data-i18n-placeholder="me.profile.bio_placeholder" placeholder="Contales tu experiencia, herramientas, zonas que cubrís…"></textarea>
        </label>
        <button type="submit" class="ps-btn" data-i18n="common.save">Guardar</button>
        <p id="profile-msg" class="ps-msg" role="alert"></p>
      </form>

      <details style="margin-top:24px;background:#f9fafb;border-radius:10px;padding:16px;">
        <summary style="font-weight:700;cursor:pointer;" data-i18n="me.ext.summary"></summary>
        <div id="ext-msg" class="ps-msg" style="margin-top:8px;color:#10b981;"></div>

        <label style="display:block;margin-top:16px;">
          <span style="display:block;font-weight:600;margin-bottom:4px;">Imagen de portada (URL)</span>
          <input id="ext-cover-url" type="url" placeholder="https://…/cover.jpg" style="width:100%;padding:8px;border:1px solid #e5e7eb;border-radius:6px;" />
        </label>

        <h3 style="margin:16px 0 8px 0;font-size:14px;text-transform:uppercase;color:#6b7280;letter-spacing:.05em;">Servicios con precio</h3>
        <div id="ext-services"></div>
        <button type="button" id="ext-add-service" data-i18n="me.ext.add_service" style="background:#eef2ff;color:#4338ca;border:1px solid #c7d2fe;border-radius:6px;padding:6px 12px;font-size:13px;cursor:pointer;"></button>

        <h3 style="margin:16px 0 8px 0;font-size:14px;text-transform:uppercase;color:#6b7280;letter-spacing:.05em;">Zonas (hasta 8)</h3>
        <div id="ext-areas" style="display:flex;flex-wrap:wrap;gap:6px;"></div>

        <h3 style="margin:16px 0 8px 0;font-size:14px;text-transform:uppercase;color:#6b7280;letter-spacing:.05em;">Portfolio (URLs de fotos)</h3>
        <div id="ext-portfolio"></div>
        <button type="button" id="ext-add-photo" data-i18n="me.ext.add_photo" style="background:#eef2ff;color:#4338ca;border:1px solid #c7d2fe;border-radius:6px;padding:6px 12px;font-size:13px;cursor:pointer;"></button>

        <h3 style="margin:16px 0 8px 0;font-size:14px;text-transform:uppercase;color:#6b7280;letter-spacing:.05em;">Horario</h3>
        <div id="ext-schedule" style="display:grid;grid-template-columns:60px 1fr 1fr;gap:6px;align-items:center;font-size:13px;"></div>

        <h3 style="margin:16px 0 8px 0;font-size:14px;text-transform:uppercase;color:#6b7280;letter-spacing:.05em;">Filtros de leads</h3>
        <label style="display:block;margin-bottom:8px;">
          <span style="display:block;font-weight:600;margin-bottom:4px;font-size:13px;">Presupuesto mínimo (Gs)</span>
          <input id="ext-lf-min" type="number" min="0" placeholder="0 = sin filtro" style="width:100%;padding:8px;border:1px solid #e5e7eb;border-radius:6px;" />
        </label>
        <label style="display:block;margin-bottom:8px;">
          <input id="ext-lf-hide-new" type="checkbox" /> Esconder cuentas creadas hace &lt; 7 días (anti-spam)
        </label>

        <h3 style="margin:16px 0 8px 0;font-size:14px;text-transform:uppercase;color:#6b7280;letter-spacing:.05em;">Guaraní (opcional)</h3>
        <label style="display:block;margin-bottom:8px;">
          <span style="display:block;font-weight:600;margin-bottom:4px;font-size:13px;">Frase corta en guaraní</span>
          <input id="ext-headline-gn" type="text" maxlength="120" placeholder="Mba'e oñembo'epáva…" style="width:100%;padding:8px;border:1px solid #e5e7eb;border-radius:6px;" />
        </label>
        <label style="display:block;margin-bottom:8px;">
          <span style="display:block;font-weight:600;margin-bottom:4px;font-size:13px;">Bio en guaraní</span>
          <textarea id="ext-bio-gn" rows="3" maxlength="2000" style="width:100%;padding:8px;border:1px solid #e5e7eb;border-radius:6px;font-family:inherit;"></textarea>
        </label>

        <h3 style="margin:16px 0 8px 0;font-size:14px;text-transform:uppercase;color:#6b7280;letter-spacing:.05em;">Verificación</h3>
        <label style="display:block;margin-bottom:8px;">
          <span style="display:block;font-weight:600;margin-bottom:4px;font-size:13px;">RUC (opcional)</span>
          <input id="ext-ruc" type="text" maxlength="20" placeholder="Ej: 80012345-1" style="width:100%;padding:8px;border:1px solid #e5e7eb;border-radius:6px;" />
        </label>

        <button type="button" id="ext-save" data-i18n="me.ext.save" class="ps-btn" style="margin-top:16px;width:100%;"></button>
      </details>

      <fieldset class="ps-banner ps-stack ps-notif-fieldset">
        <legend><strong data-i18n="me.notifs.h">Notificaciones</strong></legend>
        <label class="ps-row ps-checkbox-row">
          <input type="checkbox" id="notif-email" />
          <span data-i18n="me.notifs.email">Recibir avisos por email</span>
        </label>
        <p id="notif-msg" class="ps-msg" aria-live="polite"></p>
      </fieldset>

      <fieldset class="ps-banner ps-stack">
        <legend><strong>
          <span lang="es">Seguridad — Passkeys</span>
          <span lang="en">Security — Passkeys</span>
        </strong></legend>
        <p class="ps-card__sub">
          <span lang="es">Iniciá sesión con Touch ID, Face ID, Windows Hello o el bloqueo de tu teléfono — sin código por email.</span>
          <span lang="en">Sign in with Touch ID, Face ID, Windows Hello or your phone's screen lock — no email code needed.</span>
        </p>
        <!-- Skeleton reserves 3rem (single row height) so the form below
             doesn't shift when GET /api/auth/passkeys returns. JS swaps the
             content + removes the data-skeleton attr on first paint. -->
        <div id="passkey-list" class="ps-stack" aria-live="polite" data-skeleton="1" style="min-height:3rem">
          <p class="ps-card__sub" data-i18n="me.loading_passkeys"></p>
        </div>
        <button type="button" id="passkey-add" class="ps-btn ps-btn--sm">
          <span lang="es">+ Agregar passkey</span>
          <span lang="en">+ Add passkey</span>
        </button>
        <p id="passkey-msg" class="ps-msg" role="alert" style="min-height:1.5rem"></p>
      </fieldset>
    </div>

    <div class="ps-tabpanel" id="panel-listings" role="tabpanel" aria-labelledby="tab-listings">
      <div class="ps-row" style="justify-content:space-between">
        <T k="me.listings.h" as="h2" />
        <a id="new-listing" class="ps-btn ps-btn--sm"><T k="me.listings.new" /></a>
      </div>
      <div id="my-listings" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-requests" role="tabpanel" aria-labelledby="tab-requests">
      <div class="ps-row" style="justify-content:space-between">
        <T k="me.requests.h" as="h2" />
        <a id="new-request" class="ps-btn ps-btn--sm"><T k="me.requests.new" /></a>
      </div>
      <div id="my-requests" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-inquiries" role="tabpanel" aria-labelledby="tab-inquiries">
      <T k="me.inquiries.h" as="h2" />
      <div id="my-inquiries" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-stats" role="tabpanel" aria-labelledby="tab-stats">
      <T k="me.stats.h" as="h2" />
      <p id="stats-msg" class="ps-msg"><T k="me.stats.intro" /></p>
      <!-- aria-busy reserves a min-height via CSS so the footer doesn't jump
           when /v1/analytics/me resolves and the 5 stat cards inject. -->
      <div id="stats-grid" class="ps-stats-grid" aria-busy="true"></div>
      <div id="stats-extended" style="margin-top:24px;"></div>
    </div>

    <div class="ps-tabpanel" id="panel-game" role="tabpanel" aria-labelledby="tab-game">
      <h2>Logros e insignias</h2>
      <div id="completeness-extended" style="margin-bottom:16px;"></div>
      <h3 style="margin-top:24px;font-size:14px;text-transform:uppercase;letter-spacing:.05em;color:#6b7280;">Misiones de hoy</h3>
      <div id="quests-daily" class="ps-quests" aria-busy="true"><p class="ps-card__sub" data-i18n="me.loading_quests"></p></div>
      <h3 style="margin-top:16px;font-size:14px;text-transform:uppercase;letter-spacing:.05em;color:#6b7280;">Misión semanal</h3>
      <div id="quests-weekly" class="ps-quests" aria-busy="true"><p class="ps-card__sub" data-i18n="me.loading_quests"></p></div>
      <h3 style="margin-top:24px;font-size:16px;">Insignias</h3>
      <div id="badges-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-quotes" role="tabpanel" aria-labelledby="tab-quotes">
      <div class="ps-row" style="justify-content:space-between;align-items:center;margin-bottom:12px;">
        <h2 style="margin:0;">Cotizaciones</h2>
        <a class="ps-btn ps-btn--sm" href="/me/quotes/new/">+ Nueva cotización</a>
      </div>
      <p class="ps-card__sub">Generá cotizaciones por WhatsApp con un click. Plantillas por oficio, IVA opcional, PDF descargable.</p>
      <div id="quotes-list" aria-busy="true" style="margin-top:16px;"><p class="ps-card__sub">Cargando…</p></div>
    </div>

    <div class="ps-tabpanel" id="panel-clients" role="tabpanel" aria-labelledby="tab-clients">
      <h2>Mis clientes</h2>
      <p class="ps-card__sub">Tus clientes recurrentes. Se agregan automáticamente cuando se completa un trabajo.</p>
      <div id="clients-list" aria-busy="true" style="margin-top:16px;"><p class="ps-card__sub">Cargando…</p></div>
    </div>
  </section>

  <BarriosDatalist />

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, clearToken, categoryLabel, categoryEmoji, formatGs, formatRelativeTime, uploadImage, mediaUrl } from '../lib/api.ts'
    import { interp, t } from '../lib/i18n.ts'
    import { completenessPct, snapshotFromForm } from '../features/me/completeness.ts'
    import { escapeHtml } from '../features/me/sanitize.ts'
    import { enrollPasskey } from '../features/passkey/client.ts'
    import { passkeySupported } from '../features/passkey/platform.ts'

    // ClientRouter swaps body — module scripts re-execute, but we still
    // route through astro:page-load so we get consistent re-init on both
    // the initial paint AND every subsequent in-page navigation back to /me/.
    // The function guards against firing on the wrong route.
    const initMePage = async () => {
      const section = document.querySelector('.ps-section[data-base]')
      if (!section || !location.pathname.endsWith('/me/')) return
      // Prevent double-init when both module evaluation and astro:page-load
      // fire on the initial paint.
      if (section.dataset.meInitialized === '1') return
      section.dataset.meInitialized = '1'

      const base = section.dataset.base ?? ''
      const escape = escapeHtml

      const token = getToken()
      if (!token) {
        // Demo mode entry point — anonymous CTA on /docs/demo-mode/ links here.
        // Skip the login redirect entirely: demoStub serves canned data and the
        // page should run logged-out. Without this guard, the redirect drops
        // ?demo=1 (location.pathname strips the search) and breaks the docs CTA.
        const isDemo = (() => {
          try { return new URLSearchParams(location.search).has('demo') } catch { return false }
        })()
        if (!isDemo) {
          // Send to home with ?login=1 + ?next= so Base.astro auto-opens the
          // sign-in dialog with proper return-after-login. The legacy /login/
          // 302 rewrite strips ?next so we skip it.
          const target = location.pathname + location.search
          location.href = `${base}/?login=1&next=${encodeURIComponent(target)}&reason=dashboard`
          return
        }
      }

      document.getElementById('logout').addEventListener('click', () => {
        clearToken()
        location.href = `${base}/`
      })

      document.getElementById('new-listing').href = `${base}/me/listings/new/`
      document.getElementById('new-request').href = `${base}/me/requests/new/`

      let me
      try { me = await apiFetch('/v1/me') }
      catch { clearToken(); location.href = `${base}/login/`; return }
      document.getElementById('me-info').textContent = `${t('me.session_prefix')} ${me.userId.slice(0,8)}…`

      // Tab routing
      const tabs = document.querySelectorAll('.ps-tab')
      const panels = {
        profile: document.getElementById('panel-profile'),
        listings: document.getElementById('panel-listings'),
        quotes: document.getElementById('panel-quotes'),
        clients: document.getElementById('panel-clients'),
        game: document.getElementById('panel-game'),
        requests: document.getElementById('panel-requests'),
        inquiries: document.getElementById('panel-inquiries'),
        stats: document.getElementById('panel-stats'),
      }
      const tabsArr = Array.from(tabs)
      const setTab = (name, focusTab = false) => {
        for (const tab of tabs) {
          const selected = tab.dataset.tab === name
          tab.setAttribute('aria-selected', selected ? 'true' : 'false')
          tab.setAttribute('tabindex', selected ? '0' : '-1')
          if (selected && focusTab) tab.focus()
        }
        // Drive panel visibility via html[data-me-tab=…] (CSS handles display).
        // The `hidden` attribute is gone from panel markup so CSS alone wins —
        // same mechanism as the pre-paint bootstrap.js path.
        document.documentElement.dataset.meTab = name
        const url = new URL(location.href)
        url.searchParams.set('tab', name)
        history.replaceState({}, '', url.toString())
      }
      for (const tab of tabs) tab.addEventListener('click', () => setTab(tab.dataset.tab))
      // Arrow-key navigation per WAI-ARIA Authoring Practices tab pattern.
      for (const tab of tabs) tab.addEventListener('keydown', (e) => {
        const i = tabsArr.indexOf(e.currentTarget)
        if (e.key === 'ArrowRight') { e.preventDefault(); setTab(tabsArr[(i + 1) % tabsArr.length].dataset.tab, true) }
        else if (e.key === 'ArrowLeft') { e.preventDefault(); setTab(tabsArr[(i - 1 + tabsArr.length) % tabsArr.length].dataset.tab, true) }
        else if (e.key === 'Home') { e.preventDefault(); setTab(tabsArr[0].dataset.tab, true) }
        else if (e.key === 'End') { e.preventDefault(); setTab(tabsArr[tabsArr.length - 1].dataset.tab, true) }
      })
      const initial = new URLSearchParams(location.search).get('tab') || 'profile'
      setTab(initial)

      // ---- Profile ----
      let myProfile = null
      try {
        const list = await apiFetch('/v1/specialists')
        myProfile = list.find((s) => s.userId === me.userId) ?? null
      } catch {}
      const pf = document.getElementById('profile-form')
      const photoPreview = document.getElementById('photo-preview')
      const photoInput = document.getElementById('photo-input')
      const photoKey = document.getElementById('photo-key')
      const photoMsg = document.getElementById('photo-msg')
      const photoBtnLabel = document.getElementById('photo-btn-label')
      const photoRemove = document.getElementById('photo-remove')
      const showPhoto = (key) => {
        if (key) {
          photoPreview.classList.add('ps-avatar--photo')
          photoPreview.innerHTML = `<img class="ps-avatar__img" src="${mediaUrl(key)}" alt=""/>`
          photoBtnLabel.textContent = t('media.replace')
          photoRemove.classList.remove('ps-hidden')
        } else {
          photoPreview.classList.remove('ps-avatar--photo')
          photoPreview.textContent = '👤'
          photoBtnLabel.textContent = t('media.upload')
          photoRemove.classList.add('ps-hidden')
        }
      }
      if (myProfile) {
        for (const k of ['displayName','headline','phone','whatsapp','barrio','bio']) {
          if (pf.elements[k] && myProfile[k] != null) pf.elements[k].value = myProfile[k]
        }
        if (myProfile.photo) { photoKey.value = myProfile.photo; showPhoto(myProfile.photo) }
        if (myProfile.lat != null) pf.elements.lat.value = myProfile.lat
        if (myProfile.lng != null) pf.elements.lng.value = myProfile.lng
      }

      // Geolocation
      const geoBtn = document.getElementById('geoloc-btn')
      const geoStatus = document.getElementById('geoloc-status')
      const profileLat = document.getElementById('profile-lat')
      const profileLng = document.getElementById('profile-lng')
      const updateGeoStatus = () => {
        if (profileLat.value && profileLng.value) {
          geoStatus.textContent = `📍 ${(+profileLat.value).toFixed(4)}, ${(+profileLng.value).toFixed(4)}`
        }
      }
      updateGeoStatus()
      geoBtn.addEventListener('click', () => {
        if (!navigator.geolocation) { geoStatus.textContent = t('me.profile.geoloc.unavailable'); return }
        geoStatus.textContent = t('me.profile.geoloc.locating')
        navigator.geolocation.getCurrentPosition(
          (pos) => {
            profileLat.value = String(pos.coords.latitude)
            profileLng.value = String(pos.coords.longitude)
            updateGeoStatus()
          },
          () => { geoStatus.textContent = t('me.profile.geoloc.denied') },
          { enableHighAccuracy: false, timeout: 8000, maximumAge: 60000 },
        )
      })
      photoInput.addEventListener('change', async () => {
        const f = photoInput.files?.[0]
        if (!f) return
        photoMsg.textContent = t('media.uploading')
        try {
          const key = await uploadImage(f)
          photoKey.value = key
          showPhoto(key)
          photoMsg.textContent = ''
        } catch (err) { photoMsg.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
        finally { photoInput.value = '' }
      })
      photoRemove.addEventListener('click', () => { photoKey.value = ''; showPhoto('') })

      const pm = document.getElementById('profile-msg')
      pf.addEventListener('submit', async (e) => {
        e.preventDefault()
        pm.textContent = t('common.saving')
        const fd = Object.fromEntries(new FormData(pf))
        if (!fd.photo) fd.photo = null
        fd.lat = fd.lat ? Number(fd.lat) : null
        fd.lng = fd.lng ? Number(fd.lng) : null
        try {
          if (myProfile) {
            await apiFetch(`/v1/specialists/${myProfile.id}`, { method: 'PATCH', body: JSON.stringify(fd) })
          } else {
            myProfile = await apiFetch('/v1/specialists', { method: 'POST', body: JSON.stringify(fd) })
          }
          pm.innerHTML = `<span class="ps-msg--ok">${t('me.profile.saved')}</span>`
          refreshListings()
        } catch (err) { pm.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>` }
      })

      // ---- Profile completeness meter ----
      const completenessEl = document.getElementById('completeness')
      const completenessFill = document.getElementById('completeness-fill')
      const completenessLabel = document.getElementById('completeness-label')
      const computeCompleteness = () => {
        const pct = completenessPct(snapshotFromForm(pf, photoKey.value || null))
        completenessFill.style.width = pct + '%'
        completenessLabel.textContent = interp(t('me.profile.completeness.label'), { pct })
      }
      pf.addEventListener('input', computeCompleteness)
      photoInput.addEventListener('change', () => setTimeout(computeCompleteness, 50))
      photoRemove.addEventListener('click', () => setTimeout(computeCompleteness, 50))
      computeCompleteness()

      // ---- Passkeys (security section) ----
      const passkeyList = document.getElementById('passkey-list')
      const passkeyAdd = document.getElementById('passkey-add')
      const passkeyMsg = document.getElementById('passkey-msg')
      const renderPasskeys = (items) => {
        // Drop the skeleton marker so post-FCP mutation observers don't
        // flag this region as a content change (and so the layout is
        // committed to the rendered list height).
        passkeyList.removeAttribute('data-skeleton')
        if (!items.length) {
          passkeyList.innerHTML = `<p class="ps-card__sub">No hay passkeys guardadas. Agregá una para iniciar sesión sin código.</p>`
          return
        }
        passkeyList.innerHTML = items.map((p) => `
          <div class="ps-row" style="justify-content:space-between;align-items:center">
            <div>
              <strong>${escape(p.label || 'Passkey')}</strong>
              <p class="ps-card__sub" style="margin:0">${formatRelativeTime(p.createdAt)}</p>
            </div>
            <button type="button" class="ps-btn ps-btn--ghost ps-btn--sm js-pk-delete" data-id="${escape(p.credentialId)}" aria-label="Eliminar passkey">×</button>
          </div>
        `).join('')
        for (const btn of passkeyList.querySelectorAll('.js-pk-delete')) {
          btn.addEventListener('click', async () => {
            passkeyMsg.textContent = ''
            try {
              await apiFetch(`/api/auth/passkeys/${btn.dataset.id}`, { method: 'DELETE' })
              await refreshPasskeys()
            } catch (err) {
              passkeyMsg.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>`
            }
          })
        }
      }
      const refreshPasskeys = async () => {
        try {
          // Backend returns { items: [{credentialId, label, createdAt, lastUsedAt}] }.
          // apiFetch only unwraps `data` envelopes; this one keeps `items` at root.
          const body = await apiFetch('/api/auth/passkeys')
          renderPasskeys(body?.items || [])
        } catch { passkeyList.innerHTML = '' }
      }
      passkeyAdd.addEventListener('click', async () => {
        if (!passkeySupported()) {
          passkeyMsg.innerHTML = `<span class="ps-error">Tu navegador no soporta passkeys.</span>`
          return
        }
        passkeyMsg.textContent = t('common.saving')
        const r = await enrollPasskey(apiFetch)
        if (r === 'ok') {
          passkeyMsg.innerHTML = `<span class="ps-msg--ok">Passkey guardada.</span>`
          await refreshPasskeys()
        } else if (r === 'cancelled') {
          passkeyMsg.textContent = ''
        } else {
          passkeyMsg.innerHTML = `<span class="ps-error">No se pudo guardar la passkey.</span>`
        }
      })
      // Hide the Add button if the browser can't do passkeys at all.
      if (!passkeySupported()) passkeyAdd.disabled = true
      refreshPasskeys()

      // ---- Notifications opt-out ----
      const notifEmail = document.getElementById('notif-email')
      const notifMsg = document.getElementById('notif-msg')
      try {
        const n = await apiFetch('/v1/me/notifications')
        notifEmail.checked = n.emailNotifications !== false
      } catch { notifEmail.checked = true }
      notifEmail.addEventListener('change', async () => {
        notifMsg.textContent = t('common.saving')
        try {
          await apiFetch('/v1/me/notifications', { method: 'PATCH', body: JSON.stringify({ emailNotifications: notifEmail.checked }) })
          notifMsg.innerHTML = `<span class="ps-msg--ok">${t('me.notifs.saved')}</span>`
        } catch (err) { notifMsg.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>` }
      })

      // ---- My listings ----
      const lEl = document.getElementById('my-listings')
      const refreshListings = async () => {
        if (!myProfile) {
          lEl.removeAttribute('aria-busy')
          lEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">👤</span><strong class="ps-empty__title">${t('me.listings.empty_profile.title')}</strong><span class="ps-empty__hint">${t('me.listings.empty_profile.hint')}</span></p>`
          return
        }
        lEl.setAttribute('aria-busy', 'true')
        try {
          const items = await apiFetch(`/v1/listings?specialist_id=${myProfile.id}`)
          lEl.removeAttribute('aria-busy')
          if (items.length === 0) {
            lEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">📦</span><strong class="ps-empty__title">${t('me.listings.empty.title')}</strong><span class="ps-empty__hint">${t('me.listings.empty.hint')}</span></p>`
            return
          }
          const priceFrom = t('me.listings.price_from')
          const priceTbd = t('common.price_tbd')
          const editLabel = t('common.edit')
          const deleteLabel = t('common.delete')
          lEl.innerHTML = items.map((l) => `
            <article class="ps-card">
              <div class="ps-row">
                <span class="ps-chip">${categoryEmoji(l.category)} ${categoryLabel(l.category)}</span>
              </div>
              <h3>${escape(l.title)}</h3>
              <p class="ps-card__sub">${l.priceFromGs ? `${priceFrom} ${escape(formatGs(l.priceFromGs))}` : priceTbd}</p>
              <p class="ps-card__body">${escape(l.description.slice(0,160))}${l.description.length>160?'…':''}</p>
              <div class="ps-card__cta">
                <a href="${base}/me/listings/edit/?id=${l.id}">${editLabel}</a>
                <button data-id="${l.id}" class="ps-btn ps-btn--ghost ps-btn--sm js-del">${deleteLabel}</button>
              </div>
            </article>`).join('')
          for (const btn of lEl.querySelectorAll('.js-del')) {
            btn.addEventListener('click', async () => {
              if (!confirm(t('me.listings.confirm_delete'))) return
              await apiFetch(`/v1/listings/${btn.dataset.id}`, { method: 'DELETE' })
              refreshListings()
            })
          }
        } catch (err) { lEl.removeAttribute('aria-busy'); lEl.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }
      }
      refreshListings()

      // ---- My requests ----
      const rEl = document.getElementById('my-requests')
      const refreshRequests = async () => {
        rEl.setAttribute('aria-busy', 'true')
        try {
          // Dedicated endpoint returns ALL my requests (open + closed)
          const mine = await apiFetch('/v1/me/requests')
          rEl.removeAttribute('aria-busy')
          if (mine.length === 0) {
            rEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">📭</span><strong class="ps-empty__title">${t('me.requests.empty.title')}</strong><span class="ps-empty__hint">${t('me.requests.empty.hint')}</span></p>`
            return
          }
          const statusOpen = t('me.requests.status.open')
          const statusClosed = t('me.requests.status.closed')
          const editLabel = t('common.edit')
          const publicView = t('me.requests.public_view')
          rEl.innerHTML = mine.map((r) => `
            <article class="ps-card ps-card--request">
              <div class="ps-row">
                <span class="ps-chip">${categoryEmoji(r.category)} ${categoryLabel(r.category)}</span>
                <span class="ps-badge">${r.status === 'open' ? statusOpen : statusClosed}</span>
              </div>
              <h3>${escape(r.title)}</h3>
              <p class="ps-card__sub">📍 ${escape(r.barrio)} · 💰 ${escape(formatGs(r.budgetGs))}</p>
              <div class="ps-card__cta">
                <a href="${base}/me/requests/edit/?id=${r.id}">${editLabel}</a>
                <a href="${base}/clients/${r.id}/">${publicView}</a>
              </div>
            </article>`).join('')
        } catch (err) { rEl.removeAttribute('aria-busy'); rEl.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }
      }
      refreshRequests()

      // ---- Inquiries ----
      const iEl = document.getElementById('my-inquiries')
      try {
        const items = await apiFetch('/v1/inquiries')
        iEl.removeAttribute('aria-busy')
        if (items.length === 0) {
          iEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">💬</span><strong class="ps-empty__title">${t('me.inquiries.empty.title')}</strong><span class="ps-empty__hint">${t('me.inquiries.empty.hint')}</span></p>`
        } else {
          const asClient = t('me.inquiries.as_client')
          const asSpec = t('me.inquiries.as_specialist')
          const aboutListing = t('me.inquiries.about_listing')
          const aboutRequest = t('me.inquiries.about_request')
          iEl.innerHTML = items.map((i) => {
            const role = i.clientUserId === me.userId ? asClient : asSpec
            return `
              <a class="ps-card ps-card--mini" href="${base}/me/inquiries/detail/?id=${i.id}">
                <div class="ps-row">
                  <span class="ps-badge ps-badge--neutral">${role}</span>
                  <span class="ps-card__sub">${formatRelativeTime(i.lastMessageAt)}</span>
                </div>
                <p>${i.subjectType === 'listing' ? aboutListing : aboutRequest}</p>
              </a>`
          }).join('')
        }
      } catch (err) { iEl.removeAttribute('aria-busy'); iEl.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }

      // ---- Stats ----
      const statsGrid = document.getElementById('stats-grid')
      const statsMsg = document.getElementById('stats-msg')
      try {
        const stats = await apiFetch('/v1/analytics/me')
        statsGrid.removeAttribute('aria-busy')
        if (!stats) {
          statsMsg.textContent = t('me.stats.empty')
          statsGrid.innerHTML = ''
        } else {
          const card = (label, value) => `<div class="ps-stat-card"><div class="ps-stat-card__value">${value}</div><div class="ps-stat-card__label">${label}</div></div>`
          statsGrid.innerHTML = [
            card(t('me.stats.profile_view'), stats.last30d.profileView),
            card(t('me.stats.phone_click'), stats.last30d.phoneClick),
            card(t('me.stats.whatsapp_click'), stats.last30d.whatsappClick),
            card(t('me.stats.inquiries'), stats.funnel.inquiries),
            card(t('me.stats.completed'), stats.funnel.completed),
          ].join('')
        }
      } catch (err) { statsGrid.removeAttribute('aria-busy'); statsGrid.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }

      // ============ HUD + Game State + Badges + Quests + Quotes + Clients ============
      void loadGamification()
      void loadQuotes()
      void loadClients()
      void loadExtendedEditor()
      void maybeLaunchT1()
    }

    // ---- Extended profile editor ----
    const DAY_LABELS = { mon: 'Lun', tue: 'Mar', wed: 'Mié', thu: 'Jue', fri: 'Vie', sat: 'Sáb', sun: 'Dom' }
    const DAY_ORDER = ['mon', 'tue', 'wed', 'thu', 'fri', 'sat', 'sun']
    const loadExtendedEditor = async () => {
      // areas dropdown
      let areas = []
      try { const r = await apiFetch('/v1/me/service-areas'); areas = r.data ?? [] } catch {}
      const areasEl = document.getElementById('ext-areas')
      if (areasEl) {
        areasEl.innerHTML = areas.map((a) => `
          <label style="display:flex;align-items:center;gap:4px;background:white;border:1px solid #e5e7eb;border-radius:999px;padding:4px 10px;font-size:13px;cursor:pointer;">
            <input type="checkbox" data-area="${escape(a.slug)}" style="margin:0;" /> ${escape(a.name)}
          </label>
        `).join('')
      }
      // schedule grid
      const schedEl = document.getElementById('ext-schedule')
      if (schedEl) {
        schedEl.innerHTML = DAY_ORDER.map((d) => `
          <div>${DAY_LABELS[d]}</div>
          <input type="time" data-day-from="${d}" />
          <input type="time" data-day-to="${d}" />
        `).join('')
      }
      // Load existing
      try {
        const r = await apiFetch('/v1/me/profile-extended')
        const p = r.data
        if (p) {
          const $ = (id) => document.getElementById(id)
          if ($('ext-cover-url') && p.coverUrl) $('ext-cover-url').value = p.coverUrl
          if ($('ext-headline-gn') && p.headlineGn) $('ext-headline-gn').value = p.headlineGn
          if ($('ext-bio-gn') && p.bioGn) $('ext-bio-gn').value = p.bioGn
          if ($('ext-ruc') && p.rucNumber) $('ext-ruc').value = p.rucNumber
          if ($('ext-lf-min') && p.leadFilters?.minBudget) $('ext-lf-min').value = String(p.leadFilters.minBudget)
          if ($('ext-lf-hide-new')) $('ext-lf-hide-new').checked = Boolean(p.leadFilters?.hideNewAccounts)
          // areas
          const set = new Set((p.areas || []).map((a) => a.slug))
          document.querySelectorAll('[data-area]').forEach((cb) => { cb.checked = set.has(cb.dataset.area) })
          // services
          rebuildServices(p.services || [])
          // portfolio
          rebuildPortfolio(p.portfolio || [])
          // schedule
          for (const d of DAY_ORDER) {
            const slot = (p.schedule?.weekly?.[d] || [])[0]
            const from = document.querySelector(`[data-day-from="${d}"]`)
            const to = document.querySelector(`[data-day-to="${d}"]`)
            if (slot && from && to) {
              const [hf, ht] = String(slot).split('-')
              from.value = hf || ''
              to.value = ht || ''
            }
          }
        }
      } catch (e) { console.debug('ext load:', e.message) }

      const $ = (id) => document.getElementById(id)
      $('ext-add-service')?.addEventListener('click', () => addService())
      $('ext-add-photo')?.addEventListener('click', () => addPhoto())
      $('ext-save')?.addEventListener('click', () => void saveExt())
    }

    const rebuildServices = (list) => {
      const c = document.getElementById('ext-services')
      if (!c) return
      c.innerHTML = ''
      list.forEach((s) => addService(s))
    }
    const addService = (s = {}) => {
      const c = document.getElementById('ext-services')
      if (!c) return
      const row = document.createElement('div')
      row.style.cssText = 'display:grid;grid-template-columns:2fr 1fr 1fr 32px;gap:6px;margin-bottom:6px;'
      row.innerHTML = `
        <input type="text" placeholder="Servicio" value="${escape(s.name || '')}" data-svc="name" style="padding:6px;border:1px solid #e5e7eb;border-radius:4px;" />
        <input type="number" placeholder="Desde Gs" value="${s.priceMin ?? ''}" data-svc="priceMin" style="padding:6px;border:1px solid #e5e7eb;border-radius:4px;" />
        <input type="number" placeholder="Hasta Gs" value="${s.priceMax ?? ''}" data-svc="priceMax" style="padding:6px;border:1px solid #e5e7eb;border-radius:4px;" />
        <button type="button" data-svc-remove style="background:#fee2e2;color:#991b1b;border:none;border-radius:4px;cursor:pointer;">×</button>`
      row.addEventListener('click', (e) => { if (e.target.closest('[data-svc-remove]')) row.remove() })
      c.appendChild(row)
    }
    const rebuildPortfolio = (list) => {
      const c = document.getElementById('ext-portfolio')
      if (!c) return
      c.innerHTML = ''
      list.forEach((p) => addPhoto(p))
    }
    const addPhoto = (p = {}) => {
      const c = document.getElementById('ext-portfolio')
      if (!c) return
      const row = document.createElement('div')
      row.style.cssText = 'display:grid;grid-template-columns:1fr 1fr 32px;gap:6px;margin-bottom:6px;'
      row.innerHTML = `
        <input type="url" placeholder="URL de la foto" value="${escape(p.url || '')}" data-ph="url" style="padding:6px;border:1px solid #e5e7eb;border-radius:4px;" />
        <input type="text" placeholder="Descripción (opc)" value="${escape(p.caption || '')}" data-ph="caption" style="padding:6px;border:1px solid #e5e7eb;border-radius:4px;" />
        <button type="button" data-ph-remove style="background:#fee2e2;color:#991b1b;border:none;border-radius:4px;cursor:pointer;">×</button>`
      row.addEventListener('click', (e) => { if (e.target.closest('[data-ph-remove]')) row.remove() })
      c.appendChild(row)
    }

    const saveExt = async () => {
      const $ = (id) => document.getElementById(id)
      const services = Array.from(document.querySelectorAll('#ext-services > div')).map((row) => ({
        name: row.querySelector('[data-svc="name"]').value,
        priceMin: Number(row.querySelector('[data-svc="priceMin"]').value || 0) || null,
        priceMax: Number(row.querySelector('[data-svc="priceMax"]').value || 0) || null,
        currency: 'PYG',
      })).filter((s) => s.name)
      const portfolio = Array.from(document.querySelectorAll('#ext-portfolio > div')).map((row, i) => ({
        url: row.querySelector('[data-ph="url"]').value,
        caption: row.querySelector('[data-ph="caption"]').value,
        order: i,
      })).filter((p) => p.url)
      const areasArr = Array.from(document.querySelectorAll('[data-area]:checked')).slice(0, 8).map((cb, i) => ({ slug: cb.dataset.area, isPrimary: i === 0 }))
      const weekly = {}
      for (const d of DAY_ORDER) {
        const from = document.querySelector(`[data-day-from="${d}"]`)?.value
        const to = document.querySelector(`[data-day-to="${d}"]`)?.value
        if (from && to) weekly[d] = [`${from}-${to}`]
      }
      const body = {
        coverUrl: $('ext-cover-url')?.value || null,
        services,
        portfolio,
        areas: areasArr,
        schedule: { weekly },
        leadFilters: {
          minBudget: Number($('ext-lf-min')?.value || 0) || 0,
          hideNewAccounts: $('ext-lf-hide-new')?.checked || false,
        },
        headlineGn: $('ext-headline-gn')?.value || null,
        bioGn: $('ext-bio-gn')?.value || null,
        rucNumber: $('ext-ruc')?.value || null,
      }
      try {
        await apiFetch('/v1/me/profile-extended', { method: 'PATCH', body: JSON.stringify(body) })
        document.getElementById('ext-msg').textContent = '✓ Perfil avanzado guardado'
        // Refresh HUD / completeness
        void loadGamification()
      } catch (e) {
        document.getElementById('ext-msg').textContent = 'Error: ' + (e.message || 'Network')
        document.getElementById('ext-msg').style.color = '#991b1b'
      }
    }

    // ---- Extended completeness (10 fields, endowed-progress 20%) ----
    const completeness10Steps = (p) => {
      const steps = [
        { key: 'whatsapp_verified', label: 'WhatsApp verificado', done: Boolean(p?.verified) },
        { key: 'oficio_chosen', label: 'Oficio elegido', done: true },
        { key: 'photo', label: 'Foto de perfil', done: Boolean(p?.photo) },
        { key: 'cover', label: 'Imagen de portada', done: Boolean(p?.coverUrl) },
        { key: 'bio', label: 'Bio (≥ 80 caracteres)', done: (p?.bio ?? '').trim().length >= 80 },
        { key: 'services', label: '2 servicios con precio', done: Array.isArray(p?.services) && p.services.length >= 2 },
        { key: 'areas', label: 'Zona de trabajo', done: Array.isArray(p?.areas) && p.areas.length >= 1 },
        { key: 'portfolio', label: '3 fotos de trabajos', done: Array.isArray(p?.portfolio) && p.portfolio.length >= 3 },
        { key: 'schedule', label: 'Horario', done: p?.schedule && Object.keys(p.schedule).length > 0 },
        { key: 'cedula', label: 'Cédula o RUC', done: Boolean(p?.cedulaVerified) || Boolean(p?.rucNumber) },
      ]
      const done = steps.filter((s) => s.done).length
      return { steps, pct: Math.round((done / steps.length) * 100), done, total: steps.length }
    }

    const renderCompletenessExtended = (p) => {
      const target = document.getElementById('completeness-extended')
      if (!target) return
      const c = completeness10Steps(p)
      const remaining = c.steps.filter((s) => !s.done).slice(0, 3).map((s) => s.label).join(', ')
      target.innerHTML = `
        <div class="ps-completeness">
          <div class="ps-completeness__top">
            <span class="ps-completeness__title">Perfil ${c.pct}% completo</span>
            <span class="ps-completeness__pct">${c.done}/${c.total}</span>
          </div>
          <div class="ps-completeness__bar">
            <div class="ps-completeness__fill" style="width:${c.pct}%;"></div>
          </div>
          ${remaining ? `<div class="ps-completeness__next">Falta: ${escape(remaining)}</div>` : `<div class="ps-completeness__next">✓ Completo. Insignia "Perfil Maestro" desbloqueada.</div>`}
        </div>`
    }

    const loadGamification = async () => {
      try {
        const state = await apiFetch('/v1/me/game-state')
        const s = state.data ?? state
        const hud = document.getElementById('game-hud')
        if (hud) {
          document.getElementById('hud-xp').textContent = String(s.xp)
          const streak = s.streak?.current ?? 0
          const streakEl = document.getElementById('hud-streak')
          if (streakEl) streakEl.textContent = `🔥 ${streak} d`
          const cell = document.getElementById('hud-streak-cell')
          if (cell) cell.dataset.streak = streak >= 100 ? 'gold' : streak >= 30 ? 'red' : streak >= 7 ? 'hot' : ''
          const tierName = {aprendiz:'Aprendiz',oficial:'Oficial',maestro:'Maestro',maestro_mayor:'Maestro Mayor',patron:'Patrón'}[s.tier] || s.tier
          document.getElementById('hud-tier').textContent = `⚡ ${tierName.split(' ')[0]}`
          document.getElementById('hud-tier-name').textContent = tierName
        }

        // Extended completeness uses real profile data (we already have it via /v1/specialists/:id by user_id)
        // For now, fall back to existing me-fetch shape (no portfolio etc); profile-extended will fill more.
        try {
          const ex = await apiFetch('/v1/me/profile-extended')
          if (ex.data) renderCompletenessExtended(ex.data)
        } catch {}
      } catch (e) {
        // gracefully fail; not all users are specialists yet
        console.debug('game-state load:', e.message)
      }

      // Badges grid
      try {
        const b = await apiFetch('/v1/me/badges')
        const grid = document.getElementById('badges-grid')
        if (grid) {
          grid.removeAttribute('aria-busy')
          grid.innerHTML = (b.data ?? []).map((badge) => `
            <div class="ps-badge-pill" data-rarity="${badge.rarity}" style="display:flex;flex-direction:column;align-items:center;text-align:center;padding:12px;gap:4px;border-radius:8px;${badge.earned ? '' : 'opacity:0.4;filter:grayscale(1);'}" title="${escape(badge.description?.es ?? '')}">
              <div style="font-size:24px;">${badge.earned ? '🏆' : '🔒'}</div>
              <div style="font-weight:700;font-size:13px;">${escape(badge.name?.es ?? badge.code)}</div>
              <div style="font-size:10px;opacity:0.7;text-transform:uppercase;letter-spacing:.05em;">${badge.rarity}</div>
            </div>
          `).join('')
        }
      } catch (e) { console.debug('badges load:', e.message) }

      // Quests
      try {
        const q = await apiFetch('/v1/me/quests')
        const daily = (q.data ?? []).filter((qq) => qq.type === 'daily')
        const weekly = (q.data ?? []).filter((qq) => qq.type === 'weekly')
        const renderQuestList = (target, list) => {
          target.removeAttribute('aria-busy')
          if (list.length === 0) { target.innerHTML = '<p class="ps-card__sub">Sin misiones activas.</p>'; return }
          target.innerHTML = list.map((qq) => {
            const done = qq.status === 'done'
            const cur = qq.progress?.current ?? 0
            const goal = qq.goal?.count ?? 1
            return `<div class="ps-quest" data-done="${done ? '1' : ''}">
              <div class="ps-quest__check">${done ? '✓' : ''}</div>
              <div>${escape(qq.title)} <span style="color:#9ca3af;font-size:12px;">(${cur}/${goal})</span></div>
              <div class="ps-quest__reward">+${qq.rewardXp} XP</div>
            </div>`
          }).join('')
        }
        const d = document.getElementById('quests-daily')
        const w = document.getElementById('quests-weekly')
        if (d) renderQuestList(d, daily)
        if (w) renderQuestList(w, weekly)
      } catch (e) { console.debug('quests load:', e.message) }
    }

    const loadQuotes = async () => {
      const list = document.getElementById('quotes-list')
      if (!list) return
      try {
        const r = await apiFetch('/v1/me/quotes')
        list.removeAttribute('aria-busy')
        const items = r.data ?? []
        if (items.length === 0) {
          list.innerHTML = `<p class="ps-card__sub" style="text-align:center;padding:32px 16px;background:#f9fafb;border-radius:8px;">No hay cotizaciones aún. <a href="/me/quotes/new/" style="color:#4f46e5;">Crear la primera →</a></p>`
          return
        }
        list.innerHTML = items.map((q) => `
          <div style="background:white;border:1px solid #e5e7eb;border-radius:10px;padding:14px;margin-bottom:8px;">
            <div style="display:flex;justify-content:space-between;align-items:center;">
              <div>
                <div style="font-weight:600;">${escape(q.clientName ?? 'Sin cliente')}</div>
                <div style="color:#6b7280;font-size:13px;">${q.items.length} ítems · ${formatRelativeTime(q.createdAt)}</div>
              </div>
              <div style="font-weight:700;color:#4f46e5;">${new Intl.NumberFormat('es-PY',{maximumFractionDigits:0}).format(q.total)} Gs</div>
            </div>
            ${q.sentAt ? `<div style="margin-top:6px;font-size:12px;color:#10b981;">✓ Enviado por WhatsApp</div>` : ''}
          </div>
        `).join('')
      } catch (e) {
        list.removeAttribute('aria-busy')
        list.innerHTML = `<p class="ps-error">${escape(e.message || 'Error')}</p>`
      }
    }

    const loadClients = async () => {
      const list = document.getElementById('clients-list')
      if (!list) return
      try {
        const r = await apiFetch('/v1/me/clients')
        list.removeAttribute('aria-busy')
        const items = r.data ?? []
        if (items.length === 0) {
          list.innerHTML = `<p class="ps-card__sub" style="text-align:center;padding:32px 16px;background:#f9fafb;border-radius:8px;">Sin clientes aún. Se agregan automáticamente cuando completés un trabajo en PyaServ.</p>`
          return
        }
        list.innerHTML = items.map((cl) => `
          <div style="background:white;border:1px solid #e5e7eb;border-radius:10px;padding:14px;margin-bottom:8px;" data-client-id="${escape(cl.id)}">
            <div style="display:flex;justify-content:space-between;align-items:start;gap:12px;">
              <div style="flex:1;min-width:0;">
                <div style="font-weight:600;">${escape(cl.displayName || 'Cliente')}</div>
                <div style="color:#6b7280;font-size:13px;">${cl.jobCount} trabajo${cl.jobCount !== 1 ? 's' : ''} · ${cl.barrio || '—'}${cl.lastJobAt ? ` · último: ${formatRelativeTime(cl.lastJobAt)}` : ''}</div>
                ${cl.notes ? `<div style="margin-top:6px;color:#1f2937;font-size:13px;background:#f9fafb;padding:6px 8px;border-radius:6px;">${escape(cl.notes)}</div>` : ''}
              </div>
              <button type="button" class="ps-btn ps-btn--sm ps-btn--ghost" data-client-notes>Notas</button>
            </div>
          </div>
        `).join('')
        list.addEventListener('click', async (ev) => {
          const btn = ev.target instanceof Element ? ev.target.closest('[data-client-notes]') : null
          if (!btn) return
          const card = btn.closest('[data-client-id]')
          const id = card?.dataset.clientId
          if (!id) return
          const cur = (items.find((x) => x.id === id)?.notes) || ''
          const next = prompt('Notas sobre este cliente:', cur)
          if (next === null) return
          try {
            await apiFetch(`/v1/me/clients/${id}`, { method: 'PATCH', body: JSON.stringify({ notes: next }) })
            void loadClients()
          } catch (e) { alert('Error: ' + (e.message || 'Network')) }
        })
      } catch (e) {
        list.removeAttribute('aria-busy')
        list.innerHTML = `<p class="ps-error">${escape(e.message || 'Error')}</p>`
      }
    }

    // ---- Onboarding Tour T1 auto-launch ----
    const maybeLaunchT1 = async () => {
      try {
        const r = await apiFetch('/v1/me/tours')
        const completed = (r.data ?? []).find((tt) => tt.code === 'T1')
        if (completed) return
        // Check completeness — if already 100%, skip
        const ex = await apiFetch('/v1/me/profile-extended').catch(() => ({ data: null }))
        if (!ex.data) return // no specialist profile yet — don't launch T1 either; user must first hit /v1/specialists POST
        const c = completeness10Steps(ex.data)
        if (c.pct >= 100) return
        const mod = await import('driver.js')
        await import('driver.js/dist/driver.css')
        const driver = mod.driver({
          showProgress: true,
          progressText: 'Paso {{current}} de {{total}}',
          nextBtnText: 'Siguiente', prevBtnText: 'Atrás', doneBtnText: '¡Listo!',
          onCloseClick: async () => {
            try { await apiFetch('/v1/me/tours', { method: 'POST', body: JSON.stringify({ code: 'T1', status: 'skipped' }) }) } catch {}
            driver.destroy()
          },
          onDestroyed: async () => {
            try { await apiFetch('/v1/me/tours', { method: 'POST', body: JSON.stringify({ code: 'T1', status: 'completed' }) }) } catch {}
          },
          steps: [
            { element: '#photo-preview', popover: { title: 'Empezamos por tu cara', description: 'Una buena foto duplica las consultas. Sacate una con luz natural.' } },
            { element: 'input[name="headline"]', popover: { title: 'Tu frase de presentación', description: 'Una línea corta: oficio + zona + ventaja. Ej: "Plomero 24h en Villa Morra".' } },
            { element: 'textarea[name="bio"]', popover: { title: 'Contales quién sos', description: '2-3 frases. Tu experiencia, herramientas, zonas que cubrís.' } },
            { element: 'input[name="phone"]', popover: { title: 'Tu teléfono', description: 'Cómo te contactan. Usá el mismo que tu WhatsApp si es posible.' } },
            { element: 'input[name="whatsapp"]', popover: { title: 'WhatsApp', description: 'El botón principal de tu perfil llevará acá. Asegurate de que esté actualizado.' } },
            { element: 'input[name="barrio"]', popover: { title: 'Tu barrio principal', description: 'Donde tenés más trabajo. Después podés agregar más zonas en la edición avanzada.' } },
            { element: '#completeness-extended, #completeness', popover: { title: '¡Listo!', description: 'Cada paso adicional sube tu visibilidad. ¡A 100% desbloqueás 7 días de Boost gratis y la insignia "Perfil Maestro"!' } },
          ],
        })
        driver.drive()
      } catch (e) { console.debug('T1 launch:', e.message) }
    }

    // astro:page-load fires on initial paint AND after every ClientRouter
    // swap. Both /me/ on first load and /me/ revisited get a fresh init.
    document.addEventListener('astro:page-load', () => { void initMePage() })
  </script>
</Base>
