---
import Base from '~/layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Mi panel" titleKey="me.title" active="me">
  <section class="ps-section" data-base={base}>
    <div class="ps-row" style="justify-content:space-between">
      <h1 data-i18n="me.heading">Mi panel</h1>
      <button id="logout" class="ps-btn ps-btn--ghost ps-btn--sm" data-i18n="me.logout">Cerrar sesión</button>
    </div>
    <p id="me-info" class="ps-card__sub"></p>

    <nav class="ps-tabs" role="tablist" data-i18n-aria="me.tabs.aria" aria-label="Secciones">
      <button class="ps-tab" data-tab="profile" data-i18n="me.tabs.profile">👤 Mi perfil</button>
      <button class="ps-tab" data-tab="listings" data-i18n="me.tabs.listings">🛠️ Mis servicios</button>
      <button class="ps-tab" data-tab="requests" data-i18n="me.tabs.requests">📢 Mis pedidos</button>
      <button class="ps-tab" data-tab="inquiries" data-i18n="me.tabs.inquiries">💬 Conversaciones</button>
    </nav>

    <div class="ps-tabpanel" id="panel-profile" hidden>
      <h2 data-i18n="me.profile.h">Perfil de profesional</h2>
      <p data-i18n="me.profile.intro">Si querés ofrecer servicios, completá tu perfil acá.</p>
      <form id="profile-form" class="ps-form">
        <div class="ps-row ps-photo-widget">
          <div id="photo-preview" class="ps-detail__avatar ps-avatar--thumb">👤</div>
          <div class="ps-stack ps-photo-widget__ctrl">
            <label class="ps-btn ps-btn--ghost ps-btn--sm ps-photo-widget__btn" for="photo-input">
              <span id="photo-btn-label" data-i18n="media.upload">Subir foto</span>
            </label>
            <input id="photo-input" type="file" accept="image/jpeg,image/png,image/webp" hidden />
            <button type="button" id="photo-remove" class="ps-btn ps-btn--ghost ps-btn--sm ps-hidden" data-i18n="media.remove">Quitar</button>
            <p id="photo-msg" class="ps-msg" aria-live="polite"></p>
          </div>
        </div>
        <input type="hidden" name="photo" id="photo-key" />
        <label>
          <span data-i18n="me.profile.display_name">Nombre que mostramos</span>
          <input name="displayName" required maxlength="80" />
        </label>
        <label>
          <span data-i18n="me.profile.headline">Frase corta (headline)</span>
          <input name="headline" required maxlength="120" data-i18n-placeholder="me.profile.headline.placeholder" placeholder="Plomero 24h en Asunción" />
        </label>
        <label>
          <span data-i18n="me.profile.phone">Teléfono</span>
          <input name="phone" required data-i18n-placeholder="me.profile.phone.placeholder" placeholder="+595 981 234567" />
        </label>
        <label>
          <span data-i18n="me.profile.whatsapp">WhatsApp (opcional)</span>
          <input name="whatsapp" data-i18n-placeholder="me.profile.whatsapp.placeholder" placeholder="+595 981 234567" />
        </label>
        <label>
          <span data-i18n="me.profile.barrio">Barrio</span>
          <input name="barrio" required data-i18n-placeholder="me.profile.barrio.placeholder" placeholder="Villa Morra" />
        </label>
        <label>
          <span data-i18n="me.profile.bio">Bio</span>
          <textarea name="bio" rows="4" maxlength="2000" data-i18n-placeholder="me.profile.bio.placeholder" placeholder="Contales tu experiencia, herramientas, zonas que cubrís…"></textarea>
        </label>
        <button type="submit" class="ps-btn" data-i18n="common.save">Guardar</button>
        <p id="profile-msg" class="ps-msg" aria-live="polite"></p>
      </form>

      <fieldset class="ps-banner ps-stack ps-notif-fieldset">
        <legend><strong data-i18n="me.notifs.h">Notificaciones</strong></legend>
        <label class="ps-row ps-checkbox-row">
          <input type="checkbox" id="notif-email" />
          <span data-i18n="me.notifs.email">Recibir avisos por email</span>
        </label>
        <p id="notif-msg" class="ps-msg" aria-live="polite"></p>
      </fieldset>
    </div>

    <div class="ps-tabpanel" id="panel-listings" hidden>
      <div class="ps-row" style="justify-content:space-between">
        <h2 data-i18n="me.listings.h">Mis servicios publicados</h2>
        <a id="new-listing" class="ps-btn ps-btn--sm" data-i18n="me.listings.new">+ Nuevo</a>
      </div>
      <div id="my-listings" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-requests" hidden>
      <div class="ps-row" style="justify-content:space-between">
        <h2 data-i18n="me.requests.h">Mis pedidos como cliente</h2>
        <a id="new-request" class="ps-btn ps-btn--sm" data-i18n="me.requests.new">+ Nuevo</a>
      </div>
      <div id="my-requests" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-inquiries" hidden>
      <h2 data-i18n="me.inquiries.h">Conversaciones</h2>
      <div id="my-inquiries" class="ps-cards" aria-busy="true"></div>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, clearToken, categoryLabel, categoryEmoji, formatGs, formatRelativeTime, uploadImage, mediaUrl } from '../lib/api.ts'
    import { t } from '../lib/i18n.ts'

    ;(async () => {
      const base = document.querySelector('.ps-section').dataset.base ?? ''
      const escape = (s) => String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]))

      const token = getToken()
      if (!token) { location.href = `${base}/login/?next=${encodeURIComponent(location.pathname)}`; return }

      document.getElementById('logout').addEventListener('click', () => {
        clearToken()
        location.href = `${base}/`
      })

      document.getElementById('new-listing').href = `${base}/me/listings/new/`
      document.getElementById('new-request').href = `${base}/me/requests/new/`

      let me
      try { me = await apiFetch('/v1/me') }
      catch { clearToken(); location.href = `${base}/login/`; return }
      document.getElementById('me-info').textContent = `${t('me.session_prefix')} ${me.userId.slice(0,8)}…`

      // Tab routing
      const tabs = document.querySelectorAll('.ps-tab')
      const panels = {
        profile: document.getElementById('panel-profile'),
        listings: document.getElementById('panel-listings'),
        requests: document.getElementById('panel-requests'),
        inquiries: document.getElementById('panel-inquiries'),
      }
      const setTab = (name) => {
        for (const tab of tabs) tab.setAttribute('aria-selected', tab.dataset.tab === name ? 'true' : 'false')
        for (const [k, el] of Object.entries(panels)) el.hidden = k !== name
        const url = new URL(location.href)
        url.searchParams.set('tab', name)
        history.replaceState({}, '', url.toString())
      }
      for (const tab of tabs) tab.addEventListener('click', () => setTab(tab.dataset.tab))
      const initial = new URLSearchParams(location.search).get('tab') || 'profile'
      setTab(initial)

      // ---- Profile ----
      let myProfile = null
      try {
        const list = await apiFetch('/v1/specialists')
        myProfile = list.find((s) => s.userId === me.userId) ?? null
      } catch {}
      const pf = document.getElementById('profile-form')
      const photoPreview = document.getElementById('photo-preview')
      const photoInput = document.getElementById('photo-input')
      const photoKey = document.getElementById('photo-key')
      const photoMsg = document.getElementById('photo-msg')
      const photoBtnLabel = document.getElementById('photo-btn-label')
      const photoRemove = document.getElementById('photo-remove')
      const showPhoto = (key) => {
        if (key) {
          photoPreview.classList.add('ps-avatar--photo')
          photoPreview.innerHTML = `<img class="ps-avatar__img" src="${mediaUrl(key)}" alt=""/>`
          photoBtnLabel.textContent = t('media.replace')
          photoRemove.classList.remove('ps-hidden')
        } else {
          photoPreview.classList.remove('ps-avatar--photo')
          photoPreview.textContent = '👤'
          photoBtnLabel.textContent = t('media.upload')
          photoRemove.classList.add('ps-hidden')
        }
      }
      if (myProfile) {
        for (const k of ['displayName','headline','phone','whatsapp','barrio','bio']) {
          if (pf.elements[k] && myProfile[k] != null) pf.elements[k].value = myProfile[k]
        }
        if (myProfile.photo) { photoKey.value = myProfile.photo; showPhoto(myProfile.photo) }
      }
      photoInput.addEventListener('change', async () => {
        const f = photoInput.files?.[0]
        if (!f) return
        photoMsg.textContent = t('media.uploading')
        try {
          const key = await uploadImage(f)
          photoKey.value = key
          showPhoto(key)
          photoMsg.textContent = ''
        } catch (err) { photoMsg.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
        finally { photoInput.value = '' }
      })
      photoRemove.addEventListener('click', () => { photoKey.value = ''; showPhoto('') })

      const pm = document.getElementById('profile-msg')
      pf.addEventListener('submit', async (e) => {
        e.preventDefault()
        pm.textContent = t('common.saving')
        const fd = Object.fromEntries(new FormData(pf))
        if (!fd.photo) fd.photo = null
        try {
          if (myProfile) {
            await apiFetch(`/v1/specialists/${myProfile.id}`, { method: 'PATCH', body: JSON.stringify(fd) })
          } else {
            myProfile = await apiFetch('/v1/specialists', { method: 'POST', body: JSON.stringify(fd) })
          }
          pm.innerHTML = `<span class="ps-msg--ok">${t('me.profile.saved')}</span>`
          refreshListings()
        } catch (err) { pm.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>` }
      })

      // ---- Notifications opt-out ----
      const notifEmail = document.getElementById('notif-email')
      const notifMsg = document.getElementById('notif-msg')
      try {
        const n = await apiFetch('/v1/me/notifications')
        notifEmail.checked = n.emailNotifications !== false
      } catch { notifEmail.checked = true }
      notifEmail.addEventListener('change', async () => {
        notifMsg.textContent = t('common.saving')
        try {
          await apiFetch('/v1/me/notifications', { method: 'PATCH', body: JSON.stringify({ emailNotifications: notifEmail.checked }) })
          notifMsg.innerHTML = `<span class="ps-msg--ok">${t('me.notifs.saved')}</span>`
        } catch (err) { notifMsg.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>` }
      })

      // ---- My listings ----
      const lEl = document.getElementById('my-listings')
      const refreshListings = async () => {
        if (!myProfile) {
          lEl.removeAttribute('aria-busy')
          lEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">👤</span><strong class="ps-empty__title">${t('me.listings.empty_profile.title')}</strong>${t('me.listings.empty_profile.hint')}</p>`
          return
        }
        lEl.setAttribute('aria-busy', 'true')
        try {
          const items = await apiFetch(`/v1/listings?specialist_id=${myProfile.id}`)
          lEl.removeAttribute('aria-busy')
          if (items.length === 0) {
            lEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">📦</span><strong class="ps-empty__title">${t('me.listings.empty.title')}</strong>${t('me.listings.empty.hint')}</p>`
            return
          }
          const priceFrom = t('me.listings.price_from')
          const priceTbd = t('common.price_tbd')
          const editLabel = t('common.edit')
          const deleteLabel = t('common.delete')
          lEl.innerHTML = items.map((l) => `
            <article class="ps-card">
              <div class="ps-row">
                <span class="ps-chip">${categoryEmoji(l.category)} ${categoryLabel(l.category)}</span>
              </div>
              <h3>${escape(l.title)}</h3>
              <p class="ps-card__sub">${l.priceFromGs ? `${priceFrom} ${escape(formatGs(l.priceFromGs))}` : priceTbd}</p>
              <p class="ps-card__body">${escape(l.description.slice(0,160))}${l.description.length>160?'…':''}</p>
              <div class="ps-card__cta">
                <a href="${base}/me/listings/edit/?id=${l.id}">${editLabel}</a>
                <button data-id="${l.id}" class="ps-btn ps-btn--ghost ps-btn--sm js-del">${deleteLabel}</button>
              </div>
            </article>`).join('')
          for (const btn of lEl.querySelectorAll('.js-del')) {
            btn.addEventListener('click', async () => {
              if (!confirm(t('me.listings.confirm_delete'))) return
              await apiFetch(`/v1/listings/${btn.dataset.id}`, { method: 'DELETE' })
              refreshListings()
            })
          }
        } catch (err) { lEl.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }
      }
      refreshListings()

      // ---- My requests ----
      const rEl = document.getElementById('my-requests')
      const refreshRequests = async () => {
        rEl.setAttribute('aria-busy', 'true')
        try {
          // Dedicated endpoint returns ALL my requests (open + closed)
          const mine = await apiFetch('/v1/me/requests')
          rEl.removeAttribute('aria-busy')
          if (mine.length === 0) {
            rEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">📭</span><strong class="ps-empty__title">${t('me.requests.empty.title')}</strong>${t('me.requests.empty.hint')}</p>`
            return
          }
          const statusOpen = t('me.requests.status.open')
          const statusClosed = t('me.requests.status.closed')
          const editLabel = t('common.edit')
          const publicView = t('me.requests.public_view')
          rEl.innerHTML = mine.map((r) => `
            <article class="ps-card ps-card--request">
              <div class="ps-row">
                <span class="ps-chip">${categoryEmoji(r.category)} ${categoryLabel(r.category)}</span>
                <span class="ps-badge">${r.status === 'open' ? statusOpen : statusClosed}</span>
              </div>
              <h3>${escape(r.title)}</h3>
              <p class="ps-card__sub">📍 ${escape(r.barrio)} · 💰 ${escape(formatGs(r.budgetGs))}</p>
              <div class="ps-card__cta">
                <a href="${base}/me/requests/edit/?id=${r.id}">${editLabel}</a>
                <a href="${base}/clients/detail/?id=${r.id}">${publicView}</a>
              </div>
            </article>`).join('')
        } catch (err) { rEl.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }
      }
      refreshRequests()

      // ---- Inquiries ----
      const iEl = document.getElementById('my-inquiries')
      try {
        const items = await apiFetch('/v1/inquiries')
        iEl.removeAttribute('aria-busy')
        if (items.length === 0) {
          iEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">💬</span><strong class="ps-empty__title">${t('me.inquiries.empty.title')}</strong>${t('me.inquiries.empty.hint')}</p>`
        } else {
          const asClient = t('me.inquiries.as_client')
          const asSpec = t('me.inquiries.as_specialist')
          const aboutListing = t('me.inquiries.about_listing')
          const aboutRequest = t('me.inquiries.about_request')
          iEl.innerHTML = items.map((i) => {
            const role = i.clientUserId === me.userId ? asClient : asSpec
            return `
              <a class="ps-card ps-card--mini" href="${base}/me/inquiries/detail/?id=${i.id}">
                <div class="ps-row">
                  <span class="ps-badge ps-badge--neutral">${role}</span>
                  <span class="ps-card__sub">${formatRelativeTime(i.lastMessageAt)}</span>
                </div>
                <p>${i.subjectType === 'listing' ? aboutListing : aboutRequest}</p>
              </a>`
          }).join('')
        }
      } catch (err) { iEl.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }
    })()
  </script>
</Base>
