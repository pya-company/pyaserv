---
import Base from '~/layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Mi panel" active="home">
  <section class="ps-section" data-base={base}>
    <h1>Mi panel</h1>

    <div id="not-logged" class="ps-msg" hidden>
      No estás autenticado. <a id="login-link">Iniciar sesión →</a>
    </div>

    <div id="logged" hidden>
      <p id="me-info" class="ps-msg"></p>
      <button id="logout">Cerrar sesión</button>

      <h2>Mi perfil de profesional</h2>
      <form id="profile-form" class="ps-form">
        <label>Nombre <input name="displayName" required maxlength="80" /></label>
        <label>Headline <input name="headline" required maxlength="120" placeholder="Plomero 24h en Asunción" /></label>
        <label>Teléfono <input name="phone" required placeholder="+595 981 234567" /></label>
        <label>WhatsApp <input name="whatsapp" placeholder="+595 981 234567" /></label>
        <label>Barrio <input name="barrio" required placeholder="Villa Morra" /></label>
        <label>Bio <textarea name="bio" rows="3" maxlength="2000"></textarea></label>
        <button type="submit">Guardar</button>
      </form>
      <p id="profile-msg" class="ps-msg" aria-live="polite"></p>

      <h2>Mis publicaciones</h2>
      <div id="my-listings" aria-busy="true">Cargando…</div>
      <details>
        <summary>Crear publicación</summary>
        <form id="listing-form" class="ps-form">
          <label>Categoría
            <select name="category" id="l-category" required></select>
          </label>
          <label>Título <input name="title" required maxlength="120" /></label>
          <label>Descripción <textarea name="description" rows="3" maxlength="2000"></textarea></label>
          <label>Precio desde (Gs, opcional) <input name="priceFromGs" type="number" min="0" /></label>
          <label>Por
            <select name="priceUnit">
              <option value="">—</option>
              <option value="hour">Hora</option>
              <option value="job">Trabajo</option>
            </select>
          </label>
          <button type="submit">Publicar</button>
        </form>
        <p id="listing-msg" class="ps-msg" aria-live="polite"></p>
      </details>

      <h2>Mis conversaciones</h2>
      <div id="my-inquiries" aria-busy="true">Cargando…</div>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, clearToken, CATEGORIES, categoryLabel } from '../lib/api.ts'

    ;(async () => {
    const root = document.querySelector('.ps-section')
    const base = root.dataset.base ?? ''
    const notLogged = document.getElementById('not-logged')
    const logged = document.getElementById('logged')
    document.getElementById('login-link').href = `${base}/login/`

    const token = getToken()
    if (!token) {
      notLogged.hidden = false
    } else {
      logged.hidden = false
      const meInfo = document.getElementById('me-info')

      document.getElementById('logout').addEventListener('click', () => {
        clearToken()
        location.href = base + '/'
      })

      let me
      try {
        me = await apiFetch('/v1/me')
        meInfo.textContent = `userId: ${me.userId}`
      } catch (err) {
        notLogged.hidden = false
        logged.hidden = true
        return
      }

      // --- profile ---
      const profileForm = document.getElementById('profile-form')
      const profileMsg = document.getElementById('profile-msg')
      let myProfile = null
      try {
        const list = await apiFetch('/v1/specialists')
        myProfile = list.find((s) => s.userId === me.userId) ?? null
      } catch {}
      if (myProfile) {
        for (const k of ['displayName', 'headline', 'phone', 'whatsapp', 'barrio', 'bio']) {
          if (profileForm.elements[k] && myProfile[k] != null) profileForm.elements[k].value = myProfile[k]
        }
      }
      profileForm.addEventListener('submit', async (e) => {
        e.preventDefault()
        profileMsg.textContent = 'Guardando…'
        const fd = Object.fromEntries(new FormData(profileForm))
        try {
          if (myProfile) {
            await apiFetch(`/v1/specialists/${myProfile.id}`, {
              method: 'PATCH',
              body: JSON.stringify(fd),
            })
          } else {
            myProfile = await apiFetch('/v1/specialists', {
              method: 'POST',
              body: JSON.stringify(fd),
            })
          }
          profileMsg.textContent = '✓ Guardado'
          refreshListings()
        } catch (err) {
          profileMsg.textContent = err.message
        }
      })

      // --- listings ---
      const lCat = document.getElementById('l-category')
      for (const c of CATEGORIES) {
        const opt = document.createElement('option')
        opt.value = c.value
        opt.textContent = c.label
        lCat.append(opt)
      }
      const myListings = document.getElementById('my-listings')
      const refreshListings = async () => {
        if (!myProfile) {
          myListings.textContent = 'Primero creá tu perfil arriba.'
          return
        }
        myListings.setAttribute('aria-busy', 'true')
        try {
          const items = await apiFetch(`/v1/listings?specialist_id=${myProfile.id}`)
          myListings.removeAttribute('aria-busy')
          if (items.length === 0) {
            myListings.innerHTML = '<p class="ps-empty">Aún no tenés publicaciones.</p>'
            return
          }
          myListings.innerHTML = items
            .map(
              (l) => `
              <article class="ps-card ps-card--mini">
                <h3>${l.title} <span class="ps-card__sub">${categoryLabel(l.category)}</span></h3>
                <p>${l.description}</p>
                <button data-id="${l.id}" class="ps-listing-del">Eliminar</button>
              </article>`,
            )
            .join('')
          for (const btn of myListings.querySelectorAll('.ps-listing-del')) {
            btn.addEventListener('click', async (e) => {
              if (!confirm('¿Eliminar publicación?')) return
              await apiFetch(`/v1/listings/${e.target.dataset.id}`, { method: 'DELETE' })
              refreshListings()
            })
          }
        } catch (err) {
          myListings.removeAttribute('aria-busy')
          myListings.innerHTML = `<p class="ps-error">${err.message}</p>`
        }
      }
      refreshListings()

      document.getElementById('listing-form').addEventListener('submit', async (e) => {
        e.preventDefault()
        const lm = document.getElementById('listing-msg')
        lm.textContent = 'Publicando…'
        const fd = Object.fromEntries(new FormData(e.target))
        if (fd.priceFromGs) fd.priceFromGs = Number(fd.priceFromGs)
        else delete fd.priceFromGs
        if (!fd.priceUnit) delete fd.priceUnit
        try {
          await apiFetch('/v1/listings', { method: 'POST', body: JSON.stringify(fd) })
          lm.textContent = '✓ Publicado'
          e.target.reset()
          refreshListings()
        } catch (err) {
          lm.textContent = err.message
        }
      })

      // --- inquiries ---
      const inq = document.getElementById('my-inquiries')
      try {
        const items = await apiFetch('/v1/inquiries')
        inq.removeAttribute('aria-busy')
        if (items.length === 0) {
          inq.innerHTML = '<p class="ps-empty">No tenés conversaciones todavía.</p>'
        } else {
          inq.innerHTML = items
            .map(
              (i) => `
              <article class="ps-card ps-card--mini">
                <p>Sobre ${i.subjectType === 'listing' ? 'una publicación' : 'un pedido'}</p>
                <p class="ps-card__sub">${new Date(i.lastMessageAt * 1000).toLocaleString('es-PY')}</p>
              </article>`,
            )
            .join('')
        }
      } catch (err) {
        inq.removeAttribute('aria-busy')
        inq.innerHTML = `<p class="ps-error">${err.message}</p>`
      }
    }
    })()
  </script>
</Base>
