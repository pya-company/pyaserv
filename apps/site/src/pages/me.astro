---
import Base from '~/layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Mi panel" active="me">
  <section class="ps-section" data-base={base}>
    <div class="ps-row" style="justify-content:space-between">
      <h1>Mi panel</h1>
      <button id="logout" class="ps-btn ps-btn--ghost ps-btn--sm">Cerrar sesión</button>
    </div>
    <p id="me-info" class="ps-card__sub"></p>

    <nav class="ps-tabs" role="tablist" aria-label="Secciones">
      <button class="ps-tab" data-tab="profile">👤 Mi perfil</button>
      <button class="ps-tab" data-tab="listings">🛠️ Mis servicios</button>
      <button class="ps-tab" data-tab="requests">📢 Mis pedidos</button>
      <button class="ps-tab" data-tab="inquiries">💬 Conversaciones</button>
    </nav>

    <div class="ps-tabpanel" id="panel-profile" hidden>
      <h2>Perfil de profesional</h2>
      <p>Si querés ofrecer servicios, completá tu perfil acá.</p>
      <form id="profile-form" class="ps-form">
        <label>Nombre que mostramos
          <input name="displayName" required maxlength="80" />
        </label>
        <label>Frase corta (headline)
          <input name="headline" required maxlength="120" placeholder="Plomero 24h en Asunción" />
        </label>
        <label>Teléfono
          <input name="phone" required placeholder="+595 981 234567" />
        </label>
        <label>WhatsApp (opcional)
          <input name="whatsapp" placeholder="+595 981 234567" />
        </label>
        <label>Barrio
          <input name="barrio" required placeholder="Villa Morra" />
        </label>
        <label>Bio
          <textarea name="bio" rows="4" maxlength="2000" placeholder="Contales tu experiencia, herramientas, zonas que cubrís…"></textarea>
        </label>
        <button type="submit" class="ps-btn">Guardar</button>
        <p id="profile-msg" class="ps-msg" aria-live="polite"></p>
      </form>
    </div>

    <div class="ps-tabpanel" id="panel-listings" hidden>
      <div class="ps-row" style="justify-content:space-between">
        <h2>Mis servicios publicados</h2>
        <a id="new-listing" class="ps-btn ps-btn--sm">+ Nuevo</a>
      </div>
      <div id="my-listings" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-requests" hidden>
      <div class="ps-row" style="justify-content:space-between">
        <h2>Mis pedidos como cliente</h2>
        <a id="new-request" class="ps-btn ps-btn--sm">+ Nuevo</a>
      </div>
      <div id="my-requests" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-inquiries" hidden>
      <h2>Conversaciones</h2>
      <div id="my-inquiries" class="ps-cards" aria-busy="true"></div>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, clearToken, categoryLabel, categoryEmoji, formatGs, formatRelativeTime } from '../lib/api.ts'

    ;(async () => {
      const base = document.querySelector('.ps-section').dataset.base ?? ''
      const escape = (s) => String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]))

      const token = getToken()
      if (!token) { location.href = `${base}/login/?next=${encodeURIComponent(location.pathname)}`; return }

      document.getElementById('logout').addEventListener('click', () => {
        clearToken()
        location.href = `${base}/`
      })

      document.getElementById('new-listing').href = `${base}/me/listings/new/`
      document.getElementById('new-request').href = `${base}/me/requests/new/`

      let me
      try { me = await apiFetch('/v1/me') }
      catch { clearToken(); location.href = `${base}/login/`; return }
      document.getElementById('me-info').textContent = `Sesión iniciada · userId ${me.userId.slice(0,8)}…`

      // Tab routing
      const tabs = document.querySelectorAll('.ps-tab')
      const panels = {
        profile: document.getElementById('panel-profile'),
        listings: document.getElementById('panel-listings'),
        requests: document.getElementById('panel-requests'),
        inquiries: document.getElementById('panel-inquiries'),
      }
      const setTab = (name) => {
        for (const t of tabs) t.setAttribute('aria-selected', t.dataset.tab === name ? 'true' : 'false')
        for (const [k, el] of Object.entries(panels)) el.hidden = k !== name
        const url = new URL(location.href)
        url.searchParams.set('tab', name)
        history.replaceState({}, '', url.toString())
      }
      for (const t of tabs) t.addEventListener('click', () => setTab(t.dataset.tab))
      const initial = new URLSearchParams(location.search).get('tab') || 'profile'
      setTab(initial)

      // ---- Profile ----
      let myProfile = null
      try {
        const list = await apiFetch('/v1/specialists')
        myProfile = list.find((s) => s.userId === me.userId) ?? null
      } catch {}
      const pf = document.getElementById('profile-form')
      if (myProfile) {
        for (const k of ['displayName','headline','phone','whatsapp','barrio','bio']) {
          if (pf.elements[k] && myProfile[k] != null) pf.elements[k].value = myProfile[k]
        }
      }
      const pm = document.getElementById('profile-msg')
      pf.addEventListener('submit', async (e) => {
        e.preventDefault()
        pm.textContent = 'Guardando…'
        const fd = Object.fromEntries(new FormData(pf))
        try {
          if (myProfile) {
            await apiFetch(`/v1/specialists/${myProfile.id}`, { method: 'PATCH', body: JSON.stringify(fd) })
          } else {
            myProfile = await apiFetch('/v1/specialists', { method: 'POST', body: JSON.stringify(fd) })
          }
          pm.innerHTML = '<span class="ps-msg--ok">✓ Perfil guardado</span>'
          refreshListings()
        } catch (err) { pm.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
      })

      // ---- My listings ----
      const lEl = document.getElementById('my-listings')
      const refreshListings = async () => {
        if (!myProfile) {
          lEl.removeAttribute('aria-busy')
          lEl.innerHTML = '<p class="ps-empty"><span class="ps-empty__icon">👤</span><strong class="ps-empty__title">Primero creá tu perfil</strong>Completá la pestaña «Mi perfil» antes de publicar.</p>'
          return
        }
        lEl.setAttribute('aria-busy', 'true')
        try {
          const items = await apiFetch(`/v1/listings?specialist_id=${myProfile.id}`)
          lEl.removeAttribute('aria-busy')
          if (items.length === 0) {
            lEl.innerHTML = '<p class="ps-empty"><span class="ps-empty__icon">📦</span><strong class="ps-empty__title">No publicaste servicios todavía</strong>Tocá «+ Nuevo» arriba para empezar.</p>'
            return
          }
          lEl.innerHTML = items.map((l) => `
            <article class="ps-card">
              <div class="ps-row">
                <span class="ps-chip">${categoryEmoji(l.category)} ${categoryLabel(l.category)}</span>
              </div>
              <h3>${escape(l.title)}</h3>
              <p class="ps-card__sub">${l.priceFromGs ? `desde ${escape(formatGs(l.priceFromGs))}` : 'A coordinar'}</p>
              <p class="ps-card__body">${escape(l.description.slice(0,160))}${l.description.length>160?'…':''}</p>
              <div class="ps-card__cta">
                <a href="${base}/me/listings/edit/?id=${l.id}">Editar</a>
                <button data-id="${l.id}" class="ps-btn ps-btn--ghost ps-btn--sm js-del">Eliminar</button>
              </div>
            </article>`).join('')
          for (const btn of lEl.querySelectorAll('.js-del')) {
            btn.addEventListener('click', async () => {
              if (!confirm('¿Eliminar este servicio?')) return
              await apiFetch(`/v1/listings/${btn.dataset.id}`, { method: 'DELETE' })
              refreshListings()
            })
          }
        } catch (err) { lEl.innerHTML = `<p class="ps-error">${escape(err.message)}</p>` }
      }
      refreshListings()

      // ---- My requests ----
      const rEl = document.getElementById('my-requests')
      const refreshRequests = async () => {
        rEl.setAttribute('aria-busy', 'true')
        try {
          // server endpoint lists "open" by default; we need ALL mine — fetch open + closed separately
          const open = await apiFetch('/v1/requests')
          const mine = open.filter((r) => r.clientId === me.userId)
          rEl.removeAttribute('aria-busy')
          if (mine.length === 0) {
            rEl.innerHTML = '<p class="ps-empty"><span class="ps-empty__icon">📭</span><strong class="ps-empty__title">No publicaste pedidos abiertos</strong>Si necesitás algo concreto, tocá «+ Nuevo».</p>'
            return
          }
          rEl.innerHTML = mine.map((r) => `
            <article class="ps-card ps-card--request">
              <div class="ps-row">
                <span class="ps-chip">${categoryEmoji(r.category)} ${categoryLabel(r.category)}</span>
                <span class="ps-badge">${r.status === 'open' ? 'Abierto' : 'Cerrado'}</span>
              </div>
              <h3>${escape(r.title)}</h3>
              <p class="ps-card__sub">📍 ${escape(r.barrio)} · 💰 ${escape(formatGs(r.budgetGs))}</p>
              <div class="ps-card__cta">
                <a href="${base}/me/requests/edit/?id=${r.id}">Editar</a>
                <a href="${base}/clients/detail/?id=${r.id}">Vista pública →</a>
              </div>
            </article>`).join('')
        } catch (err) { rEl.innerHTML = `<p class="ps-error">${escape(err.message)}</p>` }
      }
      refreshRequests()

      // ---- Inquiries ----
      const iEl = document.getElementById('my-inquiries')
      try {
        const items = await apiFetch('/v1/inquiries')
        iEl.removeAttribute('aria-busy')
        if (items.length === 0) {
          iEl.innerHTML = '<p class="ps-empty"><span class="ps-empty__icon">💬</span><strong class="ps-empty__title">Sin conversaciones todavía</strong>Cuando contactes a alguien o te contacten, aparecerán acá.</p>'
        } else {
          iEl.innerHTML = items.map((i) => {
            const role = i.clientUserId === me.userId ? 'Como cliente' : 'Como profesional'
            return `
              <a class="ps-card ps-card--mini" href="${base}/me/inquiries/detail/?id=${i.id}">
                <div class="ps-row">
                  <span class="ps-badge ps-badge--neutral">${role}</span>
                  <span class="ps-card__sub">${formatRelativeTime(i.lastMessageAt)}</span>
                </div>
                <p>Sobre ${i.subjectType === 'listing' ? 'un servicio' : 'un pedido'}</p>
              </a>`
          }).join('')
        }
      } catch (err) { iEl.innerHTML = `<p class="ps-error">${escape(err.message)}</p>` }
    })()
  </script>
</Base>
