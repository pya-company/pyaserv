---
import Base from '~/layouts/Base.astro'
import BarriosDatalist from '~/components/BarriosDatalist.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Mi panel" titleKey="me.title" active="me">
  <section class="ps-section" data-base={base}>
    <div class="ps-row" style="justify-content:space-between">
      <h1 data-i18n="me.heading">Mi panel</h1>
      <button id="logout" class="ps-btn ps-btn--ghost ps-btn--sm" data-i18n="me.logout">Cerrar sesión</button>
    </div>
    <!-- Reserve one-line height so the tabs strip + form below don't jump
         down when JS later writes "Sesión: <userId>…" into this paragraph. -->
    <p id="me-info" class="ps-card__sub" style="min-height:1.25rem"></p>

    <div class="ps-tabs" role="tablist" data-i18n-aria="me.tabs.aria" aria-label="Secciones">
      <button class="ps-tab" role="tab" id="tab-profile" aria-controls="panel-profile" data-tab="profile" data-i18n="me.tabs.profile">👤 Mi perfil</button>
      <button class="ps-tab" role="tab" id="tab-listings" aria-controls="panel-listings" data-tab="listings" data-i18n="me.tabs.listings">🛠️ Mis servicios</button>
      <button class="ps-tab" role="tab" id="tab-requests" aria-controls="panel-requests" data-tab="requests" data-i18n="me.tabs.requests">📢 Mis pedidos</button>
      <button class="ps-tab" role="tab" id="tab-inquiries" aria-controls="panel-inquiries" data-tab="inquiries" data-i18n="me.tabs.inquiries">💬 Conversaciones</button>
      <button class="ps-tab" role="tab" id="tab-stats" aria-controls="panel-stats" data-tab="stats" data-i18n="me.tabs.stats">📊 Estadísticas</button>
    </div>

    <!-- Visibility is driven by html[data-me-tab=<name>] from bootstrap.js
         (set pre-paint from ?tab=X). Each panel is rendered in SSR; CSS
         hides the non-active ones on the first frame — no JS-driven swap,
         no footer jump on deep-link reload. JS tab clicks update the
         attribute too; no need for the per-panel `hidden` attribute. -->
    <div class="ps-tabpanel" id="panel-profile" role="tabpanel" aria-labelledby="tab-profile">
      <h2 data-i18n="me.profile.h">Perfil de profesional</h2>
      <p data-i18n="me.profile.intro">Si querés ofrecer servicios, completá tu perfil acá.</p>
      <!-- Always rendered at 0% so the bar's height + label line are reserved.
           JS just updates the % once /v1/me returns. -->
      <div id="completeness" class="ps-completeness" aria-live="polite">
        <div class="ps-completeness__bar"><div class="ps-completeness__fill" id="completeness-fill" style="width:0%"></div></div>
        <p class="ps-card__sub"><span id="completeness-label" data-i18n="me.profile.completeness.empty">Perfil completo: 0%</span></p>
      </div>
      <form id="profile-form" class="ps-form">
        <div class="ps-row ps-photo-widget">
          <div id="photo-preview" class="ps-detail__avatar ps-avatar--thumb">👤</div>
          <div class="ps-stack ps-photo-widget__ctrl">
            <label class="ps-btn ps-btn--ghost ps-btn--sm ps-photo-widget__btn" for="photo-input">
              <span id="photo-btn-label" data-i18n="media.upload">Subir foto</span>
            </label>
            <input id="photo-input" type="file" accept="image/jpeg,image/png,image/webp" hidden />
            <button type="button" id="photo-remove" class="ps-btn ps-btn--ghost ps-btn--sm ps-hidden" data-i18n="media.remove">Quitar</button>
            <p id="photo-msg" class="ps-msg" aria-live="polite"></p>
          </div>
        </div>
        <input type="hidden" name="photo" id="photo-key" />
        <label>
          <span data-i18n="me.profile.display_name">Nombre que mostramos</span>
          <input name="displayName" required maxlength="80" autocomplete="name" />
        </label>
        <label>
          <span data-i18n="me.profile.headline">Frase corta (headline)</span>
          <input name="headline" required maxlength="120" data-i18n-placeholder="me.profile.headline.placeholder" placeholder="Plomero 24h en Asunción" />
        </label>
        <label>
          <span data-i18n="me.profile.phone">Teléfono</span>
          <input name="phone" required type="tel" autocomplete="tel" data-i18n-placeholder="me.profile.phone.placeholder" placeholder="+595 981 234567" />
        </label>
        <label>
          <span data-i18n="me.profile.whatsapp">WhatsApp (opcional)</span>
          <input name="whatsapp" type="tel" autocomplete="tel" data-i18n-placeholder="me.profile.whatsapp.placeholder" placeholder="+595 981 234567" />
        </label>
        <label>
          <span data-i18n="me.profile.barrio">Barrio</span>
          <input name="barrio" required list="ps-barrios" data-i18n-placeholder="me.profile.barrio.placeholder" placeholder="Villa Morra" />
        </label>

        <div class="ps-row" style="align-items:center">
          <button type="button" id="geoloc-btn" class="ps-btn ps-btn--ghost ps-btn--sm" data-i18n="me.profile.geoloc">Usar mi ubicación</button>
          <span id="geoloc-status" class="ps-card__sub" aria-live="polite"></span>
        </div>
        <input type="hidden" name="lat" id="profile-lat" />
        <input type="hidden" name="lng" id="profile-lng" />

        <label>
          <span data-i18n="me.profile.bio">Bio</span>
          <textarea name="bio" rows="4" maxlength="2000" data-i18n-placeholder="me.profile.bio.placeholder" placeholder="Contales tu experiencia, herramientas, zonas que cubrís…"></textarea>
        </label>
        <button type="submit" class="ps-btn" data-i18n="common.save">Guardar</button>
        <p id="profile-msg" class="ps-msg" role="alert"></p>
      </form>

      <fieldset class="ps-banner ps-stack ps-notif-fieldset">
        <legend><strong data-i18n="me.notifs.h">Notificaciones</strong></legend>
        <label class="ps-row ps-checkbox-row">
          <input type="checkbox" id="notif-email" />
          <span data-i18n="me.notifs.email">Recibir avisos por email</span>
        </label>
        <p id="notif-msg" class="ps-msg" aria-live="polite"></p>
      </fieldset>

      <fieldset class="ps-banner ps-stack">
        <legend><strong>
          <span lang="es">Seguridad — Passkeys</span>
          <span lang="en">Security — Passkeys</span>
        </strong></legend>
        <p class="ps-card__sub">
          <span lang="es">Iniciá sesión con Touch ID, Face ID, Windows Hello o el bloqueo de tu teléfono — sin código por email.</span>
          <span lang="en">Sign in with Touch ID, Face ID, Windows Hello or your phone's screen lock — no email code needed.</span>
        </p>
        <!-- Skeleton reserves 3rem (single row height) so the form below
             doesn't shift when GET /api/auth/passkeys returns. JS swaps the
             content + removes the data-skeleton attr on first paint. -->
        <div id="passkey-list" class="ps-stack" aria-live="polite" data-skeleton="1" style="min-height:3rem">
          <p class="ps-card__sub" style="margin:0">
            <span lang="es">Cargando passkeys…</span>
            <span lang="en">Loading passkeys…</span>
          </p>
        </div>
        <button type="button" id="passkey-add" class="ps-btn ps-btn--sm">
          <span lang="es">+ Agregar passkey</span>
          <span lang="en">+ Add passkey</span>
        </button>
        <p id="passkey-msg" class="ps-msg" role="alert" style="min-height:1.5rem"></p>
      </fieldset>
    </div>

    <div class="ps-tabpanel" id="panel-listings" role="tabpanel" aria-labelledby="tab-listings">
      <div class="ps-row" style="justify-content:space-between">
        <h2 data-i18n="me.listings.h">Mis servicios publicados</h2>
        <a id="new-listing" class="ps-btn ps-btn--sm" data-i18n="me.listings.new">+ Nuevo</a>
      </div>
      <div id="my-listings" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-requests" role="tabpanel" aria-labelledby="tab-requests">
      <div class="ps-row" style="justify-content:space-between">
        <h2 data-i18n="me.requests.h">Mis pedidos como cliente</h2>
        <a id="new-request" class="ps-btn ps-btn--sm" data-i18n="me.requests.new">+ Nuevo</a>
      </div>
      <div id="my-requests" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-inquiries" role="tabpanel" aria-labelledby="tab-inquiries">
      <h2 data-i18n="me.inquiries.h">Conversaciones</h2>
      <div id="my-inquiries" class="ps-cards" aria-busy="true"></div>
    </div>

    <div class="ps-tabpanel" id="panel-stats" role="tabpanel" aria-labelledby="tab-stats">
      <h2 data-i18n="me.stats.h">Estadísticas</h2>
      <p id="stats-msg" class="ps-msg" data-i18n="me.stats.intro">Métricas de tu perfil — últimos 30 días.</p>
      <!-- aria-busy reserves a min-height via CSS so the footer doesn't jump
           when /v1/analytics/me resolves and the 5 stat cards inject. -->
      <div id="stats-grid" class="ps-stats-grid" aria-busy="true"></div>
    </div>
  </section>

  <BarriosDatalist />

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, clearToken, categoryLabel, categoryEmoji, formatGs, formatRelativeTime, uploadImage, mediaUrl } from '../lib/api.ts'
    import { interp, t } from '../lib/i18n.ts'
    import { completenessPct, snapshotFromForm } from '../features/me/completeness.ts'
    import { escapeHtml } from '../features/me/sanitize.ts'
    import { enrollPasskey } from '../features/passkey/client.ts'
    import { passkeySupported } from '../features/passkey/platform.ts'

    // ClientRouter swaps body — module scripts re-execute, but we still
    // route through astro:page-load so we get consistent re-init on both
    // the initial paint AND every subsequent in-page navigation back to /me/.
    // The function guards against firing on the wrong route.
    const initMePage = async () => {
      const section = document.querySelector('.ps-section[data-base]')
      if (!section || !location.pathname.endsWith('/me/')) return
      // Prevent double-init when both module evaluation and astro:page-load
      // fire on the initial paint.
      if (section.dataset.meInitialized === '1') return
      section.dataset.meInitialized = '1'

      const base = section.dataset.base ?? ''
      const escape = escapeHtml

      const token = getToken()
      if (!token) { location.href = `${base}/login/?next=${encodeURIComponent(location.pathname)}`; return }

      document.getElementById('logout').addEventListener('click', () => {
        clearToken()
        location.href = `${base}/`
      })

      document.getElementById('new-listing').href = `${base}/me/listings/new/`
      document.getElementById('new-request').href = `${base}/me/requests/new/`

      let me
      try { me = await apiFetch('/v1/me') }
      catch { clearToken(); location.href = `${base}/login/`; return }
      document.getElementById('me-info').textContent = `${t('me.session_prefix')} ${me.userId.slice(0,8)}…`

      // Tab routing
      const tabs = document.querySelectorAll('.ps-tab')
      const panels = {
        profile: document.getElementById('panel-profile'),
        listings: document.getElementById('panel-listings'),
        requests: document.getElementById('panel-requests'),
        inquiries: document.getElementById('panel-inquiries'),
        stats: document.getElementById('panel-stats'),
      }
      const tabsArr = Array.from(tabs)
      const setTab = (name, focusTab = false) => {
        for (const tab of tabs) {
          const selected = tab.dataset.tab === name
          tab.setAttribute('aria-selected', selected ? 'true' : 'false')
          tab.setAttribute('tabindex', selected ? '0' : '-1')
          if (selected && focusTab) tab.focus()
        }
        // Drive panel visibility via html[data-me-tab=…] (CSS handles display).
        // The `hidden` attribute is gone from panel markup so CSS alone wins —
        // same mechanism as the pre-paint bootstrap.js path.
        document.documentElement.dataset.meTab = name
        const url = new URL(location.href)
        url.searchParams.set('tab', name)
        history.replaceState({}, '', url.toString())
      }
      for (const tab of tabs) tab.addEventListener('click', () => setTab(tab.dataset.tab))
      // Arrow-key navigation per WAI-ARIA Authoring Practices tab pattern.
      for (const tab of tabs) tab.addEventListener('keydown', (e) => {
        const i = tabsArr.indexOf(e.currentTarget)
        if (e.key === 'ArrowRight') { e.preventDefault(); setTab(tabsArr[(i + 1) % tabsArr.length].dataset.tab, true) }
        else if (e.key === 'ArrowLeft') { e.preventDefault(); setTab(tabsArr[(i - 1 + tabsArr.length) % tabsArr.length].dataset.tab, true) }
        else if (e.key === 'Home') { e.preventDefault(); setTab(tabsArr[0].dataset.tab, true) }
        else if (e.key === 'End') { e.preventDefault(); setTab(tabsArr[tabsArr.length - 1].dataset.tab, true) }
      })
      const initial = new URLSearchParams(location.search).get('tab') || 'profile'
      setTab(initial)

      // ---- Profile ----
      let myProfile = null
      try {
        const list = await apiFetch('/v1/specialists')
        myProfile = list.find((s) => s.userId === me.userId) ?? null
      } catch {}
      const pf = document.getElementById('profile-form')
      const photoPreview = document.getElementById('photo-preview')
      const photoInput = document.getElementById('photo-input')
      const photoKey = document.getElementById('photo-key')
      const photoMsg = document.getElementById('photo-msg')
      const photoBtnLabel = document.getElementById('photo-btn-label')
      const photoRemove = document.getElementById('photo-remove')
      const showPhoto = (key) => {
        if (key) {
          photoPreview.classList.add('ps-avatar--photo')
          photoPreview.innerHTML = `<img class="ps-avatar__img" src="${mediaUrl(key)}" alt=""/>`
          photoBtnLabel.textContent = t('media.replace')
          photoRemove.classList.remove('ps-hidden')
        } else {
          photoPreview.classList.remove('ps-avatar--photo')
          photoPreview.textContent = '👤'
          photoBtnLabel.textContent = t('media.upload')
          photoRemove.classList.add('ps-hidden')
        }
      }
      if (myProfile) {
        for (const k of ['displayName','headline','phone','whatsapp','barrio','bio']) {
          if (pf.elements[k] && myProfile[k] != null) pf.elements[k].value = myProfile[k]
        }
        if (myProfile.photo) { photoKey.value = myProfile.photo; showPhoto(myProfile.photo) }
        if (myProfile.lat != null) pf.elements.lat.value = myProfile.lat
        if (myProfile.lng != null) pf.elements.lng.value = myProfile.lng
      }

      // Geolocation
      const geoBtn = document.getElementById('geoloc-btn')
      const geoStatus = document.getElementById('geoloc-status')
      const profileLat = document.getElementById('profile-lat')
      const profileLng = document.getElementById('profile-lng')
      const updateGeoStatus = () => {
        if (profileLat.value && profileLng.value) {
          geoStatus.textContent = `📍 ${(+profileLat.value).toFixed(4)}, ${(+profileLng.value).toFixed(4)}`
        }
      }
      updateGeoStatus()
      geoBtn.addEventListener('click', () => {
        if (!navigator.geolocation) { geoStatus.textContent = t('me.profile.geoloc.unavailable'); return }
        geoStatus.textContent = t('me.profile.geoloc.locating')
        navigator.geolocation.getCurrentPosition(
          (pos) => {
            profileLat.value = String(pos.coords.latitude)
            profileLng.value = String(pos.coords.longitude)
            updateGeoStatus()
          },
          () => { geoStatus.textContent = t('me.profile.geoloc.denied') },
          { enableHighAccuracy: false, timeout: 8000, maximumAge: 60000 },
        )
      })
      photoInput.addEventListener('change', async () => {
        const f = photoInput.files?.[0]
        if (!f) return
        photoMsg.textContent = t('media.uploading')
        try {
          const key = await uploadImage(f)
          photoKey.value = key
          showPhoto(key)
          photoMsg.textContent = ''
        } catch (err) { photoMsg.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
        finally { photoInput.value = '' }
      })
      photoRemove.addEventListener('click', () => { photoKey.value = ''; showPhoto('') })

      const pm = document.getElementById('profile-msg')
      pf.addEventListener('submit', async (e) => {
        e.preventDefault()
        pm.textContent = t('common.saving')
        const fd = Object.fromEntries(new FormData(pf))
        if (!fd.photo) fd.photo = null
        fd.lat = fd.lat ? Number(fd.lat) : null
        fd.lng = fd.lng ? Number(fd.lng) : null
        try {
          if (myProfile) {
            await apiFetch(`/v1/specialists/${myProfile.id}`, { method: 'PATCH', body: JSON.stringify(fd) })
          } else {
            myProfile = await apiFetch('/v1/specialists', { method: 'POST', body: JSON.stringify(fd) })
          }
          pm.innerHTML = `<span class="ps-msg--ok">${t('me.profile.saved')}</span>`
          refreshListings()
        } catch (err) { pm.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>` }
      })

      // ---- Profile completeness meter ----
      const completenessEl = document.getElementById('completeness')
      const completenessFill = document.getElementById('completeness-fill')
      const completenessLabel = document.getElementById('completeness-label')
      const computeCompleteness = () => {
        const pct = completenessPct(snapshotFromForm(pf, photoKey.value || null))
        completenessFill.style.width = pct + '%'
        completenessLabel.textContent = interp(t('me.profile.completeness'), { pct })
      }
      pf.addEventListener('input', computeCompleteness)
      photoInput.addEventListener('change', () => setTimeout(computeCompleteness, 50))
      photoRemove.addEventListener('click', () => setTimeout(computeCompleteness, 50))
      computeCompleteness()

      // ---- Passkeys (security section) ----
      const passkeyList = document.getElementById('passkey-list')
      const passkeyAdd = document.getElementById('passkey-add')
      const passkeyMsg = document.getElementById('passkey-msg')
      const renderPasskeys = (items) => {
        // Drop the skeleton marker so post-FCP mutation observers don't
        // flag this region as a content change (and so the layout is
        // committed to the rendered list height).
        passkeyList.removeAttribute('data-skeleton')
        if (!items.length) {
          passkeyList.innerHTML = `<p class="ps-card__sub">No hay passkeys guardadas. Agregá una para iniciar sesión sin código.</p>`
          return
        }
        passkeyList.innerHTML = items.map((p) => `
          <div class="ps-row" style="justify-content:space-between;align-items:center">
            <div>
              <strong>${escape(p.label || 'Passkey')}</strong>
              <p class="ps-card__sub" style="margin:0">${formatRelativeTime(p.createdAt)}</p>
            </div>
            <button type="button" class="ps-btn ps-btn--ghost ps-btn--sm js-pk-delete" data-id="${escape(p.credentialId)}" aria-label="Eliminar passkey">×</button>
          </div>
        `).join('')
        for (const btn of passkeyList.querySelectorAll('.js-pk-delete')) {
          btn.addEventListener('click', async () => {
            passkeyMsg.textContent = ''
            try {
              await apiFetch(`/api/auth/passkeys/${btn.dataset.id}`, { method: 'DELETE' })
              await refreshPasskeys()
            } catch (err) {
              passkeyMsg.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>`
            }
          })
        }
      }
      const refreshPasskeys = async () => {
        try {
          // Backend returns { items: [{credentialId, label, createdAt, lastUsedAt}] }.
          // apiFetch only unwraps `data` envelopes; this one keeps `items` at root.
          const body = await apiFetch('/api/auth/passkeys')
          renderPasskeys(body?.items || [])
        } catch { passkeyList.innerHTML = '' }
      }
      passkeyAdd.addEventListener('click', async () => {
        if (!passkeySupported()) {
          passkeyMsg.innerHTML = `<span class="ps-error">Tu navegador no soporta passkeys.</span>`
          return
        }
        passkeyMsg.textContent = t('common.saving')
        const r = await enrollPasskey(apiFetch)
        if (r === 'ok') {
          passkeyMsg.innerHTML = `<span class="ps-msg--ok">Passkey guardada.</span>`
          await refreshPasskeys()
        } else if (r === 'cancelled') {
          passkeyMsg.textContent = ''
        } else {
          passkeyMsg.innerHTML = `<span class="ps-error">No se pudo guardar la passkey.</span>`
        }
      })
      // Hide the Add button if the browser can't do passkeys at all.
      if (!passkeySupported()) passkeyAdd.disabled = true
      refreshPasskeys()

      // ---- Notifications opt-out ----
      const notifEmail = document.getElementById('notif-email')
      const notifMsg = document.getElementById('notif-msg')
      try {
        const n = await apiFetch('/v1/me/notifications')
        notifEmail.checked = n.emailNotifications !== false
      } catch { notifEmail.checked = true }
      notifEmail.addEventListener('change', async () => {
        notifMsg.textContent = t('common.saving')
        try {
          await apiFetch('/v1/me/notifications', { method: 'PATCH', body: JSON.stringify({ emailNotifications: notifEmail.checked }) })
          notifMsg.innerHTML = `<span class="ps-msg--ok">${t('me.notifs.saved')}</span>`
        } catch (err) { notifMsg.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>` }
      })

      // ---- My listings ----
      const lEl = document.getElementById('my-listings')
      const refreshListings = async () => {
        if (!myProfile) {
          lEl.removeAttribute('aria-busy')
          lEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">👤</span><strong class="ps-empty__title">${t('me.listings.empty_profile.title')}</strong><span class="ps-empty__hint">${t('me.listings.empty_profile.hint')}</span></p>`
          return
        }
        lEl.setAttribute('aria-busy', 'true')
        try {
          const items = await apiFetch(`/v1/listings?specialist_id=${myProfile.id}`)
          lEl.removeAttribute('aria-busy')
          if (items.length === 0) {
            lEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">📦</span><strong class="ps-empty__title">${t('me.listings.empty.title')}</strong><span class="ps-empty__hint">${t('me.listings.empty.hint')}</span></p>`
            return
          }
          const priceFrom = t('me.listings.price_from')
          const priceTbd = t('common.price_tbd')
          const editLabel = t('common.edit')
          const deleteLabel = t('common.delete')
          lEl.innerHTML = items.map((l) => `
            <article class="ps-card">
              <div class="ps-row">
                <span class="ps-chip">${categoryEmoji(l.category)} ${categoryLabel(l.category)}</span>
              </div>
              <h3>${escape(l.title)}</h3>
              <p class="ps-card__sub">${l.priceFromGs ? `${priceFrom} ${escape(formatGs(l.priceFromGs))}` : priceTbd}</p>
              <p class="ps-card__body">${escape(l.description.slice(0,160))}${l.description.length>160?'…':''}</p>
              <div class="ps-card__cta">
                <a href="${base}/me/listings/edit/?id=${l.id}">${editLabel}</a>
                <button data-id="${l.id}" class="ps-btn ps-btn--ghost ps-btn--sm js-del">${deleteLabel}</button>
              </div>
            </article>`).join('')
          for (const btn of lEl.querySelectorAll('.js-del')) {
            btn.addEventListener('click', async () => {
              if (!confirm(t('me.listings.confirm_delete'))) return
              await apiFetch(`/v1/listings/${btn.dataset.id}`, { method: 'DELETE' })
              refreshListings()
            })
          }
        } catch (err) { lEl.removeAttribute('aria-busy'); lEl.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }
      }
      refreshListings()

      // ---- My requests ----
      const rEl = document.getElementById('my-requests')
      const refreshRequests = async () => {
        rEl.setAttribute('aria-busy', 'true')
        try {
          // Dedicated endpoint returns ALL my requests (open + closed)
          const mine = await apiFetch('/v1/me/requests')
          rEl.removeAttribute('aria-busy')
          if (mine.length === 0) {
            rEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">📭</span><strong class="ps-empty__title">${t('me.requests.empty.title')}</strong><span class="ps-empty__hint">${t('me.requests.empty.hint')}</span></p>`
            return
          }
          const statusOpen = t('me.requests.status.open')
          const statusClosed = t('me.requests.status.closed')
          const editLabel = t('common.edit')
          const publicView = t('me.requests.public_view')
          rEl.innerHTML = mine.map((r) => `
            <article class="ps-card ps-card--request">
              <div class="ps-row">
                <span class="ps-chip">${categoryEmoji(r.category)} ${categoryLabel(r.category)}</span>
                <span class="ps-badge">${r.status === 'open' ? statusOpen : statusClosed}</span>
              </div>
              <h3>${escape(r.title)}</h3>
              <p class="ps-card__sub">📍 ${escape(r.barrio)} · 💰 ${escape(formatGs(r.budgetGs))}</p>
              <div class="ps-card__cta">
                <a href="${base}/me/requests/edit/?id=${r.id}">${editLabel}</a>
                <a href="${base}/clients/${r.id}/">${publicView}</a>
              </div>
            </article>`).join('')
        } catch (err) { rEl.removeAttribute('aria-busy'); rEl.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }
      }
      refreshRequests()

      // ---- Inquiries ----
      const iEl = document.getElementById('my-inquiries')
      try {
        const items = await apiFetch('/v1/inquiries')
        iEl.removeAttribute('aria-busy')
        if (items.length === 0) {
          iEl.innerHTML = `<p class="ps-empty"><span class="ps-empty__icon">💬</span><strong class="ps-empty__title">${t('me.inquiries.empty.title')}</strong><span class="ps-empty__hint">${t('me.inquiries.empty.hint')}</span></p>`
        } else {
          const asClient = t('me.inquiries.as_client')
          const asSpec = t('me.inquiries.as_specialist')
          const aboutListing = t('me.inquiries.about_listing')
          const aboutRequest = t('me.inquiries.about_request')
          iEl.innerHTML = items.map((i) => {
            const role = i.clientUserId === me.userId ? asClient : asSpec
            return `
              <a class="ps-card ps-card--mini" href="${base}/me/inquiries/detail/?id=${i.id}">
                <div class="ps-row">
                  <span class="ps-badge ps-badge--neutral">${role}</span>
                  <span class="ps-card__sub">${formatRelativeTime(i.lastMessageAt)}</span>
                </div>
                <p>${i.subjectType === 'listing' ? aboutListing : aboutRequest}</p>
              </a>`
          }).join('')
        }
      } catch (err) { iEl.removeAttribute('aria-busy'); iEl.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }

      // ---- Stats ----
      const statsGrid = document.getElementById('stats-grid')
      const statsMsg = document.getElementById('stats-msg')
      try {
        const stats = await apiFetch('/v1/analytics/me')
        statsGrid.removeAttribute('aria-busy')
        if (!stats) {
          statsMsg.textContent = t('me.stats.empty')
          statsGrid.innerHTML = ''
        } else {
          const card = (label, value) => `<div class="ps-stat-card"><div class="ps-stat-card__value">${value}</div><div class="ps-stat-card__label">${label}</div></div>`
          statsGrid.innerHTML = [
            card(t('me.stats.profile_view'), stats.last30d.profileView),
            card(t('me.stats.phone_click'), stats.last30d.phoneClick),
            card(t('me.stats.whatsapp_click'), stats.last30d.whatsappClick),
            card(t('me.stats.inquiries'), stats.funnel.inquiries),
            card(t('me.stats.completed'), stats.funnel.completed),
          ].join('')
        }
      } catch (err) { statsGrid.removeAttribute('aria-busy'); statsGrid.innerHTML = `<p class="ps-error">${escape(err.message || t('error.network'))}</p>` }
    }

    // astro:page-load fires on initial paint AND after every ClientRouter
    // swap. Both /me/ on first load and /me/ revisited get a fresh init.
    document.addEventListener('astro:page-load', () => { void initMePage() })
  </script>
</Base>
