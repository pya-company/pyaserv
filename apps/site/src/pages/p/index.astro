---
import Base from '~/layouts/Base.astro'
import '~/styles/docs.css'
---
<Base title="Perfil profesional" active="specialists" description="Perfil público de profesional en PyaServ">
  <div id="profile-root">
    <div class="ps-profile-wrap">
      <div class="ps-profile-cover" id="profile-cover"></div>
      <div class="ps-profile-header">
        <div class="ps-profile-avatar" id="profile-avatar">⬤</div>
        <h1 class="ps-profile-name">
          <!-- data-i18n hydration replaces this with the locale-specific string.
               No dual-span pattern because the test asserts textContent (not
               innerText) and would see every locale variant concatenated. -->
          <span id="profile-name" data-i18n="specialist.public.loading"></span>
          <span class="ps-profile-tier" data-tier="aprendiz" id="profile-tier" hidden></span>
        </h1>
        <p class="ps-profile-meta" id="profile-meta"></p>
        <div class="ps-profile-stats" id="profile-stats"></div>
      </div>
      <div class="ps-profile-cta" id="profile-cta" hidden>
        <a href="#" id="profile-wa-link">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2a9.86 9.86 0 0 0-8.49 14.78L2 22l5.36-1.5a9.83 9.83 0 0 0 4.68 1.2h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.91-7.01Z"/>
          </svg>
          <span data-i18n="specialist.public.contact_whatsapp"></span>
        </a>
      </div>

      <section class="ps-profile-section" id="bio-section" hidden>
        <h3 data-i18n="specialist.public.about"></h3>
        <p id="profile-bio"></p>
      </section>

      <section class="ps-profile-section" id="services-section" hidden>
        <h3 data-i18n="specialist.public.services"></h3>
        <ul class="ps-profile-services" id="services-list"></ul>
      </section>

      <section class="ps-profile-section" id="areas-section" hidden>
        <h3 data-i18n="specialist.public.work_areas"></h3>
        <div class="ps-profile-areas" id="areas-list"></div>
      </section>

      <section class="ps-profile-section" id="portfolio-section" hidden>
        <h3 data-i18n="specialist.public.jobs"></h3>
        <div class="ps-profile-portfolio" id="portfolio-grid"></div>
      </section>

      <section class="ps-profile-section" id="badges-section" hidden>
        <h3 data-i18n="specialist.public.badges"></h3>
        <div class="ps-profile-badges" id="badges-list"></div>
      </section>
    </div>

    <div id="profile-error" hidden style="text-align:center;padding:80px 16px;color:#6b7280;">
      <h2 class="ps-profile-error__title" data-i18n="specialist.public.not_found_title"></h2>
      <p data-i18n="specialist.public.not_found_body"></p>
      <p style="margin-top: 16px;"><a href="/specialists/" style="color:#4f46e5;" data-i18n="specialist.public.see_all"></a></p>
    </div>

    <div id="profile-no-slug" hidden style="text-align:center;padding:80px 16px;color:#6b7280;">
      <h2 class="ps-profile-error__title" data-i18n="specialist.public.no_slug_title"></h2>
      <p data-i18n="specialist.public.no_slug_body"></p>
      <p style="margin-top: 16px;"><a href="/specialists/" style="color:#4f46e5;" data-i18n="specialist.public.see_all"></a></p>
    </div>
  </div>

  <script>
    // @ts-nocheck
    import { apiFetch, formatGs } from '../../lib/api.ts'
    import { t, getLocale, interp } from '../../lib/i18n.ts'
    const params = new URLSearchParams(location.search)
    const slug = params.get('slug') || ''

    const loc = () => getLocale()
    const pick = (...vals) => vals.find((v) => typeof v === 'string' && v.length > 0) ?? ''

    if (!slug) {
      const noSlug = document.getElementById('profile-no-slug')
      const wrap = document.querySelector('.ps-profile-wrap')
      if (noSlug) noSlug.hidden = false
      if (wrap) wrap.hidden = true
    } else {
      ;(async () => {
        try {
          const p = await apiFetch(`/v1/p/${slug}`)
          const nameEl = document.getElementById('profile-name')
          // Replace the SSR'd "Loading…" <T> spans (one per locale) with the
          // real display name. textContent assignment removes the children.
          if (nameEl) nameEl.textContent = p.displayName
          const tierEl = document.getElementById('profile-tier')
          if (tierEl && p.tier) {
            tierEl.dataset.tier = p.tier
            const tierLabel = t(`specialist.public.tier.${p.tier}`)
            tierEl.textContent = tierLabel
            tierEl.hidden = false
          }
          const metaEl = document.getElementById('profile-meta')
          const lc = loc()
          const headline = lc === 'en'
            ? pick(p.headlineEn, p.headline)
            : lc === 'de'
              ? pick(p.headlineDe, p.headlineEn, p.headline)
              : lc === 'ru'
                ? pick(p.headlineRu, p.headlineEn, p.headline)
                : p.headline
          if (metaEl && headline) {
            metaEl.textContent = `${headline} · ${p.barrio || ''}`.replace(/ · $/, '')
          }
          const statsEl = document.getElementById('profile-stats')
          if (statsEl) {
            const stats = []
            if (p.ratingCount > 0) {
              stats.push(`<span>★ ${p.ratingAvg.toFixed(1)} (${p.ratingCount})</span>`)
            }
            if (p.verified) stats.push(`<span>${t('specialist.public.wa_verified')}</span>`)
            if (p.cedulaVerified) stats.push(`<span>${t('specialist.public.cedula_verified')}</span>`)
            statsEl.innerHTML = stats.join('')
          }
          if (p.photo) {
            const avEl = document.getElementById('profile-avatar')
            if (avEl) {
              avEl.style.backgroundImage = `url(${p.photo})`
              avEl.textContent = ''
            }
          }
          if (p.coverUrl) {
            const cv = document.getElementById('profile-cover')
            if (cv) cv.style.backgroundImage = `url(${p.coverUrl})`
          }
          if (p.whatsapp) {
            const cta = document.getElementById('profile-cta')
            const link = document.getElementById('profile-wa-link')
            if (cta && link) {
              const num = p.whatsapp.replace(/\D/g, '')
              const msg = encodeURIComponent(interp(t('specialist.public.wa_template'), { name: p.displayName }))
              link.setAttribute('href', `https://wa.me/${num}?text=${msg}`)
              cta.hidden = false
            }
          }
          const bio = lc === 'en'
            ? pick(p.bioEn, p.bio)
            : lc === 'de'
              ? pick(p.bioDe, p.bioEn, p.bio)
              : lc === 'ru'
                ? pick(p.bioRu, p.bioEn, p.bio)
                : p.bio
          if (bio && bio.trim()) {
            const sec = document.getElementById('bio-section')
            const bioEl = document.getElementById('profile-bio')
            if (sec && bioEl) {
              bioEl.textContent = bio
              sec.hidden = false
            }
          }
          if (p.services && p.services.length > 0) {
            const sec = document.getElementById('services-section')
            const list = document.getElementById('services-list')
            if (sec && list) {
              list.innerHTML = p.services.map((s) => `
                <li>
                  <span class="name">${escapeHtml(s.name || '')}</span>
                  <span class="price">${formatPriceRange(s)}</span>
                </li>
              `).join('')
              sec.hidden = false
            }
          }
          if (p.areas && p.areas.length > 0) {
            const sec = document.getElementById('areas-section')
            const list = document.getElementById('areas-list')
            if (sec && list) {
              list.innerHTML = p.areas.map((a) => `<span>${escapeHtml(a.name)}</span>`).join('')
              sec.hidden = false
            }
          }
          if (p.portfolio && p.portfolio.length > 0) {
            const sec = document.getElementById('portfolio-section')
            const grid = document.getElementById('portfolio-grid')
            if (sec && grid) {
              grid.innerHTML = p.portfolio.slice(0, 9).map((ph) =>
                `<div style="background-image:url(${ph.url})"></div>`
              ).join('')
              sec.hidden = false
            }
          }
          if (p.badges && p.badges.length > 0) {
            const sec = document.getElementById('badges-section')
            const list = document.getElementById('badges-list')
            if (sec && list) {
              list.innerHTML = p.badges.map((b) => `
                <span class="ps-badge-pill" data-rarity="${b.rarity}" title="${escapeHtml(b.description)}">
                  ${escapeHtml(b.name)}
                </span>
              `).join('')
              sec.hidden = false
            }
          }
          document.title = `${p.displayName} · ${headline || 'PyaServ'}`
          try {
            const blob = new Blob([JSON.stringify({ event: 'profile_view', subject_id: slug })], { type: 'application/json' })
            navigator.sendBeacon?.('https://api.pyaserv.com/v1/analytics', blob)
          } catch {}
        } catch (e) {
          console.error('profile load failed', e)
          const err = document.getElementById('profile-error')
          if (err) err.hidden = false
          const wrap = document.querySelector('.ps-profile-wrap')
          if (wrap) wrap.hidden = true
        }
      })()
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, (c) => ({
        '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;'
      })[c])
    }
    function formatPriceRange(s) {
      if (s.priceMin && s.priceMax && s.priceMin !== s.priceMax) {
        return `${formatGs(s.priceMin)} – ${formatGs(s.priceMax)}`
      }
      if (s.priceMin) return interp(t('specialist.public.price_from'), { amount: formatGs(s.priceMin) })
      return t('specialist.public.price_to_arrange')
    }
  </script>
</Base>
