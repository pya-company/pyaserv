---
import Base from '../../../layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Editar pedido" active="me">
  <section class="ps-section" data-base={base}>
    <p><a href={`${base}/me/?tab=requests`}>← Mis pedidos</a></p>
    <h1>Editar pedido</h1>
    <p id="status" class="ps-msg">Cargando…</p>
    <form id="form" class="ps-form ps-hidden">
      <label>Categoría <select name="category" id="category" required></select></label>
      <label>Título <input name="title" required maxlength="120" /></label>
      <label>Descripción <textarea name="description" rows="5" maxlength="2000"></textarea></label>
      <div class="ps-grid-2col">
        <label>Barrio <input name="barrio" required /></label>
        <label>Presupuesto (Gs) <input name="budgetGs" type="number" min="0" /></label>
      </div>
      <label>Estado
        <select name="status">
          <option value="open">Abierto</option>
          <option value="closed">Cerrado</option>
        </select>
      </label>
      <div class="ps-row">
        <button type="submit" class="ps-btn">Guardar</button>
      </div>
      <p id="msg" class="ps-msg" aria-live="polite"></p>
    </form>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, CATEGORIES } from '../../../lib/api.ts'

    ;(async () => {
      const base = document.querySelector('.ps-section').dataset.base ?? ''
      if (!getToken()) { location.href = `${base}/login/?next=${encodeURIComponent(location.pathname+location.search)}`; return }
      const id = new URLSearchParams(location.search).get('id')
      const status = document.getElementById('status')
      const form = document.getElementById('form')
      const msg = document.getElementById('msg')

      const cat = document.getElementById('category')
      for (const c of CATEGORIES) {
        const opt = document.createElement('option')
        opt.value = c.value
        opt.textContent = `${c.emoji} ${c.label}`
        cat.append(opt)
      }

      if (!id) { status.innerHTML = '<span class="ps-error">Falta el id</span>'; return }
      let req
      try { req = await apiFetch(`/v1/requests/${id}`) }
      catch (err) { status.innerHTML = `<span class="ps-error">${err.message}</span>`; return }

      status.classList.add('ps-hidden')
      form.classList.remove('ps-hidden')
      form.elements.category.value = req.category
      form.elements.title.value = req.title
      form.elements.description.value = req.description
      form.elements.barrio.value = req.barrio
      if (req.budgetGs != null) form.elements.budgetGs.value = req.budgetGs
      form.elements.status.value = req.status

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        msg.textContent = 'Guardando…'
        const fd = Object.fromEntries(new FormData(form))
        fd.budgetGs = fd.budgetGs ? Number(fd.budgetGs) : null
        try {
          await apiFetch(`/v1/requests/${id}`, { method: 'PATCH', body: JSON.stringify(fd) })
          location.href = `${base}/me/?tab=requests`
        } catch (err) { msg.innerHTML = `<span class="ps-error">${err.message}</span>` }
      })
    })()
  </script>
</Base>
