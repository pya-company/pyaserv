---
import Base from '../../../layouts/Base.astro'
import BarriosDatalist from '../../../components/BarriosDatalist.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Editar pedido" titleKey="request.edit.title" active="me">
  <section class="ps-section" data-base={base}>
    <p><a href={`${base}/me/?tab=requests`} data-i18n="request.new.back">← Mis pedidos</a></p>
    <h1 data-i18n="request.edit.title">Editar pedido</h1>
    <p id="status" class="ps-msg" data-i18n="common.loading">Cargando…</p>
    <form id="form" class="ps-form ps-hidden">
      <label>
        <span data-i18n="request.field.category">Categoría</span>
        <select name="category" id="category" required></select>
      </label>
      <label>
        <span data-i18n="request.field.title">Título</span>
        <input name="title" required maxlength="120" />
      </label>
      <label>
        <span data-i18n="request.field.description">Descripción</span>
        <textarea name="description" rows="5" maxlength="2000"></textarea>
      </label>
      <div class="ps-grid-2col">
        <label>
          <span data-i18n="request.field.barrio">Barrio</span>
          <input name="barrio" required list="ps-barrios" />
        </label>
        <label>
          <span data-i18n="request.field.budget.short">Presupuesto (Gs)</span>
          <input name="budgetGs" type="number" min="0" />
        </label>
      </div>
      <label>
        <span data-i18n="request.field.status">Estado</span>
        <select name="status">
          <option value="open" data-i18n="request.field.status.open">Abierto</option>
          <option value="closed" data-i18n="request.field.status.closed">Cerrado</option>
        </select>
      </label>
      <div class="ps-row">
        <button type="submit" class="ps-btn" data-i18n="common.save">Guardar</button>
      </div>
      <p id="msg" class="ps-msg" role="alert"></p>
    </form>
  </section>

  <BarriosDatalist />

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, CATEGORIES, categoryLabel } from '../../../lib/api.ts'
    import { t } from '../../../lib/i18n.ts'

    ;(async () => {
      const base = document.querySelector('.ps-section').dataset.base ?? ''
      if (!getToken()) { location.href = `${base}/login/?next=${encodeURIComponent(location.pathname+location.search)}`; return }
      const id = new URLSearchParams(location.search).get('id')
      const status = document.getElementById('status')
      const form = document.getElementById('form')
      const msg = document.getElementById('msg')
      const escape = (s) => String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]))

      const cat = document.getElementById('category')
      for (const c of CATEGORIES) {
        const opt = document.createElement('option')
        opt.value = c.value
        opt.textContent = `${c.emoji} ${categoryLabel(c.value)}`
        cat.append(opt)
      }

      if (!id) { status.innerHTML = `<span class="ps-error">${t('common.missing_id')}</span>`; return }
      let req
      try { req = await apiFetch(`/v1/requests/${id}`) }
      catch (err) { status.innerHTML = `<span class="ps-error">${escape(err.message)}</span>`; return }

      status.classList.add('ps-hidden')
      form.classList.remove('ps-hidden')
      form.elements.category.value = req.category
      form.elements.title.value = req.title
      form.elements.description.value = req.description
      form.elements.barrio.value = req.barrio
      if (req.budgetGs != null) form.elements.budgetGs.value = req.budgetGs
      form.elements.status.value = req.status

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        msg.textContent = t('common.saving')
        const fd = Object.fromEntries(new FormData(form))
        fd.budgetGs = fd.budgetGs ? Number(fd.budgetGs) : null
        try {
          await apiFetch(`/v1/requests/${id}`, { method: 'PATCH', body: JSON.stringify(fd) })
          location.href = `${base}/me/?tab=requests`
        } catch (err) { msg.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
      })
    })()
  </script>
</Base>
