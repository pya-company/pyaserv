---
import Base from '../../../layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Conversación" active="me">
  <section class="ps-section" data-base={base}>
    <p><a href={`${base}/me/?tab=inquiries`} data-i18n="inquiry.back">← Conversaciones</a></p>
    <p id="status" class="ps-msg" data-i18n="common.loading">Cargando…</p>
    <div id="thread" class="ps-hidden">
      <div class="ps-row" style="justify-content:space-between;align-items:flex-start">
        <h1 id="title">Conversación</h1>
        <a id="subject-link" class="ps-btn ps-btn--ghost ps-btn--sm" data-i18n="inquiry.view_subject">Ver publicación</a>
      </div>

      <div id="status-bar" class="ps-banner ps-row" style="flex-wrap:wrap">
        <span id="status-label" class="ps-status-chip" role="status" aria-live="polite"></span>
        <button id="btn-start" class="ps-btn ps-btn--sm ps-hidden" data-i18n="inquiry.btn_start">Comenzar trabajo</button>
        <button id="btn-done" class="ps-btn ps-btn--sm ps-hidden" data-i18n="inquiry.btn_done">Marcar terminado</button>
        <button id="btn-cancel" class="ps-btn ps-btn--ghost ps-btn--sm ps-hidden" data-i18n="inquiry.btn_cancel">Cancelar</button>
      </div>

      <div id="messages" class="ps-chat" aria-busy="true" aria-live="polite" aria-relevant="additions" aria-atomic="false"></div>
      <form id="composer-form" class="ps-composer">
        <textarea name="body" required minlength="1" maxlength="2000" data-i18n-placeholder="inquiry.compose_placeholder" placeholder="Escribí un mensaje…"></textarea>
        <button type="submit" class="ps-btn" data-i18n="common.send">Enviar</button>
      </form>
      <p id="msg" class="ps-msg" aria-live="polite"></p>

      <div id="review-form" class="ps-banner ps-hidden" role="region" aria-labelledby="review-form-h">
        <h2 id="review-form-h" data-i18n="inquiry.review_h">Calificar trabajo</h2>
        <form id="review-form-el" class="ps-form">
          <div id="stars-row" class="ps-stars-row" role="group" aria-label="Stars"></div>
          <label>
            <span data-i18n="inquiry.review_body_label">Comentario (opcional)</span>
            <textarea name="body" maxlength="1000" rows="3" data-i18n-placeholder="inquiry.review_body_placeholder" placeholder="Contale a otros cómo fue."></textarea>
          </label>
          <button type="submit" class="ps-btn" data-i18n="inquiry.review_submit">Enviar reseña</button>
          <p id="review-msg" class="ps-msg" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, formatRelativeTime } from '../../../lib/api.ts'
    import { t } from '../../../lib/i18n.ts'

    ;(async () => {
      const base = document.querySelector('.ps-section').dataset.base ?? ''
      if (!getToken()) { location.href = `${base}/login/?next=${encodeURIComponent(location.pathname+location.search)}`; return }
      const id = new URLSearchParams(location.search).get('id')
      const status = document.getElementById('status')
      const thread = document.getElementById('thread')
      const msgsEl = document.getElementById('messages')
      const cf = document.getElementById('composer-form')
      const msg = document.getElementById('msg')
      const statusBar = document.getElementById('status-bar')
      const statusLabel = document.getElementById('status-label')

      const escape = (s) => String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]))

      if (!id) { status.innerHTML = `<span class="ps-error">${t('common.missing_id')}</span>`; return }
      const me = await apiFetch('/v1/me')

      const labelByStatus = {
        negotiating: t('inquiry.status_negotiating') || 'Negociando',
        in_progress: t('inquiry.status_in_progress') || 'En curso',
        done: t('inquiry.status_done') || 'Terminado',
        cancelled: t('inquiry.status_cancelled') || 'Cancelado',
      }

      let cachedInquiry = null
      let lastCount = 0
      let cachedReviews = []
      let subjectLinkResolved = false

      const renderStatusBar = (inquiry) => {
        statusLabel.textContent = labelByStatus[inquiry.workStatus] || inquiry.workStatus
        statusLabel.dataset.status = inquiry.workStatus
        const isClient = inquiry.clientUserId === me.userId
        const isSpec = inquiry.specialistUserId === me.userId
        const btnStart = document.getElementById('btn-start')
        const btnDone = document.getElementById('btn-done')
        const btnCancel = document.getElementById('btn-cancel')

        if (inquiry.workStatus === 'negotiating' && isClient) btnStart.classList.remove('ps-hidden')
        else btnStart.classList.add('ps-hidden')

        if (inquiry.workStatus === 'in_progress') {
          const already = (isClient && inquiry.clientConfirmed) || (isSpec && inquiry.specialistConfirmed)
          if (!already) btnDone.classList.remove('ps-hidden')
          else btnDone.classList.add('ps-hidden')
        } else btnDone.classList.add('ps-hidden')

        if (['negotiating','in_progress'].includes(inquiry.workStatus)) btnCancel.classList.remove('ps-hidden')
        else btnCancel.classList.add('ps-hidden')

        // Review form: show if done and I haven't reviewed yet from my role
        const role = isClient ? 'client' : 'specialist'
        const myReviewExists = cachedReviews.some((r) => r.role === role)
        const reviewForm = document.getElementById('review-form')
        if (inquiry.workStatus === 'done' && !myReviewExists) reviewForm.classList.remove('ps-hidden')
        else reviewForm.classList.add('ps-hidden')
      }

      const renderThread = async () => {
        try {
          const data = await apiFetch(`/v1/inquiries/${id}`)
          cachedInquiry = data.inquiry
          cachedReviews = data.reviews || []
          if (data.messages.length !== lastCount) {
            lastCount = data.messages.length
            msgsEl.removeAttribute('aria-busy')
            msgsEl.innerHTML = data.messages.map((m) => {
              const mine = m.senderUserId === me.userId
              return `<div class="ps-bubble ps-bubble--${mine ? 'mine' : 'them'}">${escape(m.body)}<span class="ps-bubble__time">${formatRelativeTime(m.createdAt)}</span></div>`
            }).join('')
            msgsEl.scrollTop = msgsEl.scrollHeight
          }
          status.classList.add('ps-hidden')
          thread.classList.remove('ps-hidden')
          document.getElementById('title').textContent = data.inquiry.subjectType === 'listing' ? t('inquiry.subject_listing') : t('inquiry.subject_request')

          // Resolve subject link once per page load — listings need a lookup, requests are direct.
          if (!subjectLinkResolved) {
            const link = document.getElementById('subject-link')
            if (data.inquiry.subjectType === 'request') {
              link.href = `${base}/clients/detail/?id=${data.inquiry.subjectId}`
              subjectLinkResolved = true
            } else {
              try {
                const listing = (await apiFetch(`/v1/listings`)).find((l) => l.id === data.inquiry.subjectId)
                const profile = listing
                  ? (await apiFetch(`/v1/specialists`)).find((s) => s.userId === data.inquiry.specialistUserId)
                  : null
                if (profile) link.href = `${base}/specialists/detail/?id=${profile.id}`
                else link.classList.add('ps-hidden')
              } catch { link.classList.add('ps-hidden') }
              subjectLinkResolved = true
            }
          }

          renderStatusBar(data.inquiry)
        } catch (err) { status.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
      }
      await renderThread()
      setInterval(renderThread, 5000)

      cf.addEventListener('submit', async (e) => {
        e.preventDefault()
        msg.textContent = ''
        const body = new FormData(cf).get('body')
        try {
          await apiFetch(`/v1/inquiries/${id}/messages`, { method: 'POST', body: JSON.stringify({ body }) })
          cf.reset()
          lastCount = -1
          renderThread()
        } catch (err) { msg.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
      })

      const sendAction = async (action) => {
        try {
          await apiFetch(`/v1/inquiries/${id}/status`, { method: 'PATCH', body: JSON.stringify({ action }) })
          renderThread()
        } catch (err) { msg.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
      }
      document.getElementById('btn-start').addEventListener('click', () => sendAction('start'))
      document.getElementById('btn-done').addEventListener('click', () => sendAction('confirm_done'))
      document.getElementById('btn-cancel').addEventListener('click', () => {
        if (confirm(t('inquiry.cancel_confirm') || '¿Cancelar trabajo?')) sendAction('cancel')
      })

      // Star picker
      const starsRow = document.getElementById('stars-row')
      let pickedStars = 5
      const drawStars = () => {
        starsRow.innerHTML = [1,2,3,4,5].map((n) => `<button type="button" class="ps-star${n <= pickedStars ? ' ps-star--on' : ''}" data-n="${n}" aria-label="${n} ★" aria-pressed="${n <= pickedStars ? 'true' : 'false'}">★</button>`).join('')
        for (const b of starsRow.querySelectorAll('button')) {
          b.addEventListener('click', () => { pickedStars = +b.dataset.n; drawStars() })
        }
      }
      drawStars()
      document.getElementById('review-form-el').addEventListener('submit', async (e) => {
        e.preventDefault()
        const rm = document.getElementById('review-msg')
        rm.textContent = t('common.sending')
        try {
          await apiFetch(`/v1/inquiries/${id}/reviews`, {
            method: 'POST',
            body: JSON.stringify({ stars: pickedStars, body: new FormData(e.target).get('body') || '' }),
          })
          rm.innerHTML = `<span class="ps-msg--ok">${t('inquiry.review_thanks') || '¡Gracias!'}</span>`
          lastCount = -1
          renderThread()
        } catch (err) { rm.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
      })
    })()
  </script>
</Base>
