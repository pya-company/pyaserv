---
import Base from '../../../layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Nuevo servicio" titleKey="listing.new.title" active="me">
  <section class="ps-section" data-base={base}>
    <p><a href={`${base}/me/?tab=listings`} data-i18n="listing.new.back">← Mis servicios</a></p>
    <h1 data-i18n="listing.new.title">Nuevo servicio</h1>
    <p data-i18n="listing.new.intro">Publicá un servicio concreto que ofrecés. Aparecerá en el catálogo público de profesionales filtrable por categoría.</p>
    <form id="form" class="ps-form">
      <label>
        <span data-i18n="listing.field.category">Categoría</span>
        <select name="category" id="category" required></select>
      </label>
      <label>
        <span data-i18n="listing.field.title">Título</span>
        <input name="title" required maxlength="120" data-i18n-placeholder="listing.field.title.placeholder" placeholder="Reparación de calefones" />
      </label>
      <label>
        <span data-i18n="listing.field.description">Descripción</span>
        <textarea name="description" rows="4" maxlength="2000" data-i18n-placeholder="listing.field.description.placeholder" placeholder="Qué incluye el servicio, qué materiales, en qué zonas…"></textarea>
      </label>
      <div class="ps-grid-2col">
        <label>
          <span data-i18n="listing.field.price_from">Precio desde (Gs, opcional)</span>
          <input name="priceFromGs" type="number" min="0" />
        </label>
        <label>
          <span data-i18n="listing.field.unit">Por</span>
          <select name="priceUnit">
            <option value="" data-i18n="listing.field.unit.none">—</option>
            <option value="hour" data-i18n="listing.field.unit.hour">Hora</option>
            <option value="job" data-i18n="listing.field.unit.job">Trabajo</option>
          </select>
        </label>
      </div>
      <div class="ps-row ps-photo-widget">
        <div id="photo-preview" class="ps-detail__avatar ps-avatar--thumb">📷</div>
        <div class="ps-stack ps-photo-widget__ctrl">
          <label class="ps-btn ps-btn--ghost ps-btn--sm ps-photo-widget__btn" for="photo-input">
            <span id="photo-btn-label" data-i18n="media.upload">Subir foto</span>
          </label>
          <input id="photo-input" type="file" accept="image/jpeg,image/png,image/webp" hidden />
          <button type="button" id="photo-remove" class="ps-btn ps-btn--ghost ps-btn--sm ps-hidden" data-i18n="media.remove">Quitar</button>
          <p id="photo-msg" class="ps-msg" aria-live="polite"></p>
        </div>
      </div>
      <input type="hidden" name="photo" id="photo-key" />
      <button type="submit" class="ps-btn" data-i18n="listing.new.submit">Publicar</button>
      <p id="msg" class="ps-msg" role="alert"></p>
    </form>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, getToken, CATEGORIES, categoryLabel, uploadImage, mediaUrl } from '../../../lib/api.ts'
    import { t } from '../../../lib/i18n.ts'

    ;(async () => {
      const base = document.querySelector('.ps-section').dataset.base ?? ''
      if (!getToken()) { location.href = `${base}/login/?next=${encodeURIComponent(location.pathname)}`; return }
      const cat = document.getElementById('category')
      for (const c of CATEGORIES) {
        const opt = document.createElement('option')
        opt.value = c.value
        opt.textContent = `${c.emoji} ${categoryLabel(c.value)}`
        cat.append(opt)
      }
      const escape = (s) => String(s ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]))
      const photoPreview = document.getElementById('photo-preview')
      const photoInput = document.getElementById('photo-input')
      const photoKey = document.getElementById('photo-key')
      const photoMsg = document.getElementById('photo-msg')
      const photoBtnLabel = document.getElementById('photo-btn-label')
      const photoRemove = document.getElementById('photo-remove')
      const showPhoto = (key) => {
        if (key) {
          photoPreview.classList.add('ps-avatar--photo')
          photoPreview.innerHTML = `<img class="ps-avatar__img" src="${mediaUrl(key)}" alt=""/>`
          photoBtnLabel.textContent = t('media.replace')
          photoRemove.classList.remove('ps-hidden')
        } else {
          photoPreview.classList.remove('ps-avatar--photo')
          photoPreview.textContent = '📷'
          photoBtnLabel.textContent = t('media.upload')
          photoRemove.classList.add('ps-hidden')
        }
      }
      photoInput.addEventListener('change', async () => {
        const f = photoInput.files?.[0]
        if (!f) return
        photoMsg.textContent = t('media.uploading')
        try {
          const key = await uploadImage(f)
          photoKey.value = key
          showPhoto(key)
          photoMsg.textContent = ''
        } catch (err) { photoMsg.innerHTML = `<span class="ps-error">${escape(err.message)}</span>` }
        finally { photoInput.value = '' }
      })
      photoRemove.addEventListener('click', () => { photoKey.value = ''; showPhoto('') })

      const form = document.getElementById('form')
      const msg = document.getElementById('msg')
      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        msg.textContent = t('common.publishing')
        const fd = Object.fromEntries(new FormData(form))
        if (fd.priceFromGs) fd.priceFromGs = Number(fd.priceFromGs)
        else delete fd.priceFromGs
        if (!fd.priceUnit) delete fd.priceUnit
        if (!fd.photo) delete fd.photo
        try {
          await apiFetch('/v1/listings', { method: 'POST', body: JSON.stringify(fd) })
          location.href = `${base}/me/?tab=listings`
        } catch (err) { msg.innerHTML = `<span class="ps-error">${err.message || t('error.network')}</span>` }
      })
    })()
  </script>
</Base>
