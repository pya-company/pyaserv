---
import Base from '~/layouts/Base.astro'
import '~/styles/components-lib.css'
import '~/styles/demo-and-docs.css'
import { RELEASES } from '~/data/releases.ts'
import { getReleaseContent } from '~/lib/content.ts'
import { renderReleaseBody } from '~/lib/markdown-mini.ts'
import { tFor, type Locale } from '~/lib/i18n.ts'

export function getStaticPaths() {
  return RELEASES.map((r) => ({ params: { slug: r.slug }, props: { release: r } }))
}
const { release } = Astro.props
const loc: Locale = 'es'
const backLabel = tFor(loc, 'releases.back_to_index')
const sectionLabel = (kind: string) => tFor(loc, `releases.section_${kind}`)
const content = getReleaseContent(loc, release.slug)
if (!content) throw new Error(`Missing release content for ${release.slug}`)
---
<Base title={`${content.title} — ${tFor(loc, 'releases.page_title')}`} active="home" description={content.tldr}>
  <article class="release-detail">
    <nav class="docpage__crumbs">
      <a href="/releases/">{tFor(loc, 'releases.page_title')}</a> · <span>{release.version}</span>
    </nav>

    <header class="release-detail__head">
      <div class="release-card__meta">
        <span class="release-card__version">{release.version}</span>
        <span class="release-card__date">{release.date}</span>
      </div>
      <h1>{content.title}</h1>
      <p class="release-detail__tldr">{content.tldr}</p>
      {release.tags.length > 0 && (
        <div class="release-card__tags">
          {release.tags.map((tag) => <span class="cl-tag cl-tag--gray">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="release-detail__body">
      {content.sections.map((sec) => (
        <section class="release-section" data-kind={sec.kind}>
          <h2 class="release-section__heading">
            <span class="release-section__badge" data-kind={sec.kind}>{sectionLabel(sec.kind)}</span>
            {sec.heading && <span class="release-section__title">{sec.heading}</span>}
          </h2>
          <div class="release-section__body" set:html={renderReleaseBody(sec.body)} />
        </section>
      ))}
    </div>

    <div class="docpage__back">
      <a href="/releases/">{backLabel}</a>
    </div>
  </article>
</Base>
