---
import Base from '~/layouts/Base.astro'
import '~/styles/components-lib.css'
import '~/styles/docs.css'
import { RELEASES } from '~/data/releases.ts'
import { getReleaseContent } from '~/lib/content.ts'
import { renderReleaseBody } from '~/lib/markdown-mini.ts'
import { tFor, LOCALES, type Locale } from '~/lib/i18n.ts'
import { getAllLocales } from '~/lib/l10n-emit.ts'

export function getStaticPaths() {
  return RELEASES.map((r) => ({ params: { slug: r.slug }, props: { release: r } }))
}
const { release } = Astro.props
const loc: Locale = 'es'
const VISIBLE_LOCS = LOCALES.filter((l) => l !== 'gn')
const content = getReleaseContent(loc, release.slug)
if (!content) throw new Error(`Missing release content for ${release.slug}`)

const labelMap = (kind: string) => {
  const out: Record<string, string> = {}
  for (const l of VISIBLE_LOCS) out[l] = tFor(l, `releases.section_${kind}`)
  return out
}
const backMap = (): Record<string, string> => {
  const out: Record<string, string> = {}
  for (const l of VISIBLE_LOCS) out[l] = tFor(l, 'releases.back_to_index')
  return out
}
const pageTitleMap = (): Record<string, string> => {
  const out: Record<string, string> = {}
  for (const l of VISIBLE_LOCS) out[l] = tFor(l, 'releases.page_title')
  return out
}
const sectionBodyMap = (idx: number): Record<string, string> => {
  const out: Record<string, string> = {}
  for (const l of VISIBLE_LOCS) {
    const c = getReleaseContent(l, release.slug)
    const s = c?.sections?.[idx]
    if (s) out[l] = renderReleaseBody(s.body)
  }
  return out
}

const escapeAttr = (s: string): string =>
  s.replace(/&/g, '&amp;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
const l10nText = (m: Record<string, string>): string => `data-l10n-text='${escapeAttr(JSON.stringify(m))}'`
const l10nHtml = (m: Record<string, string>): string => `data-l10n-html='${escapeAttr(JSON.stringify(m))}'`
---
<Base title={`${content.title} — ${tFor(loc, 'releases.page_title')}`} active="home" description={content.tldr}>
  <article class="release-detail">
    <nav class="docpage__crumbs">
      <Fragment set:html={`<a href="/releases/" ${l10nText(pageTitleMap())}>${tFor(loc, 'releases.page_title')}</a>`} /> · <span>{release.version}</span>
    </nav>

    <header class="release-detail__head">
      <div class="release-card__meta">
        <span class="release-card__version">{release.version}</span>
        <span class="release-card__date">{release.date}</span>
      </div>
      <Fragment set:html={`<h1 ${l10nText(getAllLocales('releases', release.slug, ['title']))}>${content.title}</h1>`} />
      <Fragment set:html={`<p class="release-detail__tldr" ${l10nText(getAllLocales('releases', release.slug, ['tldr']))}>${content.tldr}</p>`} />
      {release.tags.length > 0 && (
        <div class="release-card__tags">
          {release.tags.map((tag) => <span class="cl-tag cl-tag--gray">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="release-detail__body">
      {content.sections.map((sec, i) => (
        <section class="release-section" data-kind={sec.kind}>
          <h2 class="release-section__heading">
            <Fragment set:html={`<span class="release-section__badge" data-kind="${sec.kind}" ${l10nText(labelMap(sec.kind))}>${tFor(loc, `releases.section_${sec.kind}`)}</span>`} />
            <Fragment set:html={`<span class="release-section__title" ${l10nText(getAllLocales('releases', release.slug, ['sections', i, 'heading']))}>${sec.heading}</span>`} />
          </h2>
          <Fragment set:html={`<div class="release-section__body" ${l10nHtml(sectionBodyMap(i))}>${renderReleaseBody(sec.body)}</div>`} />
        </section>
      ))}
    </div>

    <div class="docpage__back">
      <Fragment set:html={`<a href="/releases/" ${l10nText(backMap())}>${tFor(loc, 'releases.back_to_index')}</a>`} />
    </div>
  </article>
</Base>
