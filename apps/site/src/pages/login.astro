---
import Base from '~/layouts/Base.astro'
import T from '~/components/T.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base
  title="Iniciar sesión"
  titleKey="login.title"
  description="Entrá a PyaServ con tu email — sin contraseña. Te enviamos un código de 6 dígitos por correo."
  descriptionKey="login.description"
  active="login"
>
  <section class="ps-section" data-base={base} style="max-width:28rem;margin:auto">
    <T k="login.title" as="h1" />
    <T k="login.intro" as="p" />

    <div class="ps-login-card">
    <form id="start-form" class="ps-form">
      <label>
        <T k="login.email" as="span" />
        <input type="email" name="email" required autocomplete="email" data-i18n-placeholder="login.email.placeholder" placeholder="tunombre@correo.com" />
      </label>
      <button type="submit" class="ps-btn"><T k="login.send_code" /></button>
    </form>

    <form id="verify-form" class="ps-form" hidden>
      <label>
        <T k="login.code" as="span" />
        <input type="text" name="code" pattern="[0-9]{6}" inputmode="numeric" required autocomplete="one-time-code" maxlength="6" />
      </label>
      <div class="ps-row">
        <button type="submit" class="ps-btn"><T k="login.confirm" /></button>
        <button type="button" id="back" class="ps-btn ps-btn--ghost"><T k="login.change_email" /></button>
      </div>
    </form>

    <p id="msg" class="ps-msg" role="alert"></p>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, setToken } from '../lib/api.ts'
    import { t } from '../lib/i18n.ts'

    ;(async () => {
      const base = document.querySelector('.ps-section').dataset.base ?? ''
      const next = new URLSearchParams(location.search).get('next') || `${base}/me/`
      const startForm = document.getElementById('start-form')
      const verifyForm = document.getElementById('verify-form')
      const msg = document.getElementById('msg')
      let email = ''

      startForm.addEventListener('submit', async (e) => {
        e.preventDefault()
        msg.textContent = t('common.sending')
        email = new FormData(startForm).get('email')
        try {
          await apiFetch('/api/auth/start', { method: 'POST', body: JSON.stringify({ email, channel: 'otp' }) })
          startForm.hidden = true
          verifyForm.hidden = false
          msg.innerHTML = `<span class="ps-msg--ok">${t('login.sent_ok')}</span>`
        } catch (err) { msg.innerHTML = `<span class="ps-error">${err.message || t('error.network')}</span>` }
      })

      document.getElementById('back').addEventListener('click', () => {
        verifyForm.hidden = true
        startForm.hidden = false
        msg.textContent = ''
      })

      verifyForm.addEventListener('submit', async (e) => {
        e.preventDefault()
        msg.textContent = t('common.verifying')
        const code = new FormData(verifyForm).get('code')
        try {
          const data = await apiFetch('/api/auth/otp/verify', { method: 'POST', body: JSON.stringify({ email, code }) })
          setToken(data.token)
          msg.textContent = t('login.success')
          location.href = next
        } catch (err) { msg.innerHTML = `<span class="ps-error">${err.message || t('error.network')}</span>` }
      })
    })()
  </script>
</Base>
