---
// Login is no longer a page — it's a modal triggered from the nav (S24).
// This route stays only as a backcompat redirect so old bookmarks /
// /me/ guards / external password-manager autofill links don't 404.
// Redirects to /?login=1 (+ ?next= passed through), which Base.astro's
// LoginDialog wireup opens automatically.
import Base from '~/layouts/Base.astro'
const next = Astro.url.searchParams.get('next') ?? ''
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const targetParams = new URLSearchParams({ login: '1' })
if (next) targetParams.set('next', next)
const target = `${base}/?${targetParams.toString()}`
---
<Base title="Iniciar sesión" titleKey="login.title" description="Iniciá sesión en PyaServ" descriptionKey="login.description" active="login">
  <meta http-equiv="refresh" content={`0; url=${target}`} />
  <section class="ps-section">
    <p>Redirigiendo…</p>
    <p><a href={target}>Continuar</a></p>
  </section>
  <script define:vars={{ target }}>
    // @ts-nocheck
    // Beat the meta-refresh on browsers with JS so we don't pollute history.
    try { location.replace(target) } catch { location.href = target }
  </script>
</Base>
