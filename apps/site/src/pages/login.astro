---
import Base from '~/layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base title="Iniciar sesión" active="home">
  <section class="ps-section" style="max-width:30rem;margin:auto">
    <h1>Iniciar sesión</h1>
    <p>Te enviamos un código por email — sin contraseñas, sin recordar nada.</p>

    <form id="start-form" class="ps-form" data-base={base}>
      <label>
        Email
        <input type="email" name="email" required autocomplete="email" />
      </label>
      <button type="submit">Enviar código</button>
    </form>

    <form id="verify-form" class="ps-form" hidden>
      <label>
        Código (6 dígitos)
        <input type="text" name="code" pattern="[0-9]{6}" inputmode="numeric" required autocomplete="one-time-code" />
      </label>
      <button type="submit">Confirmar</button>
    </form>

    <p id="msg" class="ps-msg" aria-live="polite"></p>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, setToken } from '../lib/api.ts'

    const startForm = document.getElementById('start-form')
    const verifyForm = document.getElementById('verify-form')
    const msg = document.getElementById('msg')
    const base = startForm.dataset.base ?? ''

    let email = ''

    startForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      msg.textContent = 'Enviando…'
      email = new FormData(startForm).get('email')
      try {
        await apiFetch('/api/auth/start', {
          method: 'POST',
          body: JSON.stringify({ email, channel: 'otp' }),
        })
        startForm.hidden = true
        verifyForm.hidden = false
        msg.textContent = 'Revisá tu email.'
      } catch (err) {
        msg.textContent = err.message
      }
    })

    verifyForm.addEventListener('submit', async (e) => {
      e.preventDefault()
      msg.textContent = 'Verificando…'
      const code = new FormData(verifyForm).get('code')
      try {
        const data = await apiFetch('/api/auth/verify', {
          method: 'POST',
          body: JSON.stringify({ email, code }),
        })
        setToken(data.token)
        msg.textContent = '¡Listo! Redirigiendo…'
        location.href = `${base}/me/`
      } catch (err) {
        msg.textContent = err.message
      }
    })
  </script>
</Base>
