---
import Base from '~/layouts/Base.astro'
import T from '~/components/T.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base
  title="Iniciar sesión"
  titleKey="login.title"
  description="Entrá a PyaServ con tu email — sin contraseña. Te enviamos un código de 6 dígitos por correo."
  descriptionKey="login.description"
  active="login"
>
  <section class="ps-section" data-base={base} style="max-width:28rem;margin:auto">
    <T k="login.title" as="h1" />
    <T k="login.intro" as="p" />

    <div class="ps-login-card">
    <form id="start-form" class="ps-form">
      <label>
        <T k="login.email" as="span" />
        <!-- autocomplete="username webauthn" wakes Conditional UI on browsers
             that support it: a one-tap passkey suggestion appears inside the
             email field's autofill list (per WebAuthn L3 §5.1.4 + Chrome 108+). -->
        <input type="email" name="email" required autocomplete="username webauthn" data-i18n-placeholder="login.email.placeholder" placeholder="tunombre@correo.com" />
      </label>
      <button type="submit" class="ps-btn"><T k="login.send_code" /></button>
    </form>

    <form id="verify-form" class="ps-form" hidden>
      <label>
        <T k="login.code" as="span" />
        <input type="text" name="code" pattern="[0-9]{6}" inputmode="numeric" required autocomplete="one-time-code" maxlength="6" />
      </label>
      <div class="ps-row">
        <button type="submit" class="ps-btn"><T k="login.confirm" /></button>
        <button type="button" id="back" class="ps-btn ps-btn--ghost"><T k="login.change_email" /></button>
      </div>
    </form>

    <!--
      Post-OTP passkey enrollment prompt. Hidden until OTP-verify succeeds.
      Dismissible; cooldown via localStorage; never blocks the redirect.
    -->
    <div id="enroll-card" class="ps-banner ps-stack" hidden>
      <strong>
        <span lang="es">Guardá este dispositivo para la próxima vez</span>
        <span lang="en">Save this device for next time</span>
      </strong>
      <p class="ps-card__sub">
        <span lang="es">Iniciá sesión sin código — solo <span id="enroll-method-es"></span>.</span>
        <span lang="en">Sign in without a code — just <span id="enroll-method-en"></span>.</span>
      </p>
      <div class="ps-row">
        <button type="button" id="enroll-accept" class="ps-btn">
          <span lang="es">Guardar</span>
          <span lang="en">Save</span>
        </button>
        <button type="button" id="enroll-skip" class="ps-btn ps-btn--ghost">
          <span lang="es">Ahora no</span>
          <span lang="en">Not now</span>
        </button>
      </div>
    </div>

    <p id="msg" class="ps-msg" role="alert"></p>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, setToken } from '../lib/api.ts'
    import { getLocale, t } from '../lib/i18n.ts'
    import { assertPasskey, enrollPasskey, startConditionalLogin } from '../features/passkey/client.ts'
    import {
      authenticatorLabel,
      conditionalUiAvailable,
      guessPlatform,
      passkeySupported,
      platformAuthenticatorAvailable,
    } from '../features/passkey/platform.ts'
    import {
      dismissPromptForCooldown,
      isPromptOnCooldown,
      muteForeverAfterEnroll,
    } from '../features/passkey/prompt-cooldown.ts'

    const initLogin = async () => {
      const section = document.querySelector('.ps-section[data-base]')
      if (!section || !location.pathname.endsWith('/login/')) return
      if (section.dataset.loginInitialized === '1') return
      section.dataset.loginInitialized = '1'

      const base = section.dataset.base ?? ''
      const next = new URLSearchParams(location.search).get('next') || `${base}/me/`
      const startForm = document.getElementById('start-form')
      const verifyForm = document.getElementById('verify-form')
      const enrollCard = document.getElementById('enroll-card')
      const msg = document.getElementById('msg')
      const storage = window.localStorage
      const clock = { now: () => Date.now() }
      let email = ''

      // ----- post-OTP enrollment prompt -----
      const offerEnroll = async () => {
        if (isPromptOnCooldown(storage, clock)) { location.href = next; return }
        if (!passkeySupported()) { location.href = next; return }
        if (!(await platformAuthenticatorAvailable())) { location.href = next; return }
        const platform = guessPlatform(navigator.userAgent)
        const loc = getLocale()
        const labelEs = authenticatorLabel(platform, 'es')
        const labelEn = authenticatorLabel(platform, 'en')
        document.getElementById('enroll-method-es').textContent = labelEs
        document.getElementById('enroll-method-en').textContent = labelEn
        startForm.hidden = true
        verifyForm.hidden = true
        enrollCard.hidden = false
        msg.textContent = ''
      }

      document.getElementById('enroll-accept').addEventListener('click', async () => {
        msg.textContent = t('common.saving')
        const result = await enrollPasskey(apiFetch)
        if (result === 'ok') {
          muteForeverAfterEnroll(storage, clock)
          msg.innerHTML = `<span class="ps-msg--ok">${t('login.success')}</span>`
        } else if (result === 'cancelled') {
          // Treat as a soft skip — 7-day cooldown, not a year.
          dismissPromptForCooldown(storage, clock)
        } else {
          // Error: short cooldown so we don't pester on transient failures.
          dismissPromptForCooldown(storage, clock)
        }
        location.href = next
      })
      document.getElementById('enroll-skip').addEventListener('click', () => {
        dismissPromptForCooldown(storage, clock)
        location.href = next
      })

      // ----- start (email submit) -----
      startForm.addEventListener('submit', async (e) => {
        e.preventDefault()
        msg.textContent = t('common.sending')
        email = new FormData(startForm).get('email')
        let data
        try {
          data = await apiFetch('/api/auth/start', {
            method: 'POST',
            body: JSON.stringify({ email, channel: 'otp', locale: getLocale() }),
          })
        } catch (err) { msg.innerHTML = `<span class="ps-error">${err.message || t('error.network')}</span>`; return }

        // Passkey-first: server hands us assertion options when the email
        // already has a credential. Try the OS picker; on user-cancel/error
        // fall back to OTP by calling /start again with force:'otp'.
        if (data?.method === 'passkey' && data.options) {
          const r = await assertPasskey(apiFetch, email, data.options)
          if (r.status === 'ok' && r.response?.sid) {
            setToken(r.response.sid)
            document.documentElement.dataset.auth = 'user'
            location.href = r.response.redirect || next
            return
          }
          // Fall through to OTP — re-call /start with force:'otp' so user
          // gets a code in their mailbox.
          try {
            await apiFetch('/api/auth/start', {
              method: 'POST',
              body: JSON.stringify({ email, channel: 'otp', locale: getLocale(), force: 'otp' }),
            })
          } catch (err) { msg.innerHTML = `<span class="ps-error">${err.message || t('error.network')}</span>`; return }
        }

        startForm.hidden = true
        verifyForm.hidden = false
        msg.innerHTML = `<span class="ps-msg--ok">${t('login.sent_ok')}</span>`
      })

      document.getElementById('back').addEventListener('click', () => {
        verifyForm.hidden = true
        startForm.hidden = false
        msg.textContent = ''
      })

      // ----- verify (code submit) -----
      verifyForm.addEventListener('submit', async (e) => {
        e.preventDefault()
        msg.textContent = t('common.verifying')
        const code = new FormData(verifyForm).get('code')
        try {
          const data = await apiFetch('/api/auth/otp/verify', { method: 'POST', body: JSON.stringify({ email, code }) })
          if (!data?.sid) throw new Error(t('error.network'))
          setToken(data.sid)
          document.documentElement.dataset.auth = 'user'
          msg.textContent = t('login.success')
          // If the user has no passkey yet, offer enrollment before redirecting.
          // hasPasskey is reported by the verify response.
          if (data.hasPasskey === false) {
            await offerEnroll()
            return
          }
          location.href = data.redirect || next
        } catch (err) { msg.innerHTML = `<span class="ps-error">${err.message || t('error.network')}</span>` }
      })

      // ----- conditional UI -----
      // Fires in the background. The OS shows a passkey suggestion in the
      // email field's autofill chip; mediation:'conditional' resolves only
      // when the user actually picks it. We abort if the user submits the
      // regular email form first (start handler races and wins).
      if (await conditionalUiAvailable()) {
        const condCtl = new AbortController()
        startForm.addEventListener('submit', () => condCtl.abort(), { once: true })
        startConditionalLogin(apiFetch, condCtl.signal).then((r) => {
          if (r.status === 'ok' && r.response?.sid) {
            setToken(r.response.sid)
            document.documentElement.dataset.auth = 'user'
            location.href = next
          }
          // any other status: silently no-op; user finishes via normal form.
        }).catch(() => { /* benign */ })
      }
    }

    document.addEventListener('astro:page-load', () => { void initLogin() })
  </script>
</Base>
