---
import Base from '~/layouts/Base.astro'
import BarriosDatalist from '~/components/BarriosDatalist.astro'
import T from '~/components/T.astro'
import { tFor } from '~/lib/i18n.ts'
import { CATEGORIES, initials, mediaUrl } from '~/lib/api.ts'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

// Build-time fetch of the initial (unfiltered) specialist list. SSR'd into the
// page so users see real cards from FCP — no skeleton, no post-paint mutation,
// no layout jump. Filter inputs still re-fetch client-side and replace cards,
// but that's USER-INITIATED so it doesn't count against the CLS gate.
const API = (typeof import.meta.env.PUBLIC_API_URL === 'string' && import.meta.env.PUBLIC_API_URL) ||
  'https://api.pyaserv.com'

interface Specialist {
  readonly id: string
  readonly displayName: string
  readonly headline: string
  readonly headlineEs: string
  readonly headlineEn: string
  readonly barrio: string
  readonly photo: string | null
  readonly verified: boolean
  readonly primaryCategory: string | null
  readonly ratingAvg: number
  readonly ratingCount: number
}

const fetchSpecialists = async (): Promise<ReadonlyArray<Specialist>> => {
  try {
    const r = await fetch(`${API}/v1/specialists`)
    if (!r.ok) return []
    const body = await r.json() as { data?: ReadonlyArray<Specialist> }
    return body.data ?? []
  } catch { return [] }
}

const items = await fetchSpecialists()
const categoryEmoji = (value: string | null): string =>
  CATEGORIES.find((c) => c.value === value)?.emoji ?? '•'
const renderStars = (n: number): string =>
  '★★★★★'.slice(0, Math.round(n)) + '☆☆☆☆☆'.slice(0, 5 - Math.round(n))

const countOneEs = tFor('es', 'specialists.count.one')
const countManyEs = tFor('es', 'specialists.count.many')
const countOneEn = tFor('en', 'specialists.count.one')
const countManyEn = tFor('en', 'specialists.count.many')
const ctaEs = tFor('es', 'specialists.card.cta')
const ctaEn = tFor('en', 'specialists.card.cta')
const verifiedEs = tFor('es', 'specialists.card.verified')
const verifiedEn = tFor('en', 'specialists.card.verified')
---
<Base
  title="Profesionales"
  description="Plomeros, electricistas, peluqueras, profes — encontralos en tu barrio en Asunción."
  titleKey="specialists.title"
  descriptionKey="specialists.description"
  active="specialists"
>
  <section class="ps-section" data-base={base}>
    <div class="ps-page-head">
      <T k="specialists.heading" as="h1" />
      <T k="specialists.intro" as="p" />
    </div>

    <form id="filters" class="ps-filters" autocomplete="off">
      <label>
        <T k="specialists.filter.category" as="span" />
        <select name="category" id="f-category" aria-label="Categoría">
          <option value="" data-i18n="specialists.filter.category.all">Todas</option>
        </select>
      </label>
      <label>
        <T k="specialists.filter.barrio" as="span" />
        <input type="text" name="barrio" id="f-barrio" list="ps-barrios" data-i18n-placeholder="specialists.filter.barrio.placeholder" placeholder="Villa Morra, Carmelitas…" />
      </label>
      <button type="button" id="near-me-btn" class="ps-btn ps-btn--ghost ps-btn--sm"><T k="specialists.filter.near_me" /></button>
    </form>

    <p id="status" class="ps-msg" aria-live="polite">
      <span lang="es">{items.length} {items.length === 1 ? countOneEs : countManyEs}</span>
      <span lang="en">{items.length} {items.length === 1 ? countOneEn : countManyEn}</span>
    </p>
    <div id="results" class="ps-cards">
      {items.map((s) => {
        const catLabelEs = s.primaryCategory ? tFor('es', `category.${s.primaryCategory}`) : null
        const catLabelEn = s.primaryCategory ? tFor('en', `category.${s.primaryCategory}`) : null
        return (
          <a class="ps-card ps-card--with-avatar" href={`${base}/specialists/${s.id}/`}>
            <div class={`ps-card__avatar ${s.photo ? 'ps-avatar--photo' : 'ps-avatar--initials'}`}>
              {s.photo
                ? <img class="ps-avatar__img" width="56" height="56" loading="lazy" decoding="async" alt="" src={mediaUrl(s.photo)} />
                : <span class="ps-avatar__initials" aria-hidden="true">{initials(s.displayName)}</span>}
            </div>
            <div class="ps-card__main">
              <div class="ps-row">
                <h2>{s.displayName}</h2>
                {s.verified && (
                  <span class="ps-badge">
                    <span lang="es">{verifiedEs}</span>
                    <span lang="en">{verifiedEn}</span>
                  </span>
                )}
              </div>
              <p class="ps-card__sub">📍 {s.barrio}</p>
              {s.primaryCategory && (
                <div class="ps-row">
                  <span class="ps-chip">
                    {categoryEmoji(s.primaryCategory)}
                    {' '}
                    <span lang="es">{catLabelEs}</span>
                    <span lang="en">{catLabelEn}</span>
                  </span>
                  {s.ratingCount > 0 && (
                    <>
                      <span class="ps-stars-inline" aria-label={`${s.ratingAvg} de 5`}>{renderStars(s.ratingAvg)}</span>
                      <span class="ps-card__sub">{s.ratingAvg} ({s.ratingCount})</span>
                    </>
                  )}
                </div>
              )}
              <p class="ps-card__body">
                <span lang="es">{s.headlineEs}</span>
                <span lang="en">{s.headlineEn}</span>
              </p>
              <div class="ps-card__cta">
                <span lang="es">{ctaEs}</span>
                <span lang="en">{ctaEn}</span>
              </div>
            </div>
          </a>
        )
      })}
    </div>
  </section>

  <BarriosDatalist />

  <script>
    // @ts-nocheck
    import { apiFetch, CATEGORIES, categoryLabel, categoryEmoji, initials, mediaUrl } from '../lib/api.ts'
    import { t } from '../lib/i18n.ts'

    const sec = document.querySelector('.ps-section')
    const base = sec.dataset.base ?? ''
    const catSel = document.getElementById('f-category')
    for (const c of CATEGORIES) {
      const opt = document.createElement('option')
      opt.value = c.value
      opt.textContent = `${c.emoji} ${categoryLabel(c.value)}`
      catSel.append(opt)
    }

    const results = document.getElementById('results')
    const status = document.getElementById('status')
    const form = document.getElementById('filters')

    const escape = (s) => String(s).replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]))

    const render = (items) => {
      results.removeAttribute('aria-busy')
      if (items.length === 0) {
        results.innerHTML = ''
        status.innerHTML = `<span class="ps-empty"><span class="ps-empty__icon">🔍</span><strong class="ps-empty__title">${t('specialists.empty.title')}</strong><span class="ps-empty__hint">${t('specialists.empty.hint')}</span></span>`
        return
      }
      status.textContent = `${items.length} ${items.length === 1 ? t('specialists.count.one') : t('specialists.count.many')}`
      const verifiedLabel = t('specialists.card.verified')
      const cta = t('specialists.card.cta')
      const renderStars = (n) => '★★★★★'.slice(0, Math.round(n)) + '☆☆☆☆☆'.slice(0, 5 - Math.round(n))
      results.innerHTML = items.map((s) => `
        <a class="ps-card ps-card--with-avatar" href="${base}/specialists/${escape(s.id)}/">
          <div class="ps-card__avatar ${s.photo ? 'ps-avatar--photo' : 'ps-avatar--initials'}">
            ${s.photo
              ? `<img class="ps-avatar__img" width="56" height="56" loading="lazy" decoding="async" alt="" src="${mediaUrl(s.photo)}"/>`
              : `<span class="ps-avatar__initials" aria-hidden="true">${escape(initials(s.displayName))}</span>`}
          </div>
          <div class="ps-card__main">
            <div class="ps-row">
              <h2>${escape(s.displayName)}</h2>
              ${s.verified ? `<span class="ps-badge">${verifiedLabel}</span>` : ''}
            </div>
            <p class="ps-card__sub">📍 ${escape(s.barrio)}${s.distanceKm != null ? ` · ${s.distanceKm} km` : ''}</p>
            ${s.primaryCategory ? `<div class="ps-row"><span class="ps-chip">${categoryEmoji(s.primaryCategory)} ${categoryLabel(s.primaryCategory)}</span>${s.ratingCount > 0 ? `<span class="ps-stars-inline" aria-label="${s.ratingAvg} de 5">${renderStars(s.ratingAvg)}</span><span class="ps-card__sub">${s.ratingAvg} (${s.ratingCount})</span>` : ''}</div>` : ''}
            <p class="ps-card__body">${escape(s.headline)}</p>
            <div class="ps-card__cta"><span>${cta}</span></div>
          </div>
        </a>`).join('')
    }

    let nearCoords = null

    const load = async () => {
      const fd = new FormData(form)
      const params = new URLSearchParams()
      if (fd.get('barrio')) params.set('barrio', fd.get('barrio'))
      if (nearCoords) params.set('near', `${nearCoords.lat},${nearCoords.lng}`)
      status.textContent = t('common.loading')
      results.setAttribute('aria-busy', 'true')
      results.innerHTML = ''
      try {
        let items = await apiFetch(`/v1/specialists?${params.toString()}`)
        const category = fd.get('category')
        if (category) {
          const ls = await apiFetch(`/v1/listings?category=${encodeURIComponent(category)}`)
          const allowed = new Set(ls.map((l) => l.specialistId))
          items = items.filter((s) => allowed.has(s.id))
        }
        render(items)
      } catch (err) {
        results.removeAttribute('aria-busy')
        status.innerHTML = `<span class="ps-error">${escape(err.message || t('error.network'))}</span>`
      }
    }

    form.addEventListener('input', load)
    form.addEventListener('submit', (e) => { e.preventDefault(); load() })
    const nearBtn = document.getElementById('near-me-btn')
    nearBtn.addEventListener('click', () => {
      if (!navigator.geolocation) return
      nearBtn.disabled = true
      nearBtn.textContent = t('common.loading')
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          nearCoords = { lat: pos.coords.latitude, lng: pos.coords.longitude }
          nearBtn.disabled = false
          nearBtn.textContent = t('specialists.filter.near_me_on')
          load()
        },
        () => {
          nearBtn.disabled = false
          nearBtn.textContent = t('specialists.filter.near_me_denied')
        },
        { enableHighAccuracy: false, timeout: 8000, maximumAge: 60000 },
      )
    })
    // NOTE: no initial load() — cards are SSR'd inline. Filter input still triggers it.
  </script>
</Base>
