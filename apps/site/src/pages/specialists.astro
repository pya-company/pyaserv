---
import Base from '~/layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---
<Base
  title="Profesionales"
  description="Plomeros, electricistas, peluqueras, profes — encontralos en tu barrio en Asunción."
  active="specialists"
>
  <section class="ps-section">
    <h1>Profesionales disponibles</h1>
    <p>Filtrá por categoría o barrio. El contacto se hace fuera de la plataforma; PyaServ solo presenta.</p>

    <form id="filters" class="ps-filters" autocomplete="off">
      <label>
        Categoría
        <select name="category" id="f-category">
          <option value="">Todas</option>
        </select>
      </label>
      <label>
        Barrio
        <input type="text" name="barrio" id="f-barrio" placeholder="Villa Morra, Carmelitas…" />
      </label>
    </form>

    <div id="results" class="ps-cards" aria-busy="true" data-base={base}>Cargando…</div>
  </section>

  <script>
    // @ts-nocheck
    import { apiFetch, CATEGORIES } from '../lib/api.ts'

    const cats = document.getElementById('f-category')
    for (const c of CATEGORIES) {
      const opt = document.createElement('option')
      opt.value = c.value
      opt.textContent = c.label
      cats.append(opt)
    }

    const results = document.getElementById('results')
    const base = results.dataset.base ?? ''
    const form = document.getElementById('filters')

    const render = (items) => {
      results.removeAttribute('aria-busy')
      if (items.length === 0) {
        results.innerHTML = '<p class="ps-empty">No hay resultados con ese filtro.</p>'
        return
      }
      results.innerHTML = items
        .map(
          (s) => `
          <article class="ps-card">
            <header>
              <h2>${s.displayName}${s.verified ? ' <span class="ps-badge">✓ verificado</span>' : ''}</h2>
              <p class="ps-card__sub">${s.barrio}</p>
            </header>
            <p>${s.headline}</p>
            <p class="ps-card__cta"><a href="tel:${s.phone}">Llamar</a> · ${s.whatsapp ? `<a href="https://wa.me/${s.whatsapp.replace(/[^0-9]/g, '')}">WhatsApp</a>` : ''}</p>
          </article>`,
        )
        .join('')
    }

    const load = async () => {
      const fd = new FormData(form)
      const params = new URLSearchParams()
      if (fd.get('barrio')) params.set('barrio', fd.get('barrio'))
      results.setAttribute('aria-busy', 'true')
      results.textContent = 'Cargando…'
      try {
        const data = await apiFetch(`/v1/specialists?${params.toString()}`)
        const category = fd.get('category')
        let items = data
        if (category) {
          const ls = await apiFetch(`/v1/listings?category=${encodeURIComponent(category)}`)
          const allowed = new Set(ls.map((l) => l.specialistId))
          items = items.filter((s) => allowed.has(s.id))
        }
        render(items)
      } catch (err) {
        results.removeAttribute('aria-busy')
        results.innerHTML = `<p class="ps-error">${err.message}</p>`
      }
    }

    form.addEventListener('input', load)
    form.addEventListener('submit', (e) => {
      e.preventDefault()
      load()
    })
    load()
  </script>
</Base>
