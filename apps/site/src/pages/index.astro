---
import Base from '~/layouts/Base.astro'
import T from '~/components/T.astro'
import { tFor, interp } from '~/lib/i18n.ts'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const href = (p: string): string => `${base}${p}`

// Build-time stats. Fetched once during `astro build`; numbers refresh every
// deploy. Lets us SSR the social-proof line into the initial HTML so there's
// no API roundtrip, no MutationObserver-visible swap, no fade-in pop on load.
const API = (typeof import.meta.env.PUBLIC_API_URL === 'string' && import.meta.env.PUBLIC_API_URL) ||
  'https://api.pyaserv.com'

const fetchCount = async (path: string): Promise<number> => {
  try {
    const r = await fetch(`${API}${path}`)
    if (!r.ok) return 0
    const body = await r.json() as { data?: unknown[] }
    return Array.isArray(body?.data) ? body.data.length : 0
  } catch { return 0 }
}

const [specs, reqs] = await Promise.all([
  fetchCount('/v1/specialists'),
  fetchCount('/v1/requests'),
])
const showStats = specs + reqs > 0
const statsEs = showStats ? interp(tFor('es', 'home.stats'), { specs, reqs }) : ''
const statsEn = showStats ? interp(tFor('en', 'home.stats'), { specs, reqs }) : ''
---
<Base
  title="Servicios en Paraguay sin comisiones"
  description="PyaServ conecta profesionales con clientes en Paraguay. Sin comisiones por contacto, sin pagos en plataforma."
  titleKey="home.title"
  descriptionKey="home.description"
  active="home"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': [
      {
        '@type': 'Organization',
        '@id': 'https://pyaserv.com/#org',
        name: 'PyaServ',
        url: 'https://pyaserv.com/',
        logo: 'https://pyaserv.com/favicon.svg',
        sameAs: ['https://github.com/pya-company/pyaserv'],
        areaServed: { '@type': 'Country', name: 'Paraguay' },
      },
      {
        '@type': 'WebSite',
        '@id': 'https://pyaserv.com/#site',
        url: 'https://pyaserv.com/',
        name: 'PyaServ',
        description: 'Marketplace de servicios en Paraguay sin comisiones.',
        publisher: { '@id': 'https://pyaserv.com/#org' },
        potentialAction: {
          '@type': 'SearchAction',
          target: 'https://pyaserv.com/specialists/?barrio={search_term_string}',
          'query-input': 'required name=search_term_string',
        },
        inLanguage: ['es', 'en'],
      },
    ],
  })} />
  <section class="ps-hero">
    <T k="home.hero.title" as="h1" />
    <T k="home.hero.body" as="p" />
    {showStats && (
      <p class="ps-home-stats">
        <span lang="es" set:html={statsEs} />
        <span lang="en" set:html={statsEn} />
      </p>
    )}
  </section>

  <div class="ps-mode-grid">
    <a href={href('/specialists/')} class="ps-mode-card ps-mode-card--specialist">
      <span class="ps-mode-card__icon" aria-hidden="true">🛠️</span>
      <T k="home.specialists.title" as="h2" class="ps-mode-card__title" />
      <T k="home.specialists.desc" as="p" class="ps-mode-card__desc" />
      <T k="home.specialists.cta" as="span" class="ps-mode-card__cta" />
    </a>

    <a href={href('/clients/')} class="ps-mode-card ps-mode-card--client">
      <span class="ps-mode-card__icon" aria-hidden="true">📢</span>
      <T k="home.clients.title" as="h2" class="ps-mode-card__title" />
      <T k="home.clients.desc" as="p" class="ps-mode-card__desc" />
      <T k="home.clients.cta" as="span" class="ps-mode-card__cta" />
    </a>
  </div>

  <p class="ps-banner" id="home-banner">
    <T k="home.banner.status_label" as="strong" />
    <T k="home.banner.body" />
    <a href={href('/me/')}><T k="home.banner.cta" /></a>.
    <T k="home.banner.tail" />
  </p>

</Base>
