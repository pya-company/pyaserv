---
import Base from '~/layouts/Base.astro'
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const href = (p: string): string => `${base}${p}`
---
<Base
  title="Servicios en Paraguay sin comisiones"
  description="PyaServ conecta profesionales con clientes en Paraguay. Sin comisiones por contacto, sin pagos en plataforma."
  titleKey="home.title"
  descriptionKey="home.description"
  active="home"
>
  <section class="ps-hero">
    <h1 data-i18n="home.hero.title">Servicios en Paraguay, sin intermediarios.</h1>
    <p data-i18n="home.hero.body">
      Si ofrecés un servicio o si buscás a alguien que resuelva algo concreto,
      PyaServ tiene un lado para vos. Nada de comisiones por presentar — el trato lo cierran ustedes.
    </p>
    <p id="home-stats" class="ps-home-stats" aria-live="polite"></p>
  </section>

  <div class="ps-mode-grid">
    <a href={href('/specialists/')} class="ps-mode-card ps-mode-card--specialist">
      <span class="ps-mode-card__icon" aria-hidden="true">🛠️</span>
      <h2 class="ps-mode-card__title" data-i18n="home.specialists.title">Necesito a un profesional</h2>
      <p class="ps-mode-card__desc" data-i18n="home.specialists.desc">
        Plomeros, electricistas, profes, peluqueras — buscá por barrio y categoría.
        Contactá directo cuando te decidas.
      </p>
      <span class="ps-mode-card__cta" data-i18n="home.specialists.cta">Ver profesionales →</span>
    </a>

    <a href={href('/clients/')} class="ps-mode-card ps-mode-card--client">
      <span class="ps-mode-card__icon" aria-hidden="true">📢</span>
      <h2 class="ps-mode-card__title" data-i18n="home.clients.title">Ofrezco un servicio</h2>
      <p class="ps-mode-card__desc" data-i18n="home.clients.desc">
        Mirá los pedidos abiertos en tu zona. Si encaja con lo tuyo, escribiles directo —
        sin filtros, sin pago para postularte.
      </p>
      <span class="ps-mode-card__cta" data-i18n="home.clients.cta">Ver pedidos →</span>
    </a>
  </div>

  <p class="ps-banner" id="home-banner">
    <strong data-i18n="home.banner.status_label">Estado:</strong>
    <span data-i18n="home.banner.body">MVP en vivo. Crearás tu perfil de profesional o tu pedido en el panel</span>
    <a href={href('/me/')} data-i18n="home.banner.cta">Mi panel</a>.
    <span data-i18n="home.banner.tail">Si todavía no tenés cuenta, te creamos una con tu email — sin contraseñas.</span>
  </p>

  <script>
    // @ts-nocheck
    import { apiFetch } from '../lib/api.ts'
    import { interp, t } from '../lib/i18n.ts'
    ;(async () => {
      try {
        const [specs, reqs] = await Promise.all([
          apiFetch('/v1/specialists').catch(() => []),
          apiFetch('/v1/requests').catch(() => []),
        ])
        const total = (specs?.length ?? 0) + (reqs?.length ?? 0)
        if (total === 0) return
        const el = document.getElementById('home-stats')
        if (!el) return
        el.innerHTML = interp(t('home.stats'), { specs: specs.length, reqs: reqs.length })
      } catch {}
    })()
  </script>
</Base>
