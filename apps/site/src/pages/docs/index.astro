---
import Base from '~/layouts/Base.astro'
import '~/styles/components-lib.css'
import '~/styles/demo-and-docs.css'
import DocsSidebar from '~/components/DocsSidebar.astro'
import { TOC } from '~/data/docs-toc.ts'
import { tFor, type Locale } from '~/lib/i18n.ts'

const loc: Locale = 'es'
const title = tFor(loc, 'docs.page_title')
const intro = tFor(loc, 'docs.page_intro')
const statusLabel = (s: 'live' | 'demo' | 'soon') =>
  s === 'live' ? tFor(loc, 'docs.status_live')
  : s === 'demo' ? tFor(loc, 'docs.status_demo')
  : tFor(loc, 'docs.status_soon')
---
<Base title={title} active="home" description={intro}>
  <div class="docs-wiki">
    <DocsSidebar />

    <main class="docs-content">
      <header class="docpage__head" style="margin-bottom: var(--ps-space-5);">
        <h1 data-i18n="docs.page_title" style="font-size: clamp(24px, 4vw, 32px); margin: 0 0 var(--ps-space-2) 0; font-weight: 800; letter-spacing: -0.02em; color: var(--ps-text);">{title}</h1>
        <p data-i18n="docs.page_intro" style="margin: 0; color: var(--ps-text-muted); font-size: 16px; line-height: 1.55;">{intro}</p>
      </header>

      {TOC.map((entry) => (
        <section style="margin-bottom: var(--ps-space-6);">
          <h2 style="font-size: 18px; font-weight: 700; color: var(--ps-text); margin: 0 0 var(--ps-space-3) 0; letter-spacing: -0.01em;">
            {tFor(loc, entry.group.i18nKey)}
          </h2>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--ps-space-2);">
            {entry.pages.map((p) => (
              <li>
                <a href={`/docs/${p.slug}/`} style="display: flex; align-items: baseline; gap: var(--ps-space-2); padding: var(--ps-space-2) var(--ps-space-3); background: var(--ps-surface); border: 1px solid var(--ps-border); border-radius: var(--ps-radius-sm); text-decoration: none; color: var(--ps-text); transition: border-color .15s, background .15s;">
                  <span style="font-size: 11px; font-weight: 700; background: var(--ps-acc-soft); color: var(--ps-acc); padding: 2px 8px; border-radius: 3px; letter-spacing: .05em; flex-shrink: 0;">{p.code}</span>
                  <span style="flex: 1; font-weight: 600;">{p.title}</span>
                  <span class="docs-sidebar__status" data-status={p.status}>{statusLabel(p.status)}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </main>
  </div>
</Base>
