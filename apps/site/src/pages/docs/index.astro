---
import Base from '~/layouts/Base.astro'
import '~/styles/components-lib.css'
import { FeatureCard } from '~/components-lib/molecules.ts'

interface Feature {
  readonly code: string
  readonly title: string
  readonly desc: string
  readonly status: 'live' | 'demo' | 'soon'
  readonly statusLabel: string
  readonly docUrl?: string
  readonly demoUrl?: string
  readonly realUrl?: string
}

const features: ReadonlyArray<Feature> = [
  { code: 'A', title: 'Tu perfil público',     status: 'live',
    desc: 'Página propia con URL pyaserv.com/p/<tu-slug>. Foto, portada, bio, servicios con precio, galería, reseñas, badges, horario, botón directo a WhatsApp.',
    docUrl: '/docs/perfil/', demoUrl: '/me/?demo=1&tour=T1', realUrl: '/p/maria-gonzalez-019ecf', statusLabel: 'En vivo' },
  { code: 'K', title: 'Onboarding Tour',       status: 'live',
    desc: '7 pasos guiados que llevan al nuevo profesional por el armado del perfil. Auto-lanza al primer ingreso a /me/.',
    docUrl: '/docs/tour/', demoUrl: '/me/?demo=1&tour=T1', statusLabel: 'En vivo' },
  { code: 'G', title: 'Insignias',             status: 'live',
    desc: '18 insignias en 4 categorías (tier, hito, superlativo, colección). Aprendiz → Patrón. Compartibles.',
    docUrl: '/docs/insignias/', demoUrl: '/me/?demo=1&tab=game', realUrl: '/me/?tab=game', statusLabel: 'En vivo' },
  { code: 'J', title: 'XP, rachas, misiones',  status: 'live',
    desc: 'Sistema de XP por acción. Racha diaria con freezes. Misiones diarias y semanales con recompensas.',
    docUrl: '/docs/xp/', realUrl: '/me/?tab=game', statusLabel: 'En vivo' },
  { code: 'E', title: 'Cotizador rápido',      status: 'live',
    desc: 'Plantillas por oficio. Items con cantidad y precio, IVA opcional, PDF descargable, envío por WhatsApp con un click.',
    docUrl: '/docs/cotizador/', demoUrl: '/me/quotes/new/?demo=1', realUrl: '/me/quotes/new/', statusLabel: 'En vivo' },
  { code: 'B', title: 'Analítica',             status: 'live',
    desc: 'Cuántos vieron tu perfil, cuántos clickearon WhatsApp, de dónde vienen, comparación con el promedio de tu rubro.',
    docUrl: '/docs/analitica/', realUrl: '/me/?tab=stats', statusLabel: 'En vivo' },
  { code: 'I', title: 'Mis clientes',          status: 'live',
    desc: 'Lite-CRM: clientes recurrentes se agregan al completar un trabajo. Notas editables, recordatorio "6 meses sin verlo".',
    docUrl: '/docs/mis-clientes/', realUrl: '/me/?tab=clients', statusLabel: 'En vivo' },
  { code: 'F', title: 'Filtros de leads',      status: 'live',
    desc: 'Configurá presupuesto mínimo + esconder cuentas nuevas (anti-spam). Hoy se persisten; el filter en el query se aplica en sprint próximo.',
    docUrl: '/docs/filtros-leads/', realUrl: '/me/?tab=profile', statusLabel: 'En vivo' },
  { code: 'H', title: 'Multilingüe per-perfil',status: 'live',
    desc: 'Versión en guaraní de tu bio/headline sin perder el SEO en español. Hreflang automático en el perfil público.',
    docUrl: '/docs/multilingue/', realUrl: '/me/?tab=profile', statusLabel: 'En vivo' },
  { code: 'L', title: 'Demo Mode v2',          status: 'live',
    desc: 'Cualquier página real con ?demo=1 — apiFetch interceptado, datos mock, banner permanente, identidad logged-out. Mismo código que producción.',
    docUrl: '/docs/demo-mode/', demoUrl: '/me/?demo=1', statusLabel: 'En vivo' },
  { code: 'M', title: 'Docs + Releases',       status: 'live',
    desc: 'Esta página. Cada feature con detalles, GIFs, link a demo y a la versión real. Notas de cada release con suscripción RSS.',
    docUrl: '/docs/this-doc/', realUrl: '/releases/', statusLabel: 'En vivo' },
  { code: 'P', title: 'Components (Storybook)',status: 'live',
    desc: 'Catálogo de componentes pure-stateless con panel de props + locale switcher. Mismo cuerpo de código que producción.',
    docUrl: '/components/', realUrl: '/components/', statusLabel: 'En vivo' },
  { code: 'C', title: 'Recap-card PNG (WhatsApp Status)', status: 'soon',
    desc: 'Generador 1080×1920 PNG semanal listo para compartir. Cada insignia desbloqueada también genera una tarjeta.',
    docUrl: '/docs/recap-card/', statusLabel: 'Próximo' },
  { code: 'D', title: 'SIFEN — factura electrónica', status: 'soon',
    desc: 'Generación de factura electrónica integrada con DGII. En espera de consultoría tributaria.',
    docUrl: '/docs/sifen/', statusLabel: 'Próximo' },
  { code: 'N', title: 'Local-first / Offline',status: 'soon',
    desc: 'Páginas se renderizan offline desde cache, mutations queued, sync en reconexión, conflict resolution. Multi-sprint, prioridad alta.',
    docUrl: '/docs/local-first/', statusLabel: 'Planeado' },
  { code: 'O', title: 'Mobile (Tauri WebView)',status: 'soon',
    desc: 'iOS + Android app envolviendo el mismo código web. Single codebase. Sprint 7+.',
    docUrl: '/docs/mobile/', statusLabel: 'Planeado' },
]
---
<Base title="Documentación" active="home" description="Lista de features de PyaServ. Probalas en modo demo antes de comprometerte.">
  <section style="max-width:900px;margin:0 auto;padding:24px 16px 8px;text-align:center;">
    <h1 style="font-size:clamp(28px,5vw,40px);margin:0 0 8px 0;color:#111827;">Documentación de PyaServ</h1>
    <p style="color:#6b7280;margin:0;font-size:16px;">
      Catálogo completo de features. Cada una tiene página propia con detalles, link a demo y a producción.
    </p>
    <div style="margin-top:16px;display:flex;justify-content:center;gap:8px;flex-wrap:wrap;">
      <a href="#features" style="color:#4f46e5;text-decoration:none;font-weight:600;">Features ↓</a>
      <span style="color:#9ca3af;">·</span>
      <a href="#releases" style="color:#4f46e5;text-decoration:none;font-weight:600;">Novedades ↓</a>
      <span style="color:#9ca3af;">·</span>
      <a href="/components/" style="color:#4f46e5;text-decoration:none;font-weight:600;">Componentes ↗</a>
    </div>
  </section>

  <section id="features" style="max-width:1100px;margin:32px auto;padding:0 16px;">
    <h2 style="font-size:22px;margin:0 0 16px 0;">Features</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:16px;">
      {features.map((f) => (
        <Fragment set:html={FeatureCard({
          code: f.code,
          title: f.title,
          description: f.desc,
          status: f.status,
          statusLabel: f.statusLabel,
          docUrl: f.docUrl,
          demoUrl: f.demoUrl,
          realUrl: f.realUrl,
          docLabel: 'Más detalles →',
          demoLabel: 'Probar demo →',
          realLabel: 'Ver real →',
          soonLabel: 'Próximamente',
        })} />
      ))}
    </div>
  </section>

  <section id="releases" style="max-width:1100px;margin:48px auto;padding:0 16px;">
    <h2 style="font-size:22px;margin:0 0 16px 0;">Novedades</h2>
    <p style="color:#6b7280;margin:0 0 16px 0;">
      Notas de cada release con tags, links a demo y descripciones detalladas.
    </p>
    <a href="/releases/" style="display:inline-block;background:#4f46e5;color:white;padding:10px 20px;border-radius:8px;text-decoration:none;font-weight:600;">
      Ver todas las novedades →
    </a>
    <p style="color:#9ca3af;font-size:13px;margin-top:12px;">
      <a href="/releases/rss.xml" style="color:#4f46e5;">RSS feed</a>
    </p>
  </section>

  <section style="max-width:900px;margin:48px auto;padding:0 16px 64px;text-align:center;color:#9ca3af;font-size:13px;">
    PyaServ — Spec v1 · Esta página se actualiza con cada release.
  </section>
</Base>
