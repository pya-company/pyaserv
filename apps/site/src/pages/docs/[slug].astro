---
import Base from '~/layouts/Base.astro'
import '~/styles/components-lib.css'
import '~/styles/demo-and-docs.css'
import DocsSidebar from '~/components/DocsSidebar.astro'
import { DOC_PAGES } from '~/data/docs-content.ts'
import { renderReleaseBody } from '~/lib/markdown-mini.ts'
import { tFor, type Locale } from '~/lib/i18n.ts'

export function getStaticPaths() {
  return DOC_PAGES.map((p) => ({ params: { slug: p.slug }, props: { doc: p } }))
}
const { doc } = Astro.props
const loc: Locale = 'es'
const statusLabel = doc.status === 'live' ? tFor(loc, 'docs.status_live')
  : doc.status === 'demo' ? tFor(loc, 'docs.status_demo')
  : tFor(loc, 'docs.status_soon')
---
<Base title={`${doc.title} — ${tFor(loc, 'docs.page_title')}`} active="home" description={doc.tldr}>
  <div class="docs-wiki">
    <DocsSidebar currentSlug={doc.slug} />

    <article class="docs-content docpage">
      <nav class="docpage__crumbs">
        <a href="/docs/">{tFor(loc, 'docs.breadcrumb_root')}</a> · <span>{doc.title}</span>
      </nav>

      <header>
        <div class="docpage__meta">
          <span class="docpage__code">{doc.code}</span>
          <span class="docpage__status" data-status={doc.status}>{statusLabel}</span>
        </div>
        <h1>{doc.title}</h1>
        <p class="docpage__tldr">{doc.tldr}</p>

        {(doc.demoUrl || doc.realUrl) && (
          <div class="docpage__actions">
            {doc.demoUrl && <a href={doc.demoUrl} class="cl-btn cl-btn--primary">{tFor(loc, 'docs.btn_try_demo')}</a>}
            {doc.realUrl && <a href={doc.realUrl} class="cl-btn cl-btn--ghost">{tFor(loc, 'docs.btn_view_real')}</a>}
          </div>
        )}
      </header>

      {doc.sections.map((section) => (
        <section>
          <h2>{section.heading}</h2>
          <Fragment set:html={renderReleaseBody(section.bodyMd)} />
        </section>
      ))}

      <div class="docpage__back">
        <a href="/docs/">{tFor(loc, 'docs.back_to_index')}</a>
      </div>
    </article>
  </div>
</Base>
